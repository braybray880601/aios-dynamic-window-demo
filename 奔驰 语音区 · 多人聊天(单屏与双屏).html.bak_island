<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>奔驰 · 语音区 · 多人聊天 · 音区识别(单屏/双屏)</title>
<!--
  多人"聊天"但【交替进行】(非同时群聊):多名乘员轮流和 MVA 说话,交互仍在原有语音区里。
  多人识别只做两件事:① 识别时标注是哪个音区在说(主驾/后排 + 方位光波);② 回应时对应到那个人。
  本场景为单屏(中控一块屏),多名乘员(主驾/后排)轮流和 MVA 说话,交互都在中间这块语音区。
-->
<style>
  :root{--ink:#eef1f4;--soft:rgba(238,241,244,.62);--faint:rgba(238,241,244,.4);--card:rgba(20,26,38,.72);--bd:rgba(255,255,255,.1);
    --drv:#5b8cff;--rear:#34d06a;--vz-w:412px;--wc:#4ac8ff}
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{height:100%;background:#05070b;overflow:hidden;font-family:"PingFang SC","Microsoft YaHei",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;-webkit-font-smoothing:antialiased;color:var(--ink)}
  .viewport{position:fixed;inset:0;display:flex;align-items:center;justify-content:center}
  .stage{position:relative;width:1300px;height:812px;overflow:hidden;transform-origin:center center;border-radius:18px;box-shadow:0 40px 120px rgba(0,0,0,.65);background:radial-gradient(135% 115% at 50% 8%,#141c2a 0%,#0e1420 46%,#080b12 100%)}
  .mapbg{position:absolute;inset:0;z-index:0}.mapbg svg{position:absolute;inset:0;width:100%;height:100%}
  .mapbg-scrim{position:absolute;inset:0;background:radial-gradient(125% 105% at 50% 40%,rgba(8,11,18,.5),rgba(6,9,15,.76))}

  /* 说话人方位光波(音区指示) */
  .wave{position:absolute;pointer-events:none;opacity:0;transition:opacity .5s;z-index:6}
  .wave.l{left:0;top:50px;bottom:64px;width:130px;background:radial-gradient(ellipse at left center,color-mix(in srgb,var(--wc) 55%,transparent),transparent 72%)}
  .wave.r{right:0;top:50px;bottom:64px;width:130px;background:radial-gradient(ellipse at right center,color-mix(in srgb,var(--wc) 55%,transparent),transparent 72%)}
  .wave.b{left:0;right:0;bottom:64px;height:110px;background:radial-gradient(ellipse at center bottom,color-mix(in srgb,var(--wc) 48%,transparent),transparent 72%)}
  .wave.on{opacity:1;animation:wavep 1.3s ease-in-out infinite}
  @keyframes wavep{0%,100%{opacity:.5}50%{opacity:1}}

  /* 顶栏 */
  .statusbar{position:absolute;top:0;left:0;right:0;height:50px;display:flex;align-items:center;justify-content:space-between;padding:0 24px;z-index:55}
  .sb-left{display:flex;align-items:center;gap:12px;flex:1;min-width:0;height:100%;padding-right:24px}
  .avatar{width:36px;height:36px;border-radius:50%;flex:none;position:relative;background-image:linear-gradient(135deg,#f3c9b0,#cf9d86);box-shadow:inset 0 0 0 1.5px rgba(255,255,255,.4);transition:box-shadow .5s}
  .avatar::before{content:"";position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);filter:blur(1px);opacity:0;transition:opacity .55s;animation:spin 5s linear infinite}
  .avatar::after{content:"";position:absolute;inset:7px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.6));box-shadow:0 0 14px rgba(255,255,255,.55);opacity:0;transition:opacity .55s}
  .avatar.awake{box-shadow:none;animation:breathe 3.2s ease-in-out infinite}.avatar.awake::before,.avatar.awake::after{opacity:1}
  @keyframes spin{to{transform:rotate(360deg)}}@keyframes breathe{0%,100%{transform:scale(1)}50%{transform:scale(1.07)}}
  /* Avatar 模式:不加 wave,只在 avatar 处用座位色环指示音区 */
  .avatar-wrap{position:relative;width:36px;height:36px;flex:none}
  .aring{position:absolute;inset:-5px;border-radius:50%;box-shadow:0 0 0 2px var(--c,#5b8cff),0 0 16px 3px color-mix(in srgb,var(--c,#5b8cff) 70%,transparent);opacity:0;transition:opacity .3s}
  .aring.on{opacity:1;animation:aringp 1.3s ease-in-out infinite}
  @keyframes aringp{0%,100%{opacity:.5}50%{opacity:1}}
  /* ── TTS 播报时：avatar 持续光环涟漪(说话结束即消失)── */
  .tts-wave{position:absolute;inset:-5px;border-radius:50%;pointer-events:none;opacity:0;transition:opacity .25s;background:radial-gradient(circle,rgba(120,150,255,.34),rgba(120,150,255,0) 66%)}
  .avatar.speaking .tts-wave{opacity:1;animation:ttsglow 1.4s ease-in-out infinite}
  @keyframes ttsglow{0%,100%{transform:scale(1);opacity:.5}50%{transform:scale(1.16);opacity:.9}}
  .tts-wave::before,.tts-wave::after{content:"";position:absolute;inset:3px;border-radius:50%;border:2px solid rgba(140,165,255,.9);opacity:0}
  .avatar.speaking .tts-wave::before{animation:ttsripple 1.5s ease-out infinite}
  .avatar.speaking .tts-wave::after{animation:ttsripple 1.5s ease-out infinite .75s}
  @keyframes ttsripple{0%{transform:scale(.8);opacity:.9}70%{opacity:.22}100%{transform:scale(2.2);opacity:0}}
  .sb-voice{position:relative;display:flex;align-items:center;gap:9px;min-width:0;height:100%}
  /* 识别时:谁在说话(音区标注) */
  .seatchip{display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:800;color:#fff;background:var(--c,#5b8cff);padding:3px 10px;border-radius:20px;opacity:0;transform:translateX(-6px);transition:.3s;flex:none}
  .seatchip.show{opacity:1;transform:none}
  .seatchip::before{content:"";width:5px;height:5px;border-radius:50%;background:#fff}
  .sv-asr{display:inline-flex;align-items:center;max-width:600px;overflow:hidden;white-space:nowrap;font-size:15.5px;font-weight:600;color:var(--ink);opacity:0;transition:opacity .35s,transform .4s,filter .4s}
  .sv-asr.show{opacity:1}.sv-asr.done{color:#62e08c}.sv-asr.gone{opacity:0;transform:translateY(-7px);filter:blur(2px)}
  .sv-cur{display:inline-block;width:2px;height:16px;background:#62e08c;margin-left:2px;animation:blink 1s step-end infinite}@keyframes blink{50%{opacity:0}}
  .sb-right{display:flex;align-items:center;gap:16px;color:#dfe3e8;flex:none}.sb-clock{font-size:19px;font-weight:500}.sb-5g{font-size:10px;font-weight:700;vertical-align:top}

  /* 模式 / 音区指示 开关都在右侧控制台,画面不放 */

  /* 地图卡(单屏) */
  .map{position:absolute;top:64px;left:40px;width:300px;border-radius:20px;background:rgba(44,52,64,.5);backdrop-filter:blur(22px) saturate(1.2);box-shadow:0 8px 30px rgba(0,0,0,.3),inset 0 0 0 1px rgba(255,255,255,.12);overflow:hidden;z-index:25;color:#fff;transition:transform .42s cubic-bezier(.2,.7,.2,1)}
  .stage.voice-on .map{transform:translateX(calc(var(--vz-w) + 16px))}
  .map-top{display:flex;align-items:center;gap:9px;padding:14px 16px}.map-top .t{flex:1;font-size:16px;font-weight:500}
  .map-quick{display:flex;background:rgba(10,14,20,.4)}.map-quick div{flex:1;display:flex;align-items:center;justify-content:center;padding:12px 0;opacity:.85}.map-quick div+div{box-shadow:inset 1px 0 0 rgba(255,255,255,.08)}

  /* 单屏语音区:交互都在这一块里(交替) */
  .voice-zone{position:absolute;left:40px;top:64px;width:var(--vz-w);z-index:50}
  .rcard{display:none;border-radius:20px;background:var(--card);backdrop-filter:blur(20px) saturate(1.2);box-shadow:0 16px 44px rgba(0,0,0,.45),inset 0 0 0 1px var(--bd);overflow:hidden}
  .rcard.show{display:block;animation:grow .42s cubic-bezier(.2,.7,.2,1)}
  @keyframes grow{from{opacity:0;transform:translateY(-10px) scale(.98)}to{opacity:1;transform:none}}
  .rcard .rc-q{display:flex;align-items:center;gap:9px;padding:13px 16px;font-size:14px;color:var(--soft);border-bottom:1px solid var(--bd)}
  .rcard .rc-q .seat{font-size:11px;font-weight:800;color:#fff;background:var(--c);padding:2px 9px;border-radius:14px;flex:none}
  .rcard .rc-q .qt{color:var(--ink);font-weight:600}
  .rcard .rc-a{display:flex;align-items:flex-start;gap:10px;padding:14px 16px}
  .rcard .rc-a .ad{width:26px;height:26px;border-radius:50%;flex:none;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);position:relative;box-shadow:0 0 12px rgba(120,120,255,.4)}
  .rcard .rc-a .ad::after{content:"";position:absolute;inset:7px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.6))}
  .rcard .rc-a .at{font-size:15px;font-weight:600;line-height:1.45;color:#fff}
  .rcard .rc-a .at small{display:block;font-size:11px;font-weight:700;color:var(--c);margin-bottom:3px}

  .dock{position:absolute;left:0;right:0;bottom:0;height:64px;z-index:40;display:flex;align-items:center;gap:18px;padding:0 22px;background:rgba(12,16,24,.6);backdrop-filter:blur(26px);box-shadow:inset 0 1px 0 rgba(255,255,255,.08)}
  .dock .home{width:32px;height:32px;border-radius:50%;box-shadow:inset 0 0 0 2px rgba(255,255,255,.5);flex:none}
  .dock .tt{font-size:13px;color:var(--soft)}.dock .sep{flex:1}.dock .ctrl{display:flex;align-items:center;gap:24px;color:rgba(238,241,244,.7);font-size:18px}

  .panel{position:fixed;top:18px;right:18px;width:244px;z-index:100;background:rgba(20,22,26,.9);backdrop-filter:blur(20px);border-radius:16px;padding:15px;color:#e8eaee;font-size:12.5px;box-shadow:0 20px 50px rgba(0,0,0,.5),inset 0 0 0 1px rgba(255,255,255,.08)}
  .panel .title{font-size:13.5px;font-weight:700;color:#fff;display:flex;align-items:center;gap:7px;margin-bottom:11px}.panel .title i{width:8px;height:8px;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#ff6b9b,#ffab5b,#5b8cff)}
  .panel button{width:100%;border:0;border-radius:11px;cursor:pointer;font-family:inherit;font-weight:600;font-size:13px;padding:10px;color:#fff;margin-top:8px;text-align:left;background:rgba(255,255,255,.08);transition:.15s}
  .panel button:hover{background:rgba(255,255,255,.16)}.panel button.main{background:linear-gradient(135deg,#3b78ff,#2f6bff)}
  .panel .pseg-lbl{margin-top:12px;font-size:11px;color:#8b9098;letter-spacing:.04em}
  .panel .pseg{display:flex;gap:6px;margin-top:6px}
  .panel .pseg button{margin-top:0;width:auto;flex:1;text-align:center;padding:9px 4px;font-size:12px;font-weight:700;background:rgba(255,255,255,.07);color:#cfd3da}
  .panel .pseg button:hover{background:rgba(255,255,255,.14)}
  .panel .pseg button.on{color:#0b0a14;background:var(--wc)}
  .panel .note{margin-top:11px;font-size:11px;color:#8b9098;border-top:1px solid rgba(255,255,255,.08);padding-top:9px;line-height:1.5}
  .panel{opacity:.3;transform:scale(.86);transform-origin:top right;transition:opacity .3s ease,transform .3s ease}.panel:hover{opacity:1;transform:scale(1)}

  /* 全局：底栏 MVA 光球（语音区收起时的最小化态 · 点击唤起；区域展开时淡出）*/
  .mva-orb{width:38px;height:38px;border-radius:50%;flex:none;border:0;padding:0;cursor:pointer;position:relative;background:radial-gradient(circle at 38% 34%,#2a3340,#11161f);transition:transform .15s,opacity .35s}
  .mva-orb::before{content:"";position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);filter:blur(.6px);animation:mvaspin 6s linear infinite}
  .mva-orb::after{content:"";position:absolute;inset:7px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.62));box-shadow:0 0 11px rgba(255,255,255,.5)}
  .mva-orb:hover{transform:scale(1.06)}.mva-orb:active{transform:scale(.93)}
  .stage.voice-on .mva-orb{opacity:.4}
  .mva-orb.busy{opacity:.26 !important;pointer-events:none;filter:saturate(.55)}
  .stage.zone-hidden .voice-zone{opacity:0 !important;transform:translateY(-10px) scale(.985) !important;pointer-events:none !important;transition:opacity .35s ease,transform .35s ease}
  .stage.zone-hidden .map{transform:none !important}
  @keyframes mvaspin{to{transform:rotate(360deg)}}
</style>
</head>
<body>
<div class="viewport">
  <div class="stage" id="stage">
    <div class="mapbg">
      <svg viewBox="0 0 1300 812" preserveAspectRatio="xMidYMid slice">
        <defs><linearGradient id="bg" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#1c2533"/><stop offset="1" stop-color="#151b25"/></linearGradient></defs>
        <rect width="1300" height="812" fill="url(#bg)"/>
        <path d="M-20 612 C 120 588 210 640 250 720 C 270 766 250 812 250 812 L -20 812 Z" fill="#1d3144"/>
        <path d="M 1010 70 C 1110 60 1190 110 1180 200 C 1172 280 1080 300 1020 250 C 970 210 950 110 1010 70 Z" fill="#21362b"/>
        <g stroke="#222b39" stroke-width="15" fill="none" stroke-linecap="round"><path d="M-20 590 C 230 560 440 540 640 548 C 900 558 1080 520 1330 452"/><path d="M 300 -20 C 350 200 400 410 540 560 C 660 690 740 760 800 840"/></g>
        <g stroke="#4b5566" stroke-width="9" fill="none" stroke-linecap="round"><path d="M-20 590 C 230 560 440 540 640 548 C 900 558 1080 520 1330 452"/><path d="M 300 -20 C 350 200 400 410 540 560 C 660 690 740 760 800 840"/></g>
      </svg>
      <div class="mapbg-scrim"></div>
    </div>

    <div class="wave l" id="waveL"></div><div class="wave r" id="waveR"></div><div class="wave b" id="waveB"></div>

    <div class="statusbar">
      <div class="sb-left">
        <div class="avatar-wrap"><div class="aring" id="aring"></div><div class="avatar" id="avatar"><i class="tts-wave"></i></div></div>
        <div class="sb-voice"><span class="seatchip" id="seatChip">主驾</span><span class="sv-asr" id="svAsr"><span id="asrText"></span><span class="sv-cur" id="asrCur"></span></span></div>
      </div>
      <div class="sb-right"><span><sup class="sb-5g">5G</sup> ▮▮▮</span><span class="sb-clock">21:36</span></div>
    </div>

    <!-- 单屏:地图 + 语音区(交互都在这一块) -->
    <div class="map"><div class="map-top"><span>📍</span><span class="t">地图</span><svg width="18" height="18" viewBox="0 0 18 18"><circle cx="7.5" cy="7.5" r="5.5" fill="none" stroke="#fff" stroke-width="1.6"/><path d="M12 12l4 4" stroke="#fff" stroke-width="1.6" stroke-linecap="round"/></svg></div><div class="map-quick"><div>⌂</div><div>☰</div><div>★</div><div>⚡</div></div></div>
    <div class="voice-zone"><div class="rcard" id="rcard"></div></div>

    <div class="dock"><button class="mva-orb" id="mvaOrb" title="MVA · 唤起语音区"></button><div class="tt" id="dockTt">🏠 多人对话 · 单屏(中控一块屏)</div><div class="sep"></div><div class="ctrl"><span>❄</span><span>🚘</span><span>360</span><span>📞</span><span>▦</span></div></div>
  </div>
</div>

<div class="panel">
  <div class="title"><i></i>多人聊天 · 音区识别</div>
  <div class="pseg-lbl">音区指示</div>
  <div class="pseg"><button class="ss on" data-s="wave">光波</button><button class="ss" data-s="avatar">Avatar</button></div>
  <button class="main" id="bReplay">↺ 重播</button>
  <div class="note">多人【闲聊】· 交替进行:识别时标注音区(主驾/后排),回应对应本人。导航/媒体/车控沿用各自已做好的场景,多人版只在其上加音区标识,不在此重做。</div>
</div>

<script>
const stage=document.getElementById('stage');
function fit(){stage.style.transform=`scale(${Math.min(innerWidth/1300,innerHeight/812)*0.985})`;}
addEventListener('resize',fit);fit();
const $=id=>document.getElementById(id);

const SEAT={drv:{nm:'主驾',c:'var(--drv)',wave:'waveL'},rear:{nm:'后排',c:'var(--rear)',wave:'waveB'}};
// 单屏:主驾/后排两个音区交替(纯闲聊/信息;导航/媒体/车控沿用各自已做好的场景,这里不重做)
const TURNS=[
  {s:'drv', q:'今天限号吗?', a:'今天尾号不限行,放心走 ✓'},
  {s:'rear',q:'高速堵不堵?', a:'前方一小段缓行,整体还算顺畅 ✓'},
  {s:'drv', q:'我们大概几点到家?', a:'按现在路况,大约 18:40 到 ✓'},
  {s:'rear',q:'到家提醒我拿快递', a:'记好啦,到家提醒你拿快递 ✓'},
];

const timers=[];const at=(ms,fn)=>timers.push(setTimeout(fn,ms));
function clearT(){timers.forEach(clearTimeout);timers.length=0;}

/* ── TTS:浏览器语音合成(MVA 回应靠它播报,avatar 起涟漪)── */
let ttsOn=true,bestVoice=null;
function setSpeaking(on){const a=$('avatar');if(a)a.classList.toggle('speaking',!!on);}
function ttsStop(){try{window.speechSynthesis&&window.speechSynthesis.cancel();}catch(e){}setSpeaking(false);}
// 挑系统里"最好的"中文嗓音:优先系统默认 + 瀚/高音质 · zh-CN
function pickVoice(){
  try{
    const vs=window.speechSynthesis.getVoices()||[];
    const zh=vs.filter(v=>/zh|cmn|chinese|中文/i.test((v.lang||'')+' '+(v.name||'')));
    if(!zh.length){bestVoice=null;return;}
    const score=v=>{const n=v.name||'',l=v.lang||'';let s=0;
      if(v.default)s+=10;
      if(/瀚|高音质|高质量/i.test(n))s+=8;
      if(/zh[-_]?CN|cmn/i.test(l))s+=4;
      if(/siri/i.test(n))s+=6;
      if(/premium|enhanced|增强/i.test(n))s+=5;
      if(/tingting|ting[-\s]?ting|婷婷/i.test(n))s+=3;
      if(/meijia|美佳|sinji|善怡/i.test(n))s+=1;
      if(v.localService)s+=1;
      return s;};
    bestVoice=zh.slice().sort((a,b)=>score(b)-score(a))[0]||null;
  }catch(e){bestVoice=null;}
}
function speak(text){
  if(!ttsOn||!text)return;
  try{
    if(!('speechSynthesis' in window))return;
    if(!bestVoice)pickVoice();
    const u=new SpeechSynthesisUtterance(text);
    u.lang=(bestVoice&&bestVoice.lang)||'zh-CN';u.rate=.97;u.pitch=1.02;
    if(bestVoice)u.voice=bestVoice;
    u.onstart=()=>setSpeaking(true);
    u.onend=()=>setSpeaking(false);
    u.onerror=()=>setSpeaking(false);
    window.speechSynthesis.cancel();
    setSpeaking(true);
    window.speechSynthesis.speak(u);
  }catch(e){/* 自动播放被拦截等:静默 */}
}
try{if('speechSynthesis' in window){pickVoice();window.speechSynthesis.onvoiceschanged=pickVoice;}}catch(e){}
function typeInto(textEl,scrollEl,text,dur){let i=0;const step=dur/text.length;(function tick(){textEl.textContent=text.slice(0,i);if(scrollEl)scrollEl.scrollLeft=scrollEl.scrollWidth;if(i++<=text.length)timers.push(setTimeout(tick,step));})();}
function lightWave(id,on){$(id).classList.toggle('on',on);}
function clearWaves(){['waveL','waveR','waveB'].forEach(id=>$(id).classList.remove('on'));}

/* ── 单屏:交互都在中间这块语音区,交替 ── */
let singleStyle='wave';   // 'wave'=方位光波 | 'avatar'=只在 avatar 处用座位色环
function showSpeaker(s,on){
  if(singleStyle==='wave'){ if(on){clearWaves();lightWave(s.wave,true);} else lightWave(s.wave,false); }
  else { const ar=$('aring'); if(on){ar.style.setProperty('--c',s.c);ar.classList.add('on');} else ar.classList.remove('on'); }
}
function resetSingle(){
  clearWaves();$('aring').classList.remove('on');$('avatar').classList.remove('awake','speaking');ttsStop();syncMap(false);
  $('seatChip').className='seatchip';$('svAsr').className='sv-asr';$('asrText').textContent='';$('asrCur').style.display='';
  $('rcard').className='rcard';$('rcard').innerHTML='';
}
/* 流式地图:整段对话进行中,地图只推走一次并保持;会话结束/复位才收回一次。
   IRON RULE:语音区内容(回应卡)出现前,地图必须已经推走——不会重叠。 */
function syncMap(active){stage.classList.toggle('voice-on',!!active);}
function singleTurn(t0,turn){
  const s=SEAT[turn.s];
  at(t0,()=>{                                    // 识别中:仅顶栏 ASR(不属语音区),地图保持推走状态
    showSpeaker(s,true);$('avatar').classList.add('awake');
    $('rcard').className='rcard';                // 收起上一条
    $('seatChip').textContent=s.nm;$('seatChip').style.setProperty('--c',s.c);$('seatChip').className='seatchip show';
    $('svAsr').className='sv-asr show';$('asrText').textContent='';$('asrCur').style.display='';typeInto($('asrText'),$('svAsr'),turn.q,1400);
  });
  at(t0+1800,()=>{$('asrCur').style.display='none';$('svAsr').classList.add('done');});
  at(t0+2300,()=>{$('svAsr').classList.add('gone');showSpeaker(s,false);});
  at(t0+2780,()=>{                               // 地图已让位:回应卡片在语音区出现,对应到本人 + TTS 播报
    $('svAsr').className='sv-asr';$('seatChip').className='seatchip';
    $('rcard').innerHTML=`<div class="rc-q"><span class="seat" style="--c:${s.c}">${s.nm}</span><span class="qt">"${turn.q}"</span></div>
      <div class="rc-a"><span class="ad"></span><div class="at"><small style="--c:${s.c}">MVA → ${s.nm}</small>${turn.a}</div></div>`;
    $('rcard').className='rcard show';
    speak(turn.a);                               // MVA 回应:语音播报 + avatar 涟漪
  });
  return t0+4900;
}
function playSingle(){
  clearT();$('dockTt').textContent='🏠 多人对话 · 中控一块屏';resetSingle();
  syncMap(true);                                 // 会话开始:地图整段推走一次,贯穿所有轮次保持
  let t=600;TURNS.forEach(tn=>{t=singleTurn(t,tn);});
  at(t,()=>{clearWaves();$('avatar').classList.remove('awake');ttsStop();syncMap(false);});  // 整段结束:地图收回一次
}

document.querySelectorAll('.ss').forEach(b=>b.onclick=()=>{singleStyle=b.dataset.s;document.querySelectorAll('.ss').forEach(x=>x.classList.toggle('on',x===b));playSingle();});
$('bReplay').onclick=playSingle;
setTimeout(playSingle,700);
</script>

<script>
(function(){
  var orb=document.getElementById('mvaOrb');if(!orb)return;
  var stage=document.querySelector('.stage');
  var watch=[document.querySelector('.voice-zone'),document.querySelector('.statusbar')].filter(Boolean);
  var busy=true,settleT=null;
  function en(on){orb.classList.toggle('busy',!on);}
  function settle(){busy=false;en(true);}
  function bump(){busy=true;en(false);clearTimeout(settleT);settleT=setTimeout(settle,1200);}
  try{var obs=new MutationObserver(bump);watch.forEach(function(n){obs.observe(n,{childList:true,subtree:true,characterData:true,attributes:true,attributeFilter:['class','style']});});}catch(e){}
  bump();
  orb.onclick=function(){if(busy)return;stage.classList.toggle('zone-hidden');};
})();
</script>
</body>
</html>
