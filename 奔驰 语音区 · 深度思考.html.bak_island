<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>奔驰 · 深度思考 / 任务执行</title>
<!--
  场景：语音多目的地路线规划
  左侧语音区：① 顶部识别行（用户语音单行滚动显示）→ ② 识别成功变色、消失
             → ③ 一句回复 → ④ 行程逐条「生长」出现 → ⑤ 底部露出「开始导航」
  右侧地图：参考 奔驰 真实导航页（高德车机版夜间底图）。
           随左侧每个目的地实时扎点（节奏同步），最后画出完整绿色路线。
-->
<style>
  :root{
    --bg1:#161d27;--bg2:#1b2330;
    --road:#39424f;--road-core:#4c5666;--road-casing:#283040;--road-minor:#333c4a;
    --route:#34d06a;--route-glow:rgba(52,208,110,.55);
    --water:#1d3144;--water-edge:#24405a;--water-label:#5d7e98;
    --label:#9aa3b0;--label-strong:#c6ccd4;--park:#22372c;
    --shield-red:#b8443a;--shield-teal:#2f9e8d;
    --card:rgba(24,30,40,.74);--card-bd:rgba(255,255,255,.1);--ink:#eef1f4;--ink-soft:rgba(238,241,244,.6);
    --blue:#2f6bff;--vz-w:436px;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{height:100%;background:#0c0f14;overflow:hidden;
    font-family:"PingFang SC","Microsoft YaHei",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
    -webkit-font-smoothing:antialiased;color:var(--ink)}
  .viewport{position:fixed;inset:0;display:flex;align-items:center;justify-content:center}
  .stage{position:relative;width:1300px;height:812px;overflow:hidden;transform-origin:center center;
    border-radius:18px;box-shadow:0 40px 120px rgba(0,0,0,.6);background:radial-gradient(120% 120% at 70% 30%,var(--bg2),var(--bg1))}
  .map{position:absolute;inset:0}
  /* 起始：地图作壁纸被压暗；识别到导航后激活（压暗层淡出）*/
  .map-scrim{position:absolute;inset:0;z-index:2;pointer-events:none;transition:opacity .8s ease;
    background:radial-gradient(125% 105% at 50% 40%,rgba(8,11,18,.5),rgba(6,9,15,.76))}
  .stage.nav-active .map-scrim{opacity:0}
  /* 桌面家具（起始态）：导航识别后整体淡出（不右推）*/
  .home{transition:opacity .55s ease}
  .stage.nav-active .home{opacity:0;pointer-events:none}
  .mapcard{position:absolute;top:64px;left:40px;width:300px;border-radius:20px;background:rgba(44,52,64,.55);
    backdrop-filter:blur(22px) saturate(1.2);-webkit-backdrop-filter:blur(22px) saturate(1.2);
    box-shadow:0 8px 30px rgba(0,0,0,.34),inset 0 0 0 1px rgba(255,255,255,.14);overflow:hidden;z-index:25;color:#fff}
  .mapcard .mc-top{display:flex;align-items:center;gap:9px;padding:14px 16px}.mapcard .mc-top .t{flex:1;font-size:16px;font-weight:500}
  .mapcard .mc-quick{display:flex;background:rgba(10,14,20,.45)}
  .mapcard .mc-quick div{flex:1;display:flex;align-items:center;justify-content:center;padding:12px 0;opacity:.85}
  .mapcard .mc-quick div+div{box-shadow:inset 1px 0 0 rgba(255,255,255,.08)}
  .weather{position:absolute;top:60px;right:36px;text-align:right;z-index:25}
  .weather .temp{font-size:60px;font-weight:200;line-height:.9;letter-spacing:-1px;color:#fff}
  .weather .temp sup{font-size:20px;font-weight:300;vertical-align:top;margin-left:2px}
  .weather .loc{font-size:15px;color:rgba(238,241,244,.6);margin-top:6px}
  .cards{position:absolute;left:40px;right:40px;bottom:84px;display:flex;gap:16px;z-index:15}
  .card{flex:1;height:96px;border-radius:18px;background:rgba(24,30,40,.6);backdrop-filter:blur(20px) saturate(1.2);-webkit-backdrop-filter:blur(20px) saturate(1.2);
    box-shadow:0 8px 26px rgba(0,0,0,.25),inset 0 0 0 1px rgba(255,255,255,.1);display:flex;align-items:center;gap:13px;padding:0 18px;color:#eef1f4}
  .card .ic{width:42px;height:42px;border-radius:11px;flex:none;display:flex;align-items:center;justify-content:center;font-size:20px;background:rgba(255,255,255,.08);box-shadow:inset 0 0 0 1px rgba(255,255,255,.08)}
  .card .ic.pink{background:linear-gradient(135deg,#ff7a9c,#ff5277)}
  .card .big{font-size:18px;font-weight:600}.card .sub{font-size:12px;color:rgba(238,241,244,.6);margin-top:3px}.card .lnk{color:#7fa8ff;font-weight:600}
  .card .col2{display:flex;gap:18px;width:100%}
  .tyre{display:flex;flex-direction:column;gap:4px;font-size:12px;color:rgba(238,241,244,.6);width:100%}
  .tyre .r{display:flex;justify-content:space-between}.tyre .tcar{align-self:center;width:26px;height:14px;border-radius:5px;background:rgba(255,255,255,.16);margin:1px 0}
  .map svg{position:absolute;inset:0;width:100%;height:100%}

  /* 状态栏（深底浅色）*/
  .statusbar{position:absolute;top:0;left:0;right:0;height:50px;display:flex;align-items:center;justify-content:space-between;padding:0 24px;z-index:55}
  .sb-left{display:flex;align-items:center;gap:13px;flex:1;min-width:0;height:100%;padding-right:24px}
  .avatar{width:36px;height:36px;border-radius:50%;flex:none;position:relative;background-image:linear-gradient(135deg,#f3c9b0,#cf9d86);box-shadow:inset 0 0 0 1.5px rgba(255,255,255,.4);transition:box-shadow .5s}
  .avatar::before{content:"";position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);filter:blur(1px);opacity:0;transition:opacity .55s;animation:spin 5s linear infinite}
  .avatar::after{content:"";position:absolute;inset:7px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.6));box-shadow:0 0 14px rgba(255,255,255,.55);opacity:0;transition:opacity .55s}
  .avatar.awake{box-shadow:none;animation:breathe 3.2s ease-in-out infinite}
  .avatar.awake::before,.avatar.awake::after{opacity:1}
  .sb-voice{position:relative;display:flex;align-items:center;min-width:0;height:100%}
  .sv-asr{display:inline-flex;align-items:center;max-width:600px;overflow:hidden;white-space:nowrap;font-size:15.5px;font-weight:600;color:var(--ink);opacity:0;transition:opacity .35s,transform .4s,filter .4s}
  .sv-asr.show{opacity:1}.sv-asr.done{color:#62e08c}.sv-asr.gone{opacity:0;transform:translateY(-7px);filter:blur(2px)}
  .sv-cur{display:inline-block;width:2px;height:16px;background:#62e08c;margin-left:2px;animation:blink 1s step-end infinite}
  .sv-reply{font-size:15.5px;font-weight:600;color:#fff;white-space:nowrap;opacity:0;transform:translateY(4px);transition:opacity .45s,transform .45s;text-shadow:0 1px 10px rgba(0,0,0,.4)}
  .sv-reply.show{opacity:1;transform:none}
  .sb-right{display:flex;align-items:center;gap:16px;color:#dfe3e8;flex:none}
  @keyframes blink{50%{opacity:0}}
  .sb-clock{font-size:19px;font-weight:500;letter-spacing:.5px}.sb-5g{font-size:10px;font-weight:700;vertical-align:top;margin-right:1px}

  /* 地图扎点 */
  .pin{position:absolute;z-index:20;transform:translate(-50%,-100%);opacity:0;pointer-events:none}
  .pin.show{animation:drop .6s cubic-bezier(.2,1.1,.35,1) forwards}
  @keyframes drop{0%{opacity:0;transform:translate(-50%,-150%) scale(.6)}60%{opacity:1;transform:translate(-50%,-94%) scale(1.05)}100%{opacity:1;transform:translate(-50%,-100%) scale(1)}}
  .pin .body{position:relative;width:36px;height:36px;border-radius:50% 50% 50% 0;transform:rotate(-45deg);
    background:linear-gradient(135deg,#3ee07a,#23b85e);box-shadow:0 6px 16px rgba(0,0,0,.5),0 0 0 2px rgba(255,255,255,.18)}
  .pin .body span{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;transform:rotate(45deg);font-size:16px;font-weight:800;color:#0c2a16}
  .pin.start .body{background:linear-gradient(135deg,#56a0ff,#2f6bff)}.pin.start .body span{color:#fff;font-size:13px}
  .pin .label{position:absolute;left:50%;top:-30px;transform:translateX(-50%);white-space:nowrap;
    background:rgba(20,26,34,.9);color:#fff;font-size:12.5px;font-weight:600;padding:4px 10px;border-radius:9px;box-shadow:0 4px 12px rgba(0,0,0,.4)}
  .pin .ripple{position:absolute;left:50%;bottom:-3px;width:14px;height:5px;border-radius:50%;transform:translateX(-50%);
    background:rgba(52,208,110,.5)}
  .pin.show .ripple{animation:rip .6s ease-out .12s both}
  @keyframes rip{0%{transform:translateX(-50%) scale(.3);opacity:.8}100%{transform:translateX(-50%) scale(2.6);opacity:0}}
  .pin.start .ripple{background:rgba(86,160,255,.5)}

  /* 路线生长 */
  #route path{fill:none;stroke:var(--route);stroke-width:7;stroke-linecap:round;stroke-linejoin:round;
    filter:drop-shadow(0 0 6px var(--route-glow))}

  /* ── 左侧语音区（无框，深色卡）── */
  .voice-zone{position:absolute;left:40px;top:64px;z-index:36;width:var(--vz-w);display:flex;flex-direction:column;gap:14px}

  /* ① 识别行（单行滚动）*/
  .asr{display:flex;align-items:center;gap:12px;opacity:0;transition:opacity .35s,transform .45s,filter .45s}
  .asr.show{opacity:1}
  .asr.done .asr-text{color:#56e08a;transition:color .35s}
  .asr.gone{opacity:0;transform:translateY(-8px);filter:blur(2px)}
  .aicy{width:42px;height:42px;border-radius:50%;flex:none;position:relative;animation:breathe 3.2s ease-in-out infinite}
  .aicy::before{content:"";position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);filter:blur(1px);animation:spin 5s linear infinite}
  .aicy::after{content:"";position:absolute;inset:8px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.6));box-shadow:0 0 14px rgba(255,255,255,.55)}
  @keyframes spin{to{transform:rotate(360deg)}}@keyframes breathe{0%,100%{transform:scale(1)}50%{transform:scale(1.07)}}
  .asr-box{flex:1;min-width:0;background:var(--card);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
    border-radius:15px;box-shadow:inset 0 0 0 1px var(--card-bd);padding:13px 16px;overflow:hidden;position:relative}
  .asr-scroll{overflow:hidden;white-space:nowrap;width:100%}
  .asr-text{font-size:15.5px;font-weight:500;color:var(--ink);white-space:nowrap}
  .asr-cursor{display:inline-block;width:2px;height:16px;background:#56e08a;margin-left:2px;vertical-align:-3px;animation:blink 1s step-end infinite}
  @keyframes blink{50%{opacity:0}}

  /* ③ 回复 */
  .reply{display:flex;align-items:flex-start;gap:12px;opacity:0;transform:translateY(6px);transition:opacity .5s,transform .5s}
  .reply.show{opacity:1;transform:none}
  .reply-t{font-size:16px;font-weight:600;color:#fff;line-height:1.45;padding-top:9px;text-shadow:0 1px 10px rgba(0,0,0,.5)}

  /* ④ 行程时间线（逐条生长）*/
  .trip{position:relative;margin-left:7px;padding-left:30px}
  .trip-line{position:absolute;left:0;top:14px;width:2px;background:linear-gradient(180deg,#56a0ff,var(--route));
    height:0;transition:height .5s ease}
  .stop{position:relative;opacity:0;transform:translateX(-10px);max-height:130px;transition:opacity .45s,transform .45s,max-height .45s ease,margin .45s ease;margin-bottom:12px}
  .stop.in{opacity:1;transform:none}
  .stop.removing{opacity:0;transform:translateX(-22px);max-height:0;margin-bottom:0;overflow:hidden}
  .stop.removing .row{box-shadow:inset 0 0 0 1px rgba(255,96,96,.6);background:rgba(255,80,80,.14)}
  .pin.removing{animation:pinout .55s ease forwards}
  @keyframes pinout{0%{opacity:1;transform:translate(-50%,-100%) scale(1)}100%{opacity:0;transform:translate(-50%,-100%) scale(.35)}}
  .stop .node{position:absolute;left:-30px;top:14px;width:22px;height:22px;border-radius:50%;
    display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:#0c2a16;
    background:linear-gradient(135deg,#3ee07a,#23b85e);box-shadow:0 0 0 4px rgba(52,208,110,.16)}
  .stop.s0 .node{background:linear-gradient(135deg,#56a0ff,#2f6bff);color:#fff}
  .stop .row{background:var(--card);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
    border-radius:15px;box-shadow:inset 0 0 0 1px var(--card-bd);padding:13px 15px;display:flex;align-items:center;gap:13px}
  .stop .em{width:40px;height:40px;border-radius:11px;flex:none;display:flex;align-items:center;justify-content:center;font-size:20px;
    background:rgba(255,255,255,.08);box-shadow:inset 0 0 0 1px rgba(255,255,255,.08)}
  .stop .name{font-size:16px;font-weight:600;color:var(--ink)}
  .stop .meta{font-size:12.5px;color:var(--ink-soft);margin-top:3px}
  .stop .eta{margin-left:auto;text-align:right;font-size:12px;color:var(--ink-soft);white-space:nowrap}
  .stop .eta b{display:block;font-size:14px;font-weight:700;color:#9fd9b4}
  .tag{display:inline-block;font-size:11px;font-weight:600;color:#9fd9b4;background:rgba(52,208,110,.14);padding:1px 7px;border-radius:6px;margin-left:6px;vertical-align:1px}
  .s0 .tag{color:#9fc2ff;background:rgba(86,160,255,.16)}

  /* ⑤ 开始导航 */
  .go{display:flex;align-items:center;gap:14px;margin-top:4px;opacity:0;transform:translateY(8px);transition:opacity .5s,transform .5s}
  .go.show{opacity:1;transform:none}
  .go-sum{font-size:12.5px;color:var(--ink-soft);line-height:1.5}.go-sum b{color:var(--ink);font-size:14px}
  .go-btn{margin-left:auto;border:0;cursor:pointer;font-family:inherit;font-weight:700;font-size:16px;color:#06140b;
    padding:14px 26px;border-radius:15px;background:linear-gradient(135deg,#46e985,#2ec96a);
    box-shadow:0 8px 24px rgba(46,201,106,.5);display:flex;align-items:center;gap:9px;animation:pulse 2s ease-in-out infinite}
  @keyframes pulse{0%,100%{box-shadow:0 8px 24px rgba(46,201,106,.45)}50%{box-shadow:0 8px 34px rgba(46,201,106,.75)}}

  /* Dock（深色）*/
  .dock{position:absolute;left:0;right:0;bottom:0;height:70px;z-index:30;display:flex;align-items:center;gap:18px;padding:0 22px;
    background:rgba(14,18,26,.62);backdrop-filter:blur(26px) saturate(1.2);-webkit-backdrop-filter:blur(26px) saturate(1.2);
    box-shadow:inset 0 1px 0 rgba(255,255,255,.08)}
  .dock .home{width:34px;height:34px;border-radius:50%;box-shadow:inset 0 0 0 2px rgba(255,255,255,.5);flex:none}
  .np{display:flex;align-items:center;gap:11px;width:230px}.np .cov{width:40px;height:40px;border-radius:9px;flex:none;background:linear-gradient(135deg,#ffb37a,#ff7eb0,#9b8cff)}
  .np .ti{font-size:14px;font-weight:600;line-height:1.25}.np .ar{font-size:11px;color:var(--ink-soft)}.np .pause{margin-left:auto;font-size:16px;color:var(--ink-soft)}
  .dock .sep{flex:1}.dock .ctrl{display:flex;align-items:center;gap:24px;color:rgba(238,241,244,.75)}
  .dock .ctrl .temp{display:flex;align-items:center;gap:9px;font-size:21px;font-weight:600;color:var(--ink)}
  .dock .ctrl .temp small{font-size:12px;color:var(--ink-soft)}.dock .ctrl .chev{font-size:13px;color:rgba(238,241,244,.4)}.dock .ctrl .it{font-size:19px}

  /* 面板 */
  .panel{position:fixed;top:18px;right:18px;width:236px;z-index:100;background:rgba(20,22,26,.9);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
    border-radius:16px;padding:15px;color:#e8eaee;font-size:12.5px;box-shadow:0 20px 50px rgba(0,0,0,.5),inset 0 0 0 1px rgba(255,255,255,.08)}
  .panel .title{font-size:13.5px;font-weight:700;color:#fff;display:flex;align-items:center;gap:7px;margin-bottom:12px}
  .panel .title i{width:8px;height:8px;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#ff6b9b,#ffab5b,#5b8cff)}
  .ask{width:100%;border:0;border-radius:12px;cursor:pointer;font-family:inherit;font-weight:600;font-size:13.5px;padding:13px;color:#fff;
    background:linear-gradient(135deg,#3b78ff,#2f6bff);box-shadow:0 6px 18px rgba(47,107,255,.45);transition:.15s;display:flex;align-items:center;justify-content:center;gap:8px}
  .ask:hover{filter:brightness(1.08)}.ask:active{transform:translateY(1px)}
  .panel .phase{margin-top:12px;font-size:11px;color:#8b9098;border-top:1px solid rgba(255,255,255,.08);padding-top:10px}.panel .phase b{color:#ffce8a}

  /* ── 相机 + 导航态 ── */
  .world{position:absolute;inset:0;transform-origin:0 0;will-change:transform}
  #traveled{fill:none;pointer-events:none}
  .voice-zone{transition:opacity .4s}
  .car{position:absolute;z-index:26;transform:translate(-50%,-50%);display:none;pointer-events:none}
  .car .sonar{position:absolute;left:50%;top:50%;width:30px;height:30px;margin:-15px 0 0 -15px;border-radius:50%;
    border:2px solid rgba(47,107,255,.55);animation:sonar 1.8s ease-out infinite}
  @keyframes sonar{0%{transform:scale(.6);opacity:.7}100%{transform:scale(2.8);opacity:0}}
  .car .puck{width:30px;height:30px;border-radius:50%;background:radial-gradient(circle at 40% 34%,#9cc6ff,#2f6bff 72%);
    box-shadow:0 0 0 6px rgba(47,107,255,.22),0 6px 14px rgba(0,0,0,.55),inset 0 0 0 2px rgba(255,255,255,.55);
    display:flex;align-items:center;justify-content:center}
  .car .puck::before{content:"";width:0;height:0;border-left:6px solid transparent;border-right:6px solid transparent;border-bottom:12px solid #fff;transform:translateY(-1px)}
  .navcard{position:absolute;top:64px;left:40px;width:432px;z-index:40;color:#eef1f4;
    background:rgba(16,22,30,.82);backdrop-filter:blur(22px) saturate(1.2);-webkit-backdrop-filter:blur(22px) saturate(1.2);
    border-radius:20px;box-shadow:0 18px 50px rgba(0,0,0,.5),inset 0 0 0 1px rgba(255,255,255,.1);padding:18px 20px;
    opacity:0;transform:translateY(-8px);transition:opacity .45s,transform .45s;pointer-events:none}
  .navcard.show{opacity:1;transform:none}
  .navcard .man{display:flex;align-items:center;gap:16px}
  .navcard .arrow{font-size:42px;font-weight:300;color:#3ee07a;line-height:1;width:46px;text-align:center}
  .navcard .dist{font-size:15px;color:var(--ink-soft)}
  .navcard .dist b{font-size:38px;font-weight:300;color:#fff;letter-spacing:-1px;margin-right:4px}
  .navcard .road{font-size:16px;font-weight:600;margin-top:2px}
  .navcard .sum{display:flex;flex-wrap:wrap;gap:6px;margin-top:14px;padding-top:13px;border-top:1px solid rgba(255,255,255,.12);font-size:13.5px;color:var(--ink-soft)}
  .navcard .sum b{color:#9fd9b4;font-weight:700}
  .navcard .next{margin-top:10px;font-size:13px;color:var(--ink-soft)}.navcard .next b{color:#9fc2ff}
  .navexit{position:absolute;top:250px;left:40px;z-index:40;border:0;cursor:pointer;font-family:inherit;font-weight:600;font-size:13px;
    color:#fff;background:rgba(40,46,56,.85);backdrop-filter:blur(12px);padding:11px 18px;border-radius:12px;box-shadow:0 6px 16px rgba(0,0,0,.4);
    opacity:0;transform:translateY(-6px);transition:.4s;pointer-events:none}
  .navexit.show{opacity:1;transform:none;pointer-events:auto}

  /* ── 深度思考 / 任务执行动效 ── */
  .avatar.thinking{animation:think-breathe 1.25s ease-in-out infinite}
  .avatar.thinking::before{animation-duration:1.5s}
  @keyframes think-breathe{0%,100%{box-shadow:0 0 14px 2px rgba(120,140,255,.5)}50%{box-shadow:0 0 24px 7px rgba(150,110,255,.82)}}
  /* 思考胶囊放进语音区顶部（光球下方）；展开时其下内容随之下推 */
  .think{display:none;flex-direction:column;gap:10px;width:100%}
  .think.show{display:flex;animation:thinkin .42s ease}
  @keyframes thinkin{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:none}}
  .think-pill{display:flex;align-items:center;gap:13px;padding:11px 15px;cursor:pointer;
    background:rgba(18,24,34,.85);backdrop-filter:blur(22px);-webkit-backdrop-filter:blur(22px);border-radius:20px;
    box-shadow:0 12px 34px rgba(0,0,0,.45),inset 0 0 0 1px rgba(125,140,255,.32)}
  .think-pill .spinner{width:22px;height:22px;border-radius:50%;flex:none;
    background:conic-gradient(from 0deg,rgba(125,140,255,0),#7d8cff,#b58cff,rgba(125,140,255,0));
    -webkit-mask:radial-gradient(circle 6.5px at center,transparent 98%,#000);mask:radial-gradient(circle 6.5px at center,transparent 98%,#000);
    animation:spin 1s linear infinite}
  .think-pill .now{flex:1;min-width:0;overflow:hidden}
  .think-pill .l1{font-size:14.5px;font-weight:700;color:#eaecff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .think-pill .l1.roll{animation:roll-up .42s cubic-bezier(.2,.7,.2,1)}
  @keyframes roll-up{0%{transform:translateY(85%);opacity:0}100%{transform:translateY(0);opacity:1}}
  .think-pill .l2{font-size:11.5px;color:rgba(180,188,220,.72);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:2px}
  .think-pill .chev{font-size:13px;color:rgba(180,188,220,.7);transition:transform .3s;flex:none}
  .think.expanded .think-pill .chev{transform:rotate(180deg)}
  .think-panel{max-height:0;opacity:0;overflow:hidden;transition:max-height .42s cubic-bezier(.2,.8,.2,1),opacity .35s;
    background:rgba(16,22,32,.9);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-radius:18px;
    box-shadow:0 18px 50px rgba(0,0,0,.5),inset 0 0 0 1px rgba(125,140,255,.25)}
  .think.expanded .think-panel{max-height:340px;opacity:1}
  .tp-head{display:flex;align-items:center;gap:9px;padding:15px 18px 10px;font-size:14px;font-weight:700;color:#fff}
  .tp-orb{width:16px;height:16px;border-radius:50%;background:conic-gradient(from 0deg,#7d8cff,#b58cff,#ff8cd0,#7d8cff);animation:spin 3s linear infinite}
  .tp-tag{margin-left:auto;font-size:10px;font-weight:700;color:#bda6ff;background:rgba(150,120,255,.18);padding:2px 8px;border-radius:6px}
  .tp-list{padding:2px 18px 16px}
  .tp-row{display:flex;align-items:center;gap:12px;padding:8px 0;font-size:14px;transition:color .3s}
  .tp-row+.tp-row{border-top:1px solid rgba(255,255,255,.05)}
  .tp-row .ic{width:18px;height:18px;border-radius:50%;flex:none;position:relative}
  .tp-row.todo{color:rgba(180,188,220,.5)}
  .tp-row.todo .ic{box-shadow:inset 0 0 0 1.5px rgba(180,188,220,.3)}
  .tp-row.active{color:#fff;font-weight:600}
  .tp-row.active .ic{box-shadow:inset 0 0 0 2px #8c8cff;animation:think-ic 1.2s ease-in-out infinite}
  .tp-row.active .ic::after{content:"";position:absolute;inset:4px;border-radius:50%;background:#9c8cff}
  @keyframes think-ic{0%,100%{box-shadow:inset 0 0 0 2px #8c8cff,0 0 0 0 rgba(140,140,255,.5)}50%{box-shadow:inset 0 0 0 2px #b58cff,0 0 8px 2px rgba(150,120,255,.6)}}
  .tp-row.done{color:rgba(155,172,210,.9)}
  .tp-row.done .ic{background:#34d06a}
  .tp-row.done .ic::after{content:"✓";position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:#06210f}
  /* 演示控制台：默认弱化半透明、略缩小，悬停恢复清晰（不抢演示效果） */
  .panel{opacity:.3;transform:scale(.86);transform-origin:top right;transition:opacity .3s ease,transform .3s ease}
  .panel:hover{opacity:1;transform:scale(1)}

  /* 全局：底栏 MVA 光球（语音区收起时的最小化态 · 点击唤起；区域展开时淡出）*/
  .mva-orb{width:38px;height:38px;border-radius:50%;flex:none;border:0;padding:0;cursor:pointer;position:relative;background:radial-gradient(circle at 38% 34%,#2a3340,#11161f);transition:transform .15s,opacity .35s}
  .mva-orb::before{content:"";position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);filter:blur(.6px);animation:mvaspin 6s linear infinite}
  .mva-orb::after{content:"";position:absolute;inset:7px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.62));box-shadow:0 0 11px rgba(255,255,255,.5)}
  .mva-orb:hover{transform:scale(1.06)}.mva-orb:active{transform:scale(.93)}
  .stage.voice-on .mva-orb{opacity:.4}
  .mva-orb.busy{opacity:.26 !important;pointer-events:none;filter:saturate(.55)}
  .stage.zone-hidden .voice-zone{opacity:0 !important;transform:translateY(-10px) scale(.985) !important;pointer-events:none !important;transition:opacity .35s ease,transform .35s ease}
  .stage.zone-hidden .map{transform:none !important}
  @keyframes mvaspin{to{transform:rotate(360deg)}}
</style>
</head>
<body>
<div class="viewport">
  <div class="stage" id="stage">
    <!-- ── 真实深色地图底图（参考 奔驰 / 高德车机版夜间）── -->
    <div class="map"><div class="world" id="world">
      <svg viewBox="0 0 1300 812" preserveAspectRatio="xMidYMid slice">
        <defs>
          <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color="#1c2533"/><stop offset="1" stop-color="#151b25"/>
          </linearGradient>
        </defs>
        <rect width="1300" height="812" fill="url(#bg)"/>
        <!-- 水域 -->
        <path d="M-20 612 C 120 588 210 640 250 720 C 270 766 250 812 250 812 L -20 812 Z" fill="#1d3144"/>
        <path d="M 470 -20 C 520 90 470 160 540 250 C 600 330 560 420 640 470" fill="none" stroke="#1d3144" stroke-width="26" stroke-linecap="round" opacity=".9"/>
        <!-- 公园绿地 -->
        <path d="M 1010 70 C 1110 60 1190 110 1180 200 C 1172 280 1080 300 1020 250 C 970 210 950 110 1010 70 Z" fill="#21362b"/>
        <!-- 道路 casing -->
        <g stroke="#222b39" stroke-width="15" fill="none" stroke-linecap="round">
          <path d="M-20 590 C 230 560 440 540 640 548 C 900 558 1080 520 1330 452"/>
          <path d="M 300 -20 C 350 200 400 410 540 560 C 660 690 740 760 800 840"/>
          <path d="M 1330 150 C 1150 210 1050 330 1010 470 C 980 640 1010 760 1030 840"/>
          <path d="M-20 230 C 220 250 430 250 640 300 C 900 360 1040 340 1330 300"/>
        </g>
        <!-- 道路 core -->
        <g stroke="#4b5566" stroke-width="9" fill="none" stroke-linecap="round">
          <path d="M-20 590 C 230 560 440 540 640 548 C 900 558 1080 520 1330 452"/>
          <path d="M 300 -20 C 350 200 400 410 540 560 C 660 690 740 760 800 840"/>
          <path d="M 1330 150 C 1150 210 1050 330 1010 470 C 980 640 1010 760 1030 840"/>
          <path d="M-20 230 C 220 250 430 250 640 300 C 900 360 1040 340 1330 300"/>
        </g>
        <!-- 次干道 -->
        <g stroke="#3c4552" stroke-width="4.8" fill="none" stroke-linecap="round">
          <path d="M 360 90 C 420 230 480 360 560 470"/>
          <path d="M 700 300 C 760 380 820 430 920 450"/>
          <path d="M 640 548 C 700 620 740 700 720 812"/>
          <path d="M 1010 470 C 900 500 800 520 700 560"/>
          <path d="M 200 400 C 320 420 440 440 540 470"/>
          <path d="M 880 110 C 900 200 920 300 945 360"/>
        </g>
        <!-- 支路/街区，填充空白 -->
        <g stroke="#3a4350" stroke-width="3.4" fill="none" stroke-linecap="round">
          <path d="M 380 560 C 520 600 680 636 840 658 C 1000 680 1150 694 1330 686"/>
          <path d="M 520 470 C 540 600 552 700 560 812"/>
          <path d="M 760 560 C 778 660 792 740 800 812"/>
          <path d="M 900 520 C 944 620 972 712 982 812"/>
          <path d="M 240 650 C 440 660 640 682 860 704"/>
          <path d="M 1090 540 C 1118 640 1136 740 1150 812"/>
          <path d="M 640 548 C 600 656 566 742 542 812"/>
          <path d="M 700 300 C 640 360 580 392 520 470"/>
          <path d="M 980 470 C 1060 510 1140 540 1330 560"/>
        </g>
        <!-- 河流名 -->
        <text x="560" y="360" fill="#5d7e98" font-size="14" font-style="italic" transform="rotate(58 560 360)">东茗溪</text>
        <!-- 乡镇/路名 -->
        <g fill="#9aa3b0" font-size="15">
          <text x="430" y="470">莫干山镇</text>
          <text x="800" y="210">埭溪镇</text>
          <text x="1110" y="150">东林镇</text>
        </g>
        <g fill="#7c8694" font-size="13">
          <text x="250" y="320">浦东南路</text>
          <text x="640" y="630">世纪大道</text>
          <text x="1040" y="560">滨江东路</text>
        </g>
        <!-- 高速盾牌 -->
        <g font-size="12" font-weight="700" text-anchor="middle">
          <rect x="688" y="392" width="42" height="20" rx="5" fill="#b8443a"/><text x="709" y="406" fill="#fff">G104</text>
          <rect x="500" y="500" width="42" height="20" rx="5" fill="#2f9e8d"/><text x="521" y="514" fill="#fff">S43</text>
        </g>
        <!-- 路线层（生长）-->
        <g id="route"></g>
        <!-- 已行驶路段（导航态，覆盖在绿线上转灰）-->
        <path id="traveled"></path>
      </svg>
    </div></div>
    <div class="map-scrim"></div>

    <!-- 起始桌面家具：导航识别后整体淡出 -->
    <div class="home">
      <div class="mapcard">
        <div class="mc-top"><span>📍</span><span class="t">地图</span>
          <svg width="18" height="18" viewBox="0 0 18 18"><circle cx="7.5" cy="7.5" r="5.5" fill="none" stroke="#fff" stroke-width="1.6"/><path d="M12 12l4 4" stroke="#fff" stroke-width="1.6" stroke-linecap="round"/></svg></div>
        <div class="mc-quick"><div>⌂</div><div>☰</div><div>★</div><div>⚡</div></div>
      </div>
      <div class="weather"><div class="temp">18<sup>°C</sup></div><div class="loc">上海市　晴</div></div>
      
    </div>

    <div class="statusbar">
      <div class="sb-left">
        <div class="avatar" id="avatar"></div>
        <div class="sb-voice">
          <span class="sv-asr" id="svAsr"><span id="asrText"></span><span class="sv-cur" id="asrCur"></span></span>
          <span class="sv-reply" id="replyT"></span>
        </div>
      </div>
      <div class="sb-right">
        <svg width="15" height="18" viewBox="0 0 15 18"><path d="M3 5l9 8-4.5 4V1L12 5 3 13" fill="none" stroke="#dfe3e8" stroke-width="1.6" stroke-linejoin="round"/></svg>
        <span><sup class="sb-5g">5G</sup>
          <svg width="22" height="16" viewBox="0 0 22 16" style="vertical-align:middle">
            <rect x="0" y="11" width="3.4" height="5" rx="1" fill="#dfe3e8"/><rect x="5.2" y="8" width="3.4" height="8" rx="1" fill="#dfe3e8"/>
            <rect x="10.4" y="5" width="3.4" height="11" rx="1" fill="#dfe3e8"/><rect x="15.6" y="2" width="3.4" height="14" rx="1" fill="#dfe3e8"/></svg></span>
        <span class="sb-clock">13:12</span>
      </div>
    </div>

    <!-- 扎点容器（与 stage 同坐标）-->
    <div id="pins"></div>
    <!-- 车标（导航态）-->
    <div class="car" id="car"><div class="sonar"></div><div class="puck" id="carInner"></div></div>
    <!-- 转向卡（导航态）-->
    <div class="navcard" id="navcard">
      <div class="man"><div class="arrow" id="navArrow">↑</div>
        <div><div class="dist"><b id="navDist">320</b>米</div><div class="road" id="navRoad">沿世纪大道直行</div></div></div>
      <div class="sum">全程 18.6 公里 · 剩余 <b id="navRemain">18.6 公里</b> · 约 <b id="navEta">52 分钟</b> · <span id="navArr">14:04</span> 到达</div>
      <div class="next" id="navNext">下一站　<b>① 华润万家</b></div>
    </div>
    <button class="navexit" id="navexit">结束导航</button>

    <!-- ── 左侧语音区 ── -->
    <div class="voice-zone" id="vz">
      <!-- 深度思考：胶囊状态条 + 可展开步骤清单（在语音区顶部、光球下方）-->
      <div class="think" id="think">
        <div class="think-pill" id="thinkPill">
          <div class="spinner"></div>
          <div class="now"><div class="l1" id="thinkNow">理解多目的地指令</div><div class="l2" id="thinkNext">下一步 · …</div></div>
          <div class="chev">⌃</div>
        </div>
        <div class="think-panel">
          <div class="tp-head"><span class="tp-orb"></span>MVA 思考过程<span class="tp-tag">深度思考</span></div>
          <div class="tp-list" id="tpList"></div>
        </div>
      </div>
      <div class="trip" id="trip"><div class="trip-line" id="tripLine"></div></div>
      <div class="go" id="go">
        <div class="go-sum">为你规划 <b>4 个目的地</b><br>全程 18.6 公里 · 约 52 分钟</div>
        <button class="go-btn" id="goBtn">▶ 开始导航</button>
      </div>
    </div>

    <div class="dock">
      <button class="mva-orb" id="mvaOrb" title="MVA · 唤起语音区"></button>
      <div class="np"><div class="cov"></div><div><div class="ti">Infinite Passion</div><div class="ar">Suker Wong</div></div><div class="pause">❙❙</div></div>
      <div class="sep"></div>
      <div class="ctrl"><div class="it">❄</div><div class="temp"><span class="chev">‹</span>23.5<small>°</small><span class="chev">›</span></div>
        <div class="it">🚘</div><div class="it">⚡</div><div class="it">360</div><div class="it">📞</div><div class="it">▦</div></div>
    </div>
  </div>
</div>

<div class="panel">
  <div class="title"><i></i>深度思考 / 任务执行</div>
  <button class="ask" id="ask">🎤 说出多目的地行程</button>
  <button class="ask" id="askRm" style="margin-top:8px;background:rgba(255,255,255,.08);box-shadow:inset 0 0 0 1px rgba(255,255,255,.12)">🎤 “不去接孩子了”</button>
  <div class="phase">阶段：<b id="phlabel">待机</b></div>
</div>

<script>
const stage=document.getElementById('stage');
function fit(){stage.style.transform=`scale(${Math.min(innerWidth/1300,innerHeight/812)*0.985})`;}
addEventListener('resize',fit);fit();
const $=id=>document.getElementById(id);
const SVGNS='http://www.w3.org/2000/svg';

const SENT='咱们先导航去趟常去的超市，然后顺路去小李那拿个文件，然后去接上孩子，然后导航回家';
// 深度思考步骤
const THINK_STEPS=['理解多目的地出行指令','识别「常去的超市」「小李」位置','获取 4 个目的地坐标','计算最优途经顺序','规划路线与预计耗时','生成行程'];
const STEP_MS=950;
// 当前位置 + 4 个目的地（坐标对应右侧地图，避开左侧语音区）
const PTS=[
  {x:602,y:548,start:true,name:'当前位置'},
  {x:742,y:372,em:'🛒',name:'华润万家',tag:'常去',meta:'江月路店 · 平时常去',eta:'8 分钟',km:'3.1km'},
  {x:946,y:300,em:'📄',name:'小李 · 办公室',tag:'顺路',meta:'取文件 · 预计停留 5 分钟',eta:'15 分钟',km:'5.4km'},
  {x:1086,y:452,em:'🎒',name:'阳光第一小学',tag:'接孩子',meta:'东门接送点',eta:'12 分钟',km:'4.2km'},
  {x:1000,y:642,em:'🏠',name:'家',tag:'回家',meta:'滨江花园 3 号楼',eta:'17 分钟',km:'5.9km'},
];

// 扎点 DOM
const pinsBox=$('pins');
PTS.forEach((p,i)=>{const d=document.createElement('div');d.className='pin'+(p.start?' start':'');d.style.left=p.x+'px';d.style.top=p.y+'px';
  d.innerHTML=`<div class="label">${p.start?'当前位置':p.name}</div><div class="body"><span>${p.start?'起':i}</span></div><div class="ripple"></div>`;
  d.id='pin'+i;pinsBox.appendChild(d);});

// ── 相机系统（世界=地图，可平移缩放；扎点为屏幕覆盖层，恒定大小）──
const world=$('world');
let cam={s:1,tx:0,ty:0},carShown=false,carWorld={x:PTS[0].x,y:PTS[0].y},navRAF=null,order=[0,1,2,3,4];
function applyCam(s,tx,ty,animate){
  cam={s,tx,ty};
  world.style.transition=animate?'transform .85s cubic-bezier(.3,.85,.25,1)':'none';
  world.style.transform=`translate(${tx}px,${ty}px) scale(${s})`;
  PTS.forEach((p,i)=>{const el=$('pin'+i);
    el.style.transition=animate?'left .85s cubic-bezier(.3,.85,.25,1),top .85s cubic-bezier(.3,.85,.25,1)':'none';
    el.style.left=(tx+s*p.x)+'px';el.style.top=(ty+s*p.y)+'px';});
  if(carShown){const c=$('car');c.style.left=(tx+s*carWorld.x)+'px';c.style.top=(ty+s*carWorld.y)+'px';}
}
function fitCam(pts,R,animate,maxS){
  const xs=pts.map(p=>p.x),ys=pts.map(p=>p.y),pad=72;
  const minX=Math.min(...xs)-pad,maxX=Math.max(...xs)+pad,minY=Math.min(...ys)-pad,maxY=Math.max(...ys)+pad;
  const bw=Math.max(maxX-minX,140),bh=Math.max(maxY-minY,140);
  let s=Math.min((R.x1-R.x0)/bw,(R.y1-R.y0)/bh);s=Math.max(.9,Math.min(maxS||1.7,s));
  const cx=(minX+maxX)/2,cy=(minY+maxY)/2;
  applyCam(s,(R.x0+R.x1)/2-s*cx,(R.y0+R.y1)/2-s*cy,animate);
}
const PLAN_R={x0:540,y0:150,x1:1262,y1:724};
applyCam(1,0,0,false);

// 路线段
const routeG=$('route');
function seg(a,b){const mx=(a.x+b.x)/2,my=(a.y+b.y)/2,cx=mx+(b.y-a.y)*.14,cy=my-(b.x-a.x)*.14;
  const p=document.createElementNS('http://www.w3.org/2000/svg','path');p.setAttribute('d',`M${a.x} ${a.y} Q ${cx} ${cy} ${b.x} ${b.y}`);routeG.appendChild(p);
  const L=p.getTotalLength();p.style.strokeDasharray=L;p.style.strokeDashoffset=L;p.style.transition='stroke-dashoffset .7s ease';return p;}

// 行程卡
function stopHTML(p,i){return `<div class="node">${p.start?'起':i}</div>
  <div class="row"><div class="em">${p.start?'📍':p.em}</div>
    <div><div class="name">${p.name}${p.tag?`<span class="tag">${p.tag}</span>`:''}</div><div class="meta">${p.meta||'出发点'}</div></div>
    ${p.km?`<div class="eta"><b>${p.eta}</b>${p.km}</div>`:''}</div>`;}

const timers=[];
function at(ms,fn){timers.push(setTimeout(fn,ms));}
function reset(){
  timers.forEach(clearTimeout);timers.length=0;
  stage.classList.remove('nav-active');   // 起始：桌面家具在、地图压暗
  $('avatar').classList.remove('awake','thinking');
  $('think').classList.remove('show','expanded');$('tpList').innerHTML='';
  $('svAsr').className='sv-asr';$('svAsr').style.display='';$('asrText').textContent='';$('svAsr').scrollLeft=0;$('asrCur').style.display='';
  $('replyT').className='sv-reply';$('replyT').textContent='';
  $('trip').innerHTML='<div class="trip-line" id="tripLine"></div>';
  $('go').className='go';
  routeG.innerHTML='';routeG.style.opacity='';
  order=[0,1,2,3,4];
  PTS.forEach((p,i)=>{const el=$('pin'+i);el.className='pin'+(p.start?' start':'');el.style.display='';const sp=el.querySelector('.body span');if(sp)sp.textContent=p.start?'起':i;});
  $('go').querySelector('.go-sum').innerHTML='为你规划 <b>4 个目的地</b><br>全程 18.6 公里 · 约 52 分钟';
  stopNav(true);                       // 清掉导航态
  $('vz').style.display='';$('vz').style.opacity='1';
  applyCam(1,0,0,false);               // 镜头回到全图
}
function typeASR(text,dur,done){
  const el=$('asrText'),sc=$('svAsr');let i=0;const step=dur/text.length;
  (function tick(){el.textContent=text.slice(0,i);sc.scrollLeft=sc.scrollWidth;
    if(i++<=text.length)timers.push(setTimeout(tick,step));else done&&done();})();
}
// ── 深度思考动效 ──
function startThinking(){
  $('avatar').classList.add('thinking');
  $('think').classList.add('show','expanded');   // 思考时自动展开，露出步骤清单
  $('tpList').innerHTML=THINK_STEPS.map((s,i)=>`<div class="tp-row todo" id="tpr${i}"><span class="ic"></span><span class="tx">${s}</span></div>`).join('');
}
function setThinkStep(i){
  const now=$('thinkNow');now.textContent=THINK_STEPS[i];now.classList.remove('roll');void now.offsetWidth;now.classList.add('roll');
  $('thinkNext').textContent = i<THINK_STEPS.length-1 ? '下一步 · '+THINK_STEPS[i+1] : '即将生成结果';
  THINK_STEPS.forEach((s,k)=>{const r=$('tpr'+k);if(r)r.className='tp-row '+(k<i?'done':k===i?'active':'todo');});
}
function endThinking(){
  $('avatar').classList.remove('thinking');
  THINK_STEPS.forEach((s,k)=>{const r=$('tpr'+k);if(r)r.className='tp-row done';});
  $('thinkNow').textContent='已完成思考 · 规划路线';$('thinkNow').classList.remove('roll');void $('thinkNow').offsetWidth;$('thinkNow').classList.add('roll');
  $('thinkNext').textContent='点开查看思考过程';
  $('think').classList.remove('expanded');   // 收起为胶囊（保留在顶部），下方开始出结果；再点开会把内容下推
}

function play(){
  reset();
  $('phlabel').textContent='聆听 · 识别中';
  $('avatar').classList.add('awake');
  $('svAsr').classList.add('show');
  typeASR(SENT,3000);
  at(3300,()=>{$('phlabel').textContent='识别成功';$('asrCur').style.display='none';$('svAsr').classList.add('done');});
  at(4000,()=>$('svAsr').classList.add('gone'));
  at(4500,()=>{$('svAsr').style.display='none';$('phlabel').textContent='深度思考中';$('replyT').textContent='好的，这就为你规划多目的地的路线';$('replyT').classList.add('show');
    stage.classList.add('nav-active');});  // 识别到导航：地图小组件等桌面家具淡出消失、地图激活
  // ★ 深度思考阶段：光球进入思考态 + 底部胶囊跑马灯（可点开看步骤）★
  const TS=4900;
  at(TS,()=>startThinking());
  THINK_STEPS.forEach((s,i)=>at(TS+i*STEP_MS,()=>{setThinkStep(i);$('phlabel').textContent=`思考 ${i+1}/${THINK_STEPS.length}`;}));
  const P0=TS+THINK_STEPS.length*STEP_MS;   // 思考结束 → 出结果
  at(P0,()=>endThinking());
  // 起点扎点 + 镜头框住当前位置
  const shown=[PTS[0]];
  at(P0+550,()=>{$('phlabel').textContent='规划路线';$('pin0').classList.add('show');fitCam(shown,PLAN_R,true,1.55);});
  // 行程逐条生长 + 同步扎点 + 路线段生长 + 镜头跟随
  const base=P0+1150,gap=1150;
  PTS.forEach((p,i)=>{ if(i===0) return;
    at(base+(i-1)*gap,()=>{
      $('phlabel').textContent=`扎点 ${i}/4`;
      const line=$('tripLine');
      const s=document.createElement('div');s.className='stop s'+i;s.innerHTML=stopHTML(p,i);$('trip').appendChild(s);
      requestAnimationFrame(()=>{s.classList.add('in');line.style.height=($('trip').scrollHeight-28)+'px';});
      $('pin'+i).classList.add('show');
      const sp=seg(PTS[i-1],PTS[i]);requestAnimationFrame(()=>{sp.getBoundingClientRect();sp.style.strokeDashoffset='0';});
      shown.push(PTS[i]);fitCam(shown,PLAN_R,true,1.6);
    });
  });
  at(base+4*gap+500,()=>{$('phlabel').textContent='规划完成 · 可开始导航';$('go').classList.add('show');fitCam(shown,PLAN_R,true,1.5);});
  at(base+4*gap+500+3200,()=>removeWaypoint());   // 规划完成片刻后，自动演示「不去接孩子了」
}
$('thinkPill').onclick=()=>$('think').classList.toggle('expanded');   // 点开/收起步骤清单
$('ask').onclick=play;

// ── 中途改主意：删除「接孩子」途经点并重新规划 ──
function renumber(){for(let k=1;k<order.length;k++){const idx=order[k];
  const sp=$('pin'+idx).querySelector('.body span');if(sp)sp.textContent=k;
  const node=document.querySelector('.stop.s'+idx+' .node');if(node)node.textContent=k;}}
function removeWaypoint(){
  const RM=3;if(order.indexOf(RM)<0)return;                 // 接孩子 = 阳光第一小学（索引3）
  $('replyT').classList.remove('show');
  $('svAsr').style.display='';$('svAsr').className='sv-asr show';$('asrText').textContent='';$('asrCur').style.display='';
  $('phlabel').textContent='聆听 · 识别中';
  typeASR('不去接孩子了',1300);
  at(1550,()=>{$('asrCur').style.display='none';$('svAsr').classList.add('done');});
  at(2000,()=>$('svAsr').classList.add('gone'));
  at(2400,()=>{$('svAsr').style.display='none';$('replyT').textContent='好的，已去掉「接孩子」这一站，正在为你重新规划';$('replyT').classList.add('show');$('phlabel').textContent='删除途经点';});
  at(2700,()=>{const row=document.querySelector('.stop.s'+RM);if(row)row.classList.add('removing');$('pin'+RM).classList.add('removing');});
  at(3350,()=>{const row=document.querySelector('.stop.s'+RM);if(row)row.remove();
    $('pin'+RM).style.display='none';$('tripLine').style.height=($('trip').scrollHeight-28)+'px';
    order=order.filter(i=>i!==RM);renumber();});
  at(3550,()=>{routeG.style.transition='opacity .3s';routeG.style.opacity='0';});
  at(3900,()=>{routeG.innerHTML='';routeG.style.opacity='1';
    for(let k=1;k<order.length;k++){const sp=seg(PTS[order[k-1]],PTS[order[k]]);requestAnimationFrame(()=>{sp.getBoundingClientRect();sp.style.strokeDashoffset='0';});}
    fitCam(order.map(i=>PTS[i]),PLAN_R,true,1.5);
    $('go').querySelector('.go-sum').innerHTML='为你规划 <b>3 个目的地</b><br>全程 14.8 公里 · 约 41 分钟';
    $('phlabel').textContent='已重新规划 · 3 个目的地';});
}
$('askRm').onclick=removeWaypoint;

// ── ② 转向导航态 ──
function buildFullD(){let d=`M ${PTS[0].x} ${PTS[0].y}`;
  for(let i=1;i<PTS.length;i++){const a=PTS[i-1],b=PTS[i],mx=(a.x+b.x)/2,my=(a.y+b.y)/2,cx=mx+(b.y-a.y)*.14,cy=my-(b.x-a.x)*.14;
    d+=` Q ${cx} ${cy} ${b.x} ${b.y}`;}return d;}
const NAV_R={x0:150,y0:160,x1:1240,y1:736},NAV_S=1.55,NAV_DUR=17000;
const STOPS=['① 华润万家','② 小李·办公室','③ 阳光第一小学','④ 家'];
function startNav(){
  $('phlabel').textContent='导航中';
  $('navArrow').textContent='↑';$('navRoad').textContent='沿世纪大道直行';
  $('replyT').classList.remove('show');                 // 收起顶栏规划回复
  $('vz').style.opacity='0';setTimeout(()=>{$('vz').style.display='none';},420);
  $('navcard').classList.add('show');$('navexit').classList.add('show');
  const tr=$('traveled');tr.setAttribute('d',buildFullD());
  tr.style.stroke='#5a6474';tr.style.strokeWidth='7';tr.style.strokeLinecap='round';tr.style.strokeLinejoin='round';
  const L=tr.getTotalLength();tr.style.strokeDasharray='0 '+L;
  carShown=true;$('car').style.display='';
  const ncx=(NAV_R.x0+NAV_R.x1)/2,ncy=(NAV_R.y0+NAV_R.y1)/2,t0=performance.now();
  (function tick(now){
    const p=Math.min(1,(now-t0)/NAV_DUR),len=p*L,pt=tr.getPointAtLength(len),ah=tr.getPointAtLength(Math.min(L,len+3));
    carWorld={x:pt.x,y:pt.y};
    $('carInner').style.transform=`rotate(${Math.atan2(ah.y-pt.y,ah.x-pt.x)*180/Math.PI+90}deg)`;
    tr.style.strokeDasharray=len+' '+L;
    applyCam(NAV_S,ncx-NAV_S*pt.x,ncy-NAV_S*pt.y,false);
    $('navRemain').textContent=((1-p)*18.6).toFixed(1)+' 公里';
    $('navEta').textContent=Math.round((1-p)*52)+' 分钟';
    $('navDist').textContent=Math.max(20,Math.round((1-((p*4)%1))*420));
    $('navNext').innerHTML='下一站　<b>'+STOPS[Math.min(3,Math.floor(p*4+1e-4))]+'</b>';
    if(p<1)navRAF=requestAnimationFrame(tick);
    else{$('navDist').textContent='0';$('navArrow').textContent='◎';$('navRoad').textContent='已到达终点 · 家';$('navNext').innerHTML='全部目的地已完成 🎉';}
  })(t0);
}
function stopNav(silent){
  if(navRAF){cancelAnimationFrame(navRAF);navRAF=null;}
  carShown=false;$('car').style.display='none';
  $('traveled').setAttribute('d','');$('traveled').style.strokeDasharray='';
  $('navcard').classList.remove('show');$('navexit').classList.remove('show');
  $('navArrow').textContent='↑';$('navRoad').textContent='沿世纪大道直行';
  if(silent)return;
  $('vz').style.display='';requestAnimationFrame(()=>$('vz').style.opacity='1');
  $('replyT').classList.add('show');                    // 恢复顶栏规划回复
  $('phlabel').textContent='规划完成 · 可开始导航';
  fitCam(PTS,PLAN_R,true,1.5);
}
$('goBtn').onclick=startNav;
$('navexit').onclick=()=>stopNav(false);

setTimeout(play,600);
</script>

<script>
(function(){
  var orb=document.getElementById('mvaOrb');if(!orb)return;
  var stage=document.querySelector('.stage');
  var watch=[document.querySelector('.voice-zone'),document.querySelector('.statusbar')].filter(Boolean);
  var busy=true,settleT=null;
  function en(on){orb.classList.toggle('busy',!on);}
  function settle(){busy=false;en(true);}
  function bump(){busy=true;en(false);clearTimeout(settleT);settleT=setTimeout(settle,1200);}
  try{var obs=new MutationObserver(bump);watch.forEach(function(n){obs.observe(n,{childList:true,subtree:true,characterData:true,attributes:true,attributeFilter:['class','style']});});}catch(e){}
  bump();
  orb.onclick=function(){if(busy)return;stage.classList.toggle('zone-hidden');};
})();
</script>
</body>
</html>
