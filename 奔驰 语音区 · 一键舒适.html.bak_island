<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>奔驰 · 语音区 · 一键舒适（复杂推理 + 多动作执行）</title>
<!--
  场景：用户「有点累，把座舱调舒适些，歇会儿」
  → 复杂推理（检测环境/车况 + 调用用户偏好[记忆]）→ 依次执行：
    氛围灯=暖色涟漪光波（无组件）/ 车窗·空调·循环·按摩=车控执行弹窗 / 音乐=一束光从 avatar 飞到底部播放器点亮它
-->
<style>
  @property --amb{syntax:'<color>';inherits:true;initial-value:#ffb060}
  :root{
    --card:rgba(22,28,38,.66);--card-bd:rgba(255,255,255,.1);
    --ink:#eef1f4;--ink-soft:rgba(238,241,244,.58);--ink-faint:rgba(238,241,244,.38);
    --blue:#3b78ff;--green:#34d06a;--vz-w:392px;--amb:#ffb060;--amb-int:.85;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{height:100%;background:#05070b;overflow:hidden;font-family:"PingFang SC","Microsoft YaHei",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;-webkit-font-smoothing:antialiased;color:var(--ink)}
  .viewport{position:fixed;inset:0;display:flex;align-items:center;justify-content:center}
  .stage{position:relative;width:1300px;height:812px;overflow:hidden;transform-origin:center center;border-radius:18px;
    box-shadow:0 40px 120px rgba(0,0,0,.65);background:radial-gradient(135% 115% at 50% 8%,#141c2a 0%,#0e1420 46%,#080b12 100%)}
  .mapbg{position:absolute;inset:0;z-index:0}.mapbg svg{position:absolute;inset:0;width:100%;height:100%}
  .mapbg-scrim{position:absolute;inset:0;background:radial-gradient(125% 105% at 50% 40%,rgba(8,11,18,.5),rgba(6,9,15,.78))}

  /* 状态栏：头像→MVA 光球 + 顶栏识别/回复 */
  .statusbar{position:absolute;top:0;left:0;right:0;height:50px;display:flex;align-items:center;justify-content:space-between;padding:0 24px;z-index:55}
  .sb-left{display:flex;align-items:center;gap:13px;flex:1;min-width:0;height:100%;padding-right:24px}
  .avatar{width:36px;height:36px;border-radius:50%;flex:none;position:relative;background-image:linear-gradient(135deg,#f3c9b0,#cf9d86);box-shadow:inset 0 0 0 1.5px rgba(255,255,255,.4);transition:box-shadow .5s}
  .avatar::before{content:"";position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);filter:blur(1px);opacity:0;transition:opacity .55s;animation:spin 5s linear infinite}
  .avatar::after{content:"";position:absolute;inset:7px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.6));box-shadow:0 0 14px rgba(255,255,255,.55);opacity:0;transition:opacity .55s}
  .avatar.awake{box-shadow:none;animation:breathe 3.2s ease-in-out infinite}
  .avatar.awake::before,.avatar.awake::after{opacity:1}
  @keyframes spin{to{transform:rotate(360deg)}}@keyframes breathe{0%,100%{transform:scale(1)}50%{transform:scale(1.07)}}
  .sb-voice{position:relative;display:flex;align-items:center;min-width:0;height:100%}
  .sv-asr{display:inline-flex;align-items:center;max-width:640px;overflow:hidden;white-space:nowrap;font-size:15.5px;font-weight:600;color:var(--ink);opacity:0;transition:opacity .35s,transform .4s,filter .4s}
  .sv-asr.show{opacity:1}.sv-asr.done{color:#62e08c}.sv-asr.gone{opacity:0;transform:translateY(-7px);filter:blur(2px)}
  .sv-cur{display:inline-block;width:2px;height:16px;background:#62e08c;margin-left:2px;animation:blink 1s step-end infinite}
  @keyframes blink{50%{opacity:0}}
  .sv-reply{font-size:15.5px;font-weight:600;color:#fff;white-space:nowrap;opacity:0;transform:translateY(4px);transition:opacity .45s,transform .45s;text-shadow:0 1px 12px rgba(0,0,0,.5)}
  .sv-reply.show{opacity:1;transform:none}
  .sb-right{display:flex;align-items:center;gap:16px;color:#dfe3e8;flex:none}
  .sb-clock{font-size:19px;font-weight:500;letter-spacing:.5px}.sb-5g{font-size:10px;font-weight:700;vertical-align:top;margin-right:1px}

  /* 桌面家具（起始）*/
  .map{position:absolute;top:64px;left:40px;width:300px;border-radius:20px;background:rgba(44,52,64,.5);backdrop-filter:blur(22px) saturate(1.2);-webkit-backdrop-filter:blur(22px) saturate(1.2);box-shadow:0 8px 30px rgba(0,0,0,.3),inset 0 0 0 1px rgba(255,255,255,.12);overflow:hidden;z-index:25;color:#fff;
    transition:transform .42s cubic-bezier(.2,.7,.2,1)}
  .stage.voice-on .map{transform:translateX(calc(var(--vz-w) + 16px))}  /* 内容出现→地图卡推右 */
  /* 执行清单：语音区里逐条「规划/执行」生长 */
  .acts{position:relative;margin-left:7px;padding-left:30px}
  .acts-line{position:absolute;left:0;top:14px;width:2px;background:linear-gradient(180deg,#ffb060,#34d06a);height:0;transition:height .5s ease}
  .act{position:relative;opacity:0;transform:translateX(-10px);transition:opacity .45s,transform .45s;margin-bottom:10px}
  .act.in{opacity:1;transform:none}
  .act .node{position:absolute;left:-30px;top:15px;width:20px;height:20px;border-radius:50%;background:rgba(255,255,255,.14);box-shadow:0 0 0 4px rgba(255,176,96,.1)}
  .act.amb .node{background:linear-gradient(135deg,#ffd58a,#ff9d3c)}.act.music .node{background:linear-gradient(135deg,#8fb6ff,#3b78ff)}
  .act .row{background:var(--card);backdrop-filter:blur(20px) saturate(1.2);-webkit-backdrop-filter:blur(20px) saturate(1.2);border-radius:14px;box-shadow:inset 0 0 0 1px var(--card-bd);display:flex;align-items:center;gap:12px;padding:10px 14px}
  .act .aem{width:38px;height:38px;border-radius:11px;flex:none;display:flex;align-items:center;justify-content:center;font-size:19px;background:rgba(255,255,255,.08);box-shadow:inset 0 0 0 1px rgba(255,255,255,.08)}
  .act .atitle{font-size:15px;font-weight:600;color:var(--ink)}.act .asub{font-size:12px;color:var(--ink-soft);margin-top:2px}
  .act .ack{margin-left:auto;color:var(--green);font-size:17px;font-weight:800;opacity:0;transition:opacity .3s}.act.done .ack{opacity:1}

  /* 快速调整小组件：每条动作落地后展开 */
  .qa{max-height:0;opacity:0;overflow:hidden;margin-left:50px;transition:max-height .42s cubic-bezier(.2,.8,.2,1),opacity .32s,margin-top .3s}
  .act.tuned .qa{max-height:90px;opacity:1;margin-top:7px}
  .qa-in{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:12px;background:rgba(14,19,28,.72);box-shadow:inset 0 0 0 1px rgba(255,255,255,.07)}
  .qa-in .lab{font-size:11px;color:var(--ink-faint);flex:none}
  /* −/+ 步进 */
  .qa-step{display:flex;align-items:center;gap:11px}
  .qa-btn{width:26px;height:26px;border-radius:8px;flex:none;display:flex;align-items:center;justify-content:center;font-size:17px;font-weight:700;color:var(--ink);cursor:pointer;background:rgba(255,255,255,.08);box-shadow:inset 0 0 0 1px rgba(255,255,255,.1);user-select:none;transition:background .15s,transform .1s}
  .qa-btn:hover{background:rgba(255,255,255,.16)}.qa-btn:active{transform:scale(.9)}
  .qa-val{font-size:15px;font-weight:700;color:#fff;min-width:54px;text-align:center;font-variant-numeric:tabular-nums}.qa-val small{font-size:11px;color:var(--ink-soft);font-weight:600;margin-left:1px}
  /* 档位切换 */
  .qa-seg{display:flex;gap:4px;background:rgba(255,255,255,.05);padding:3px;border-radius:9px}
  .qa-seg .sg{padding:5px 13px;font-size:12.5px;font-weight:600;color:var(--ink-soft);cursor:pointer;border-radius:7px;transition:.18s;user-select:none}
  .qa-seg .sg:hover{color:var(--ink)}.qa-seg .sg.on{color:#fff;background:linear-gradient(135deg,rgba(255,176,96,.9),rgba(255,140,70,.8));box-shadow:0 2px 8px rgba(255,140,60,.3)}
  .act.music .qa-seg .sg.on{background:linear-gradient(135deg,#5b8cff,#3b78ff);box-shadow:0 2px 8px rgba(59,120,255,.35)}
  /* 迷你滑条 */
  .qa-slider{flex:1;height:24px;position:relative;cursor:pointer;display:flex;align-items:center;min-width:90px}
  .qa-track{position:relative;width:100%;height:6px;border-radius:4px;background:rgba(255,255,255,.12);overflow:hidden}
  .qa-fill{position:absolute;left:0;top:0;bottom:0;width:30%;border-radius:4px;background:linear-gradient(90deg,#ffb060,#ff9d3c);transition:width .12s}
  .act.win .qa-fill{background:linear-gradient(90deg,#7fa8ff,#3b78ff)}.act.music .qa-fill{background:linear-gradient(90deg,#8fb6ff,#3b78ff)}
  .qa-knob{position:absolute;top:50%;width:15px;height:15px;border-radius:50%;background:#fff;box-shadow:0 1px 6px rgba(0,0,0,.5);transform:translate(-50%,-50%);transition:left .12s}
  /* 音乐迷你播放控制 */
  .qa-trans{display:flex;align-items:center;gap:6px}
  .qa-tb{width:28px;height:28px;border-radius:8px;flex:none;display:flex;align-items:center;justify-content:center;font-size:13px;color:var(--ink);cursor:pointer;background:rgba(255,255,255,.08);box-shadow:inset 0 0 0 1px rgba(255,255,255,.1);user-select:none;transition:background .15s,transform .1s}
  .qa-tb:hover{background:rgba(255,255,255,.16)}.qa-tb:active{transform:scale(.9)}
  .qa-tb.play{background:linear-gradient(135deg,#5b8cff,#3b78ff);color:#fff;box-shadow:0 2px 8px rgba(59,120,255,.35)}
  /* 开关切换 */
  .qa-toggle{display:flex;gap:5px}
  .qa-toggle .tg{padding:6px 16px;font-size:12.5px;font-weight:700;color:var(--ink-soft);cursor:pointer;border-radius:8px;background:rgba(255,255,255,.06);transition:.18s;user-select:none}
  .qa-toggle .tg.on{color:#fff;background:linear-gradient(135deg,#7fa8ff,#3b78ff)}
  .qa-toggle .tg.on.off{background:rgba(255,255,255,.16);color:var(--ink-soft)}
  .map-top{display:flex;align-items:center;gap:9px;padding:14px 16px}.map-top .t{flex:1;font-size:16px;font-weight:500}
  .map-quick{display:flex;background:rgba(10,14,20,.4)}.map-quick div{flex:1;display:flex;align-items:center;justify-content:center;padding:12px 0;opacity:.85}.map-quick div+div{box-shadow:inset 1px 0 0 rgba(255,255,255,.08)}
  .weather{position:absolute;top:60px;right:36px;text-align:right;z-index:25}
  .weather .temp{font-size:60px;font-weight:200;line-height:.9;letter-spacing:-1px;color:#fff}.weather .temp sup{font-size:20px;font-weight:300;vertical-align:top;margin-left:2px}.weather .loc{font-size:15px;color:var(--ink-soft);margin-top:6px}
  .cards{position:absolute;left:40px;right:40px;bottom:84px;display:flex;gap:16px;z-index:15}
  .card{flex:1;height:96px;border-radius:18px;background:rgba(24,30,40,.6);backdrop-filter:blur(20px) saturate(1.2);-webkit-backdrop-filter:blur(20px) saturate(1.2);box-shadow:0 8px 26px rgba(0,0,0,.25),inset 0 0 0 1px rgba(255,255,255,.1);display:flex;align-items:center;gap:13px;padding:0 18px;color:#eef1f4}
  .card .ic{width:42px;height:42px;border-radius:11px;flex:none;display:flex;align-items:center;justify-content:center;font-size:20px;background:rgba(255,255,255,.08);box-shadow:inset 0 0 0 1px rgba(255,255,255,.08)}
  .card .ic.pink{background:linear-gradient(135deg,#ff7a9c,#ff5277)}
  .card .big{font-size:18px;font-weight:600}.card .sub{font-size:12px;color:var(--ink-soft);margin-top:3px}.card .lnk{color:#7fa8ff;font-weight:600}
  .card .col2{display:flex;gap:18px;width:100%}
  .tyre{display:flex;flex-direction:column;gap:4px;font-size:12px;color:var(--ink-soft);width:100%}.tyre .r{display:flex;justify-content:space-between}.tyre .tcar{align-self:center;width:26px;height:14px;border-radius:5px;background:rgba(255,255,255,.16);margin:1px 0}

  /* ② 氛围灯：暖色边缘涟漪（无组件）*/
  .amb{position:absolute;inset:0;z-index:41;pointer-events:none;border-radius:18px}
  .amb .edge{position:absolute;inset:0;border-radius:18px;mix-blend-mode:screen;box-shadow:inset 0 0 46px -10px var(--amb);opacity:0;transition:opacity 1.1s ease}
  .stage.amb-on .amb .edge{opacity:calc(.18*var(--amb-int))}
  .amb .wave{position:absolute;inset:0;border-radius:18px;mix-blend-mode:screen;opacity:0;box-shadow:inset 0 0 3px 0 var(--amb)}
  .amb.go .wave{animation:edgegrow 3s cubic-bezier(.22,.62,.2,1) both}
  .amb.go .wave:nth-child(3){animation-delay:.6s}.amb.go .wave:nth-child(4){animation-delay:1.2s}
  @keyframes edgegrow{0%{opacity:0;box-shadow:inset 0 0 3px 0 var(--amb)}16%{opacity:calc(.62*var(--amb-int))}100%{opacity:0;box-shadow:inset 0 0 120px 16px var(--amb)}}

  /* 语音区：推理思考胶囊 */
  .voice-zone{position:absolute;left:40px;top:64px;z-index:50;width:var(--vz-w);display:flex;flex-direction:column;gap:10px}
  .think{display:none;flex-direction:column;gap:10px;width:100%}
  .think.show{display:flex;animation:thinkin .4s ease}
  @keyframes thinkin{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:none}}
  .think-pill{display:flex;align-items:center;gap:13px;padding:11px 15px;cursor:pointer;background:rgba(18,24,34,.85);backdrop-filter:blur(22px);-webkit-backdrop-filter:blur(22px);border-radius:18px;box-shadow:0 12px 34px rgba(0,0,0,.45),inset 0 0 0 1px rgba(125,140,255,.32)}
  .think-pill .spinner{width:22px;height:22px;border-radius:50%;flex:none;background:conic-gradient(from 0deg,rgba(125,140,255,0),#7d8cff,#b58cff,rgba(125,140,255,0));-webkit-mask:radial-gradient(circle 6.5px at center,transparent 98%,#000);mask:radial-gradient(circle 6.5px at center,transparent 98%,#000);animation:spin 1s linear infinite}
  .think-pill .now{flex:1;min-width:0;overflow:hidden}
  .think-pill .l1{font-size:14.5px;font-weight:700;color:#eaecff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .think-pill .l1.roll{animation:roll .42s cubic-bezier(.2,.7,.2,1)}@keyframes roll{0%{transform:translateY(85%);opacity:0}100%{transform:translateY(0);opacity:1}}
  .think-pill .l2{font-size:11.5px;color:rgba(180,188,220,.7);white-space:nowrap;margin-top:2px}
  .think-pill .chev{font-size:13px;color:rgba(180,188,220,.7);transition:transform .3s;flex:none}.think.expanded .think-pill .chev{transform:rotate(180deg)}
  .think-panel{max-height:0;opacity:0;overflow:hidden;transition:max-height .42s cubic-bezier(.2,.8,.2,1),opacity .35s;background:rgba(16,22,32,.9);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-radius:18px;box-shadow:0 18px 50px rgba(0,0,0,.5),inset 0 0 0 1px rgba(125,140,255,.25)}
  .think.expanded .think-panel{max-height:300px;opacity:1}
  .tp-head{display:flex;align-items:center;gap:9px;padding:15px 18px 10px;font-size:14px;font-weight:700;color:#fff}
  .tp-orb{width:16px;height:16px;border-radius:50%;background:conic-gradient(from 0deg,#7d8cff,#b58cff,#ff8cd0,#7d8cff);animation:spin 3s linear infinite}
  .tp-list{padding:2px 18px 16px}
  .tp-row{display:flex;align-items:center;gap:12px;padding:8px 0;font-size:14px;transition:color .3s}
  .tp-row+.tp-row{border-top:1px solid rgba(255,255,255,.05)}
  .tp-row .ic{width:18px;height:18px;border-radius:50%;flex:none;position:relative}
  .tp-row.todo{color:rgba(180,188,220,.5)}.tp-row.todo .ic{box-shadow:inset 0 0 0 1.5px rgba(180,188,220,.3)}
  .tp-row.active{color:#fff;font-weight:600}.tp-row.active .ic{box-shadow:inset 0 0 0 2px #8c8cff}.tp-row.active .ic::after{content:"";position:absolute;inset:4px;border-radius:50%;background:#9c8cff}
  .tp-row.done{color:rgba(155,172,210,.9)}.tp-row.done .ic{background:#34d06a}.tp-row.done .ic::after{content:"✓";position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:#06210f}
  .tp-row.is-mem.active,.tp-row.is-mem.done{color:#d9a24a;font-weight:700}
  .tp-row.is-mem .ic{background:linear-gradient(135deg,#ffd58a,#ff9d3c);box-shadow:0 0 9px rgba(255,170,80,.6)}
  .tp-row.is-mem .ic::after{content:"✦";position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:#5a3a00}
  .tp-row .mem-tag{margin-left:auto;font-size:10px;font-weight:700;color:#e0b063;background:rgba(255,180,90,.2);padding:2px 8px;border-radius:6px}
  .think-pill.mem .l1{color:#e7c074}
  /* avatar 记忆仪式光效 */
  .mem-halo{position:absolute;inset:-10px;border-radius:50%;pointer-events:none;opacity:0;background:radial-gradient(circle,rgba(255,213,138,.6),rgba(255,213,138,0) 66%)}
  .avatar.mem .mem-halo{animation:memglow 1.15s ease-out}
  .mem-halo::before,.mem-halo::after{content:"";position:absolute;inset:8px;border-radius:50%;border:2px solid rgba(255,210,135,.9);opacity:0}
  .avatar.mem .mem-halo::before{animation:memring 1.15s ease-out}.avatar.mem .mem-halo::after{animation:memring 1.15s ease-out .32s}
  @keyframes memglow{0%{opacity:0;transform:scale(.55)}22%{opacity:1}100%{opacity:0;transform:scale(2.3)}}
  @keyframes memring{0%{transform:scale(.7);opacity:.95}100%{transform:scale(2.5);opacity:0}}

  /* ③ 车控执行弹窗（依次弹出）*/
  .toast{position:absolute;left:50%;top:300px;transform:translate(-50%,12px) scale(.96);z-index:52;display:flex;align-items:center;gap:14px;
    background:rgba(20,26,36,.86);backdrop-filter:blur(26px) saturate(1.2);-webkit-backdrop-filter:blur(26px) saturate(1.2);
    border-radius:18px;box-shadow:0 20px 50px rgba(0,0,0,.5),inset 0 0 0 1px rgba(255,255,255,.14);padding:14px 22px 14px 16px;min-width:280px;opacity:0;transition:opacity .35s,transform .35s}
  .toast.in{opacity:1;transform:translate(-50%,0) scale(1)}
  .toast .ic{width:42px;height:42px;border-radius:12px;flex:none;display:flex;align-items:center;justify-content:center;font-size:22px;background:rgba(255,255,255,.1)}
  .toast .t-title{font-size:16px;font-weight:700;color:#fff}.toast .t-sub{font-size:12.5px;color:var(--ink-soft);margin-top:2px}
  .toast .ck{margin-left:auto;color:var(--green);font-size:20px;font-weight:800}

  /* ④ avatar→播放器 光束 */
  .spark{position:absolute;left:50px;top:24px;width:15px;height:15px;border-radius:50%;z-index:60;pointer-events:none;opacity:0;
    background:radial-gradient(circle,#fff,#bfe0ff 45%,rgba(150,200,255,0) 72%);box-shadow:0 0 18px 5px rgba(160,205,255,.85)}
  .spark.go{animation:spark 1s cubic-bezier(.45,0,.55,1) forwards}
  @keyframes spark{0%{opacity:0;transform:translate(0,0) scale(.5)}12%{opacity:1;transform:translate(2px,30px) scale(1)}82%{opacity:1}100%{opacity:0;transform:translate(38px,748px) scale(.7)}}

  /* Dock + 播放器 */
  .dock{position:absolute;left:0;right:0;bottom:0;height:72px;z-index:30;display:flex;align-items:center;gap:18px;padding:0 22px;background:rgba(12,16,24,.6);backdrop-filter:blur(26px) saturate(1.2);-webkit-backdrop-filter:blur(26px) saturate(1.2);box-shadow:inset 0 1px 0 rgba(255,255,255,.08)}
  .dock .home{width:34px;height:34px;border-radius:50%;box-shadow:inset 0 0 0 2px rgba(255,255,255,.5);flex:none}
  .np{display:flex;align-items:center;gap:11px;width:240px;border-radius:14px;padding:5px 8px;margin-left:-6px;transition:box-shadow .5s,background .5s}
  .np.lit{background:rgba(150,200,255,.12);box-shadow:0 0 0 1px rgba(150,200,255,.35),0 0 22px rgba(150,200,255,.3)}
  .np .cov{width:40px;height:40px;border-radius:9px;flex:none;background:linear-gradient(135deg,#ffb37a,#ff7eb0,#9b8cff);transition:background .5s}
  .np .ti{font-size:14px;font-weight:600;line-height:1.25}.np .ar{font-size:11px;color:var(--ink-soft)}
  .np .eq{margin-left:auto;display:inline-flex;gap:2.5px;align-items:flex-end;height:15px}.np .eq i{width:3px;background:#8fb6ff;border-radius:2px;height:5px}
  .np.lit .eq i{animation:eq .9s ease-in-out infinite}.np .eq i:nth-child(2){animation-delay:.2s}.np .eq i:nth-child(3){animation-delay:.4s}.np .eq i:nth-child(4){animation-delay:.6s}
  @keyframes eq{0%,100%{height:4px}50%{height:15px}}
  .dock .sep{flex:1}.dock .ctrl{display:flex;align-items:center;gap:24px;color:rgba(238,241,244,.72)}
  .dock .ctrl .temp{display:flex;align-items:center;gap:9px;font-size:21px;font-weight:600;color:var(--ink)}.dock .ctrl .temp small{font-size:12px;color:var(--ink-soft)}.dock .ctrl .chev{font-size:13px;color:var(--ink-faint)}.dock .ctrl .it{font-size:19px}

  .panel{position:fixed;top:18px;right:18px;width:236px;z-index:100;background:rgba(20,22,26,.9);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-radius:16px;padding:15px;color:#e8eaee;font-size:12.5px;box-shadow:0 20px 50px rgba(0,0,0,.5),inset 0 0 0 1px rgba(255,255,255,.08)}
  .panel .title{font-size:13.5px;font-weight:700;color:#fff;display:flex;align-items:center;gap:7px;margin-bottom:12px}.panel .title i{width:8px;height:8px;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#ff6b9b,#ffab5b,#5b8cff)}
  .ask{width:100%;border:0;border-radius:12px;cursor:pointer;font-family:inherit;font-weight:600;font-size:13.5px;padding:13px;color:#fff;background:linear-gradient(135deg,#3b78ff,#2f6bff);box-shadow:0 6px 18px rgba(47,107,255,.45);transition:.15s;display:flex;align-items:center;justify-content:center;gap:8px}
  .ask:hover{filter:brightness(1.08)}.ask:active{transform:translateY(1px)}
  .panel .phase{margin-top:12px;font-size:11px;color:#8b9098;border-top:1px solid rgba(255,255,255,.08);padding-top:10px}.panel .phase b{color:#ffce8a}
  /* 演示控制台：默认弱化半透明、略缩小，悬停恢复清晰（不抢演示效果） */
  .panel{opacity:.3;transform:scale(.86);transform-origin:top right;transition:opacity .3s ease,transform .3s ease}
  .panel:hover{opacity:1;transform:scale(1)}

  /* 全局：底栏 MVA 光球（语音区收起时的最小化态 · 点击唤起；区域展开时淡出）*/
  .mva-orb{width:38px;height:38px;border-radius:50%;flex:none;border:0;padding:0;cursor:pointer;position:relative;background:radial-gradient(circle at 38% 34%,#2a3340,#11161f);transition:transform .15s,opacity .35s}
  .mva-orb::before{content:"";position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);filter:blur(.6px);animation:mvaspin 6s linear infinite}
  .mva-orb::after{content:"";position:absolute;inset:7px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.62));box-shadow:0 0 11px rgba(255,255,255,.5)}
  .mva-orb:hover{transform:scale(1.06)}.mva-orb:active{transform:scale(.93)}
  .stage.voice-on .mva-orb{opacity:.4}
  .mva-orb.busy{opacity:.26 !important;pointer-events:none;filter:saturate(.55)}
  .stage.zone-hidden .voice-zone{opacity:0 !important;transform:translateY(-10px) scale(.985) !important;pointer-events:none !important;transition:opacity .35s ease,transform .35s ease}
  .stage.zone-hidden .map{transform:none !important}
  @keyframes mvaspin{to{transform:rotate(360deg)}}
</style>
</head>
<body>
<div class="viewport">
  <div class="stage" id="stage">
    <div class="mapbg">
      <svg viewBox="0 0 1300 812" preserveAspectRatio="xMidYMid slice">
        <defs><linearGradient id="bg" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#1c2533"/><stop offset="1" stop-color="#151b25"/></linearGradient></defs>
        <rect width="1300" height="812" fill="url(#bg)"/>
        <path d="M-20 612 C 120 588 210 640 250 720 C 270 766 250 812 250 812 L -20 812 Z" fill="#1d3144"/>
        <path d="M 1010 70 C 1110 60 1190 110 1180 200 C 1172 280 1080 300 1020 250 C 970 210 950 110 1010 70 Z" fill="#21362b"/>
        <g stroke="#222b39" stroke-width="15" fill="none" stroke-linecap="round"><path d="M-20 590 C 230 560 440 540 640 548 C 900 558 1080 520 1330 452"/><path d="M 300 -20 C 350 200 400 410 540 560 C 660 690 740 760 800 840"/><path d="M 1330 150 C 1150 210 1050 330 1010 470 C 980 640 1010 760 1030 840"/><path d="M-20 230 C 220 250 430 250 640 300 C 900 360 1040 340 1330 300"/></g>
        <g stroke="#4b5566" stroke-width="9" fill="none" stroke-linecap="round"><path d="M-20 590 C 230 560 440 540 640 548 C 900 558 1080 520 1330 452"/><path d="M 300 -20 C 350 200 400 410 540 560 C 660 690 740 760 800 840"/><path d="M 1330 150 C 1150 210 1050 330 1010 470 C 980 640 1010 760 1030 840"/><path d="M-20 230 C 220 250 430 250 640 300 C 900 360 1040 340 1330 300"/></g>
        <g stroke="#3c4552" stroke-width="4.5" fill="none" stroke-linecap="round"><path d="M 360 90 C 420 230 480 360 560 470"/><path d="M 700 300 C 760 380 820 430 920 450"/><path d="M 200 400 C 320 420 440 440 540 470"/><path d="M 980 470 C 1060 510 1140 540 1330 560"/></g>
        <g fill="#9aa3b0" font-size="15"><text x="430" y="470">莫干山镇</text><text x="800" y="210">埭溪镇</text><text x="1110" y="150">东林镇</text></g>
      </svg>
      <div class="mapbg-scrim"></div>
    </div>

    <div class="statusbar">
      <div class="sb-left">
        <div class="avatar" id="avatar"><i class="mem-halo"></i></div>
        <div class="sb-voice">
          <span class="sv-asr" id="svAsr"><span id="asrText"></span><span class="sv-cur" id="asrCur"></span></span>
          <span class="sv-reply" id="svReply"></span>
        </div>
      </div>
      <div class="sb-right">
        <svg width="15" height="18" viewBox="0 0 15 18"><path d="M3 5l9 8-4.5 4V1L12 5 3 13" fill="none" stroke="#dfe3e8" stroke-width="1.6" stroke-linejoin="round"/></svg>
        <span><sup class="sb-5g">5G</sup><svg width="22" height="16" viewBox="0 0 22 16" style="vertical-align:middle"><rect x="0" y="11" width="3.4" height="5" rx="1" fill="#dfe3e8"/><rect x="5.2" y="8" width="3.4" height="8" rx="1" fill="#dfe3e8"/><rect x="10.4" y="5" width="3.4" height="11" rx="1" fill="#dfe3e8"/><rect x="15.6" y="2" width="3.4" height="14" rx="1" fill="#dfe3e8"/></svg></span>
        <span class="sb-clock">22:18</span>
      </div>
    </div>

    <div class="map">
      <div class="map-top"><span>📍</span><span class="t">地图</span><svg width="18" height="18" viewBox="0 0 18 18"><circle cx="7.5" cy="7.5" r="5.5" fill="none" stroke="#fff" stroke-width="1.6"/><path d="M12 12l4 4" stroke="#fff" stroke-width="1.6" stroke-linecap="round"/></svg></div>
      <div class="map-quick"><div>⌂</div><div>☰</div><div>★</div><div>⚡</div></div>
    </div>
    <div class="weather"><div class="temp">14<sup>°C</sup></div><div class="loc">上海市　夜间晴</div></div>

    <!-- 氛围灯涟漪 -->
    <div class="amb" id="amb"><div class="edge"></div><div class="wave"></div><div class="wave"></div><div class="wave"></div></div>

    <!-- 推理胶囊 -->
    <div class="voice-zone" id="vz">
      <div class="think" id="think">
        <div class="think-pill" id="thinkPill"><div class="spinner"></div>
          <div class="now"><div class="l1" id="thinkNow">检测车内环境…</div><div class="l2" id="thinkNext">点开查看推理</div></div>
          <div class="chev">⌃</div></div>
        <div class="think-panel"><div class="tp-head"><span class="tp-orb"></span>MVA 推理过程</div><div class="tp-list" id="tpList"></div></div>
      </div>
      <div class="acts" id="acts"><div class="acts-line" id="actsLine"></div></div>
    </div>

    <!-- avatar→播放器 光束 -->
    <div class="spark" id="spark"></div>

    <div class="dock">
      <button class="mva-orb" id="mvaOrb" title="MVA · 唤起语音区"></button>
      <div class="np" id="np"><div class="cov" id="npCov"></div><div><div class="ti" id="npTi">未在播放</div><div class="ar" id="npAr">—</div></div><div class="eq"><i></i><i></i><i></i><i></i></div></div>
      <div class="sep"></div>
      <div class="ctrl"><div class="it">❄</div><div class="temp"><span class="chev">‹</span>22.0<small>°</small><span class="chev">›</span></div><div class="it">🚘</div><div class="it">⚡</div><div class="it">360</div><div class="it">📞</div><div class="it">▦</div></div>
    </div>
  </div>
</div>

<div class="panel">
  <div class="title"><i></i>一键舒适 · 复杂执行</div>
  <button class="ask" id="ask">🎤 “有点累，把座舱调舒适些”</button>
  <div class="phase">阶段：<b id="phlabel">待机</b></div>
</div>

<script>
const stage=document.getElementById('stage');
function fit(){stage.style.transform=`scale(${Math.min(innerWidth/1300,innerHeight/812)*0.985})`;}
addEventListener('resize',fit);fit();
const $=id=>document.getElementById(id);

const SENT='我有点累，你帮我把座舱调得舒适一些，我歇会儿';
const THINK=['检测车内环境（光线 / 温度 / 噪音）','读取车辆状态（车速 0 · 已驻车）',{t:'调用你的舒适偏好：暖光 · 24°C · 轻音乐',mem:1},'生成舒适调节方案（6 项）'];
// 执行动作：amb=氛围灯涟漪 / music=光束点亮播放器 / 其余=车控弹窗
const ACTS=[
  {ic:'🌅',title:'氛围灯 · 暖光',sub:'已调为暖色 · 30%',amb:1,
    qa:{type:'slider',lab:'亮度',val:30,min:0,max:100,unit:'%'}},
  {ic:'🪟',title:'车窗 · 已关闭',sub:'隔绝外界噪音',win:1,
    qa:{type:'slider',lab:'开合',val:0,min:0,max:100,unit:'%'}},
  {ic:'❄️',title:'空调 · 24°C',sub:'柔风 · 风量 2 挡',
    qa:{type:'step',lab:'温度',val:24,min:18,max:30,step:.5,unit:'°'}},
  {ic:'🔄',title:'已切换内循环',sub:'维持车内空气',
    qa:{type:'toggle',lab:'循环',opts:['内循环','外循环'],val:0}},
  {ic:'💆',title:'座椅按摩 · 舒缓',sub:'主驾 · 轻度 10 分钟',
    qa:{type:'seg',lab:'力度',opts:['低','中','高'],val:0}},
  {ic:'🎵',title:'轻音乐 · 助眠',sub:'MVA 精选歌单',music:1,
    qa:{type:'music',lab:'音量',val:40}},
];
// 记录每条动作的初始标题/副标题/控件值，重播时复位（控件会就地改写它们）
ACTS.forEach(a=>{a._t=a.title;a._s=a.sub;if(a.qa)a.qa._v=a.qa.val;});

const timers=[];const at=(ms,fn)=>timers.push(setTimeout(fn,ms));
function reset(){
  timers.forEach(clearTimeout);timers.length=0;
  ACTS.forEach(a=>{a.title=a._t;a.sub=a._s;if(a.qa)a.qa.val=a.qa._v;});
  document.documentElement.style.setProperty('--amb-int','.85');
  const dk=document.querySelector('.dock .temp');if(dk)dk.innerHTML='<span class="chev">‹</span>22.0<small>°</small><span class="chev">›</span>';
  $('avatar').classList.remove('awake','mem');$('thinkPill').classList.remove('mem');
  $('svAsr').className='sv-asr';$('svAsr').style.display='';$('asrText').textContent='';$('svAsr').scrollLeft=0;$('asrCur').style.display='';
  $('svReply').className='sv-reply';$('svReply').textContent='';
  $('think').classList.remove('show','expanded');$('tpList').innerHTML='';
  $('amb').classList.remove('go');stage.classList.remove('amb-on','voice-on');
  $('acts').innerHTML='<div class="acts-line" id="actsLine"></div>';$('spark').classList.remove('go');
  $('np').classList.remove('lit');$('npCov').style.background='';$('npTi').textContent='未在播放';$('npAr').textContent='—';
}
function typeASR(text,dur){const el=$('asrText'),sc=$('svAsr');let i=0;const step=dur/text.length;
  (function tick(){el.textContent=text.slice(0,i);sc.scrollLeft=sc.scrollWidth;if(i++<=text.length)timers.push(setTimeout(tick,step));})();}
// 胶囊
function showCapsule(steps){$('think').classList.add('show');
  $('tpList').innerHTML=steps.map((s,i)=>{const o=typeof s==='string'?{t:s}:s;return `<div class="tp-row todo${o.mem?' is-mem':''}" id="tpr${i}"><span class="ic"></span><span>${o.t}</span>${o.mem?'<span class="mem-tag">记忆</span>':''}</div>`;}).join('');}
function setCap(steps,k){const o=typeof steps[k]==='string'?{t:steps[k]}:steps[k],now=$('thinkNow');
  now.textContent=(o.mem?'✦ ':'')+o.t;now.classList.remove('roll');void now.offsetWidth;now.classList.add('roll');$('thinkPill').classList.toggle('mem',!!o.mem);
  steps.forEach((x,j)=>{const m=typeof x!=='string'&&x.mem;const r=$('tpr'+j);if(r)r.className='tp-row '+(j<k?'done':j===k?'active':'todo')+(m?' is-mem':'');});
  if(o.mem)memPulse();}
function capStatus(txt){$('think').classList.remove('expanded');$('thinkPill').classList.remove('mem');const now=$('thinkNow');now.textContent=txt;now.classList.remove('roll');void now.offsetWidth;now.classList.add('roll');$('thinkNext').textContent='点开查看推理';
  [...$('tpList').children].forEach(r=>r.className=r.className.replace('active','done'));}
function memPulse(){const a=$('avatar');a.classList.remove('mem');void a.offsetWidth;a.classList.add('mem');timers.push(setTimeout(()=>a.classList.remove('mem'),1300));}
// 氛围灯涟漪
function ripple(){stage.classList.add('amb-on');const a=$('amb');a.classList.remove('go');void a.offsetWidth;a.classList.add('go');}
// 执行清单：逐条生长（像导航规划点）
function addAct(a){const cls=a.amb?' amb':a.music?' music':a.win?' win':'';
  const s=document.createElement('div');s.className='act'+cls;
  s.innerHTML=`<div class="node"></div><div class="row"><div class="aem">${a.ic}</div><div><div class="atitle">${a.title}</div><div class="asub">${a.sub}</div></div><div class="ack">✓</div></div>`
    +`<div class="qa">${buildQA(a)}</div>`;
  $('acts').appendChild(s);
  // 连接线只连到最后一个节点圆心，不随快速调整控件继续往下延伸
  const grow=()=>{const acts=$('acts'),nodes=acts.querySelectorAll('.act .node');if(!nodes.length)return;
    const last=nodes[nodes.length-1],top=acts.getBoundingClientRect().top;
    $('actsLine').style.height=(last.getBoundingClientRect().top-top-14+10)+'px';};
  requestAnimationFrame(()=>{s.classList.add('in');grow();});
  timers.push(setTimeout(()=>{s.classList.add('done');},360));
  // 动作落地后再展开它的快速调整控件
  timers.push(setTimeout(()=>{s.classList.add('tuned');wireQA(s,a);timers.push(setTimeout(grow,30));},620));}

// 快速调整控件：按动作类型生成
function buildQA(a){const q=a.qa;if(!q)return'';
  if(q.type==='step')return `<div class="qa-in"><span class="lab">${q.lab}</span><div class="qa-step"><span class="qa-btn" data-d="-1">−</span><span class="qa-val">${q.val.toFixed(1)}<small>${q.unit}</small></span><span class="qa-btn" data-d="1">+</span></div></div>`;
  if(q.type==='seg')return `<div class="qa-in"><span class="lab">${q.lab}</span><div class="qa-seg">${q.opts.map((o,i)=>`<span class="sg${i===q.val?' on':''}" data-i="${i}">${o}</span>`).join('')}</div></div>`;
  if(q.type==='toggle')return `<div class="qa-in"><span class="lab">${q.lab}</span><div class="qa-toggle">${q.opts.map((o,i)=>`<span class="tg${i===q.val?' on':''}" data-i="${i}">${o}</span>`).join('')}</div></div>`;
  if(q.type==='slider')return `<div class="qa-in"><span class="lab">${q.lab}</span><div class="qa-slider"><div class="qa-track"><div class="qa-fill"></div></div><div class="qa-knob"></div></div><span class="qa-val" style="min-width:42px">${q.val}<small>${q.unit}</small></span></div>`;
  if(q.type==='music')return `<div class="qa-in"><div class="qa-trans"><span class="qa-tb" data-m="prev">⏮</span><span class="qa-tb play" data-m="play">⏸</span><span class="qa-tb" data-m="next">⏭</span></div><span class="lab" style="margin-left:2px">🔊</span><div class="qa-slider"><div class="qa-track"><div class="qa-fill"></div></div><div class="qa-knob"></div></div></div>`;
  return'';}

// 快速调整控件：交互绑定（即时视觉反馈）
function wireQA(s,a){const q=a.qa;if(!q)return;const sub=s.querySelector('.asub');
  if(q.type==='step'){const valEl=s.querySelector('.qa-val');
    s.querySelectorAll('.qa-btn').forEach(b=>b.onclick=()=>{q.val=Math.min(q.max,Math.max(q.min,q.val+(+b.dataset.d)*q.step));
      valEl.innerHTML=`${q.val.toFixed(1)}<small>${q.unit}</small>`;sub.textContent=`柔风 · 风量 2 挡`;
      const dk=document.querySelector('.dock .temp');if(dk)dk.innerHTML=`<span class="chev">‹</span>${q.val.toFixed(1)}<small>°</small><span class="chev">›</span>`;
      s.querySelector('.atitle').textContent=`空调 · ${q.val.toFixed(1)}°C`;});}
  else if(q.type==='seg'){const sgs=s.querySelectorAll('.sg');sgs.forEach(sg=>sg.onclick=()=>{q.val=+sg.dataset.i;
    sgs.forEach(x=>x.classList.toggle('on',x===sg));sub.textContent=`主驾 · ${['轻度','中度','强度'][q.val]} 10 分钟`;});}
  else if(q.type==='toggle'){const tgs=s.querySelectorAll('.tg');tgs.forEach(tg=>tg.onclick=()=>{q.val=+tg.dataset.i;
    tgs.forEach((x,i)=>{x.classList.toggle('on',i===q.val);x.classList.toggle('off',i!==q.val&&i===1);});
    s.querySelector('.atitle').textContent='已切换'+q.opts[q.val];});}
  else if(q.type==='slider'){const fill=s.querySelector('.qa-fill'),knob=s.querySelector('.qa-knob'),valEl=s.querySelector('.qa-val'),track=s.querySelector('.qa-slider');
    const set=p=>{p=Math.round(Math.min(100,Math.max(0,p)));q.val=p;fill.style.width=p+'%';knob.style.left=p+'%';valEl.innerHTML=`${p}<small>${q.unit}</small>`;
      if(a.amb){document.documentElement.style.setProperty('--amb-int',(.35+p/100*.65).toFixed(2));s.querySelector('.atitle').textContent='氛围灯 · 暖光';sub.textContent=`已调为暖色 · ${p}%`;}
      if(a.win){s.querySelector('.atitle').textContent=p<=2?'车窗 · 已关闭':`车窗 · 开 ${p}%`;sub.textContent=p<=2?'隔绝外界噪音':'通风换气';}};
    set(q.val);dragSlider(track,set);}
  else if(q.type==='music'){const fill=s.querySelector('.qa-fill'),knob=s.querySelector('.qa-knob'),track=s.querySelector('.qa-slider'),playBtn=s.querySelector('[data-m="play"]');
    const set=p=>{p=Math.round(Math.min(100,Math.max(0,p)));q.val=p;fill.style.width=p+'%';knob.style.left=p+'%';};set(q.val);dragSlider(track,set);
    playBtn.onclick=()=>{const on=playBtn.textContent==='⏸';playBtn.textContent=on?'▶':'⏸';$('np').classList.toggle('lit',!on);};
    s.querySelector('[data-m="prev"]').onclick=()=>{$('npTi').textContent='上一首 · MVA 精选';};
    s.querySelector('[data-m="next"]').onclick=()=>{$('npTi').textContent='下一首 · MVA 精选';};}}

// 通用滑条拖拽 + 点击
function dragSlider(track,set){const pct=e=>{const r=track.getBoundingClientRect();const x=(e.touches?e.touches[0].clientX:e.clientX)-r.left;return x/r.width*100;};
  const onMove=e=>{set(pct(e));e.preventDefault();};
  const onUp=()=>{removeEventListener('mousemove',onMove);removeEventListener('mouseup',onUp);removeEventListener('touchmove',onMove);removeEventListener('touchend',onUp);};
  const onDown=e=>{set(pct(e));addEventListener('mousemove',onMove);addEventListener('mouseup',onUp);addEventListener('touchmove',onMove,{passive:false});addEventListener('touchend',onUp);};
  track.addEventListener('mousedown',onDown);track.addEventListener('touchstart',onDown,{passive:false});}
// 音乐：光束→点亮播放器
function lightMusic(a){const s=$('spark');s.classList.remove('go');void s.offsetWidth;s.classList.add('go');
  at(0,()=>{});setTimeout(()=>{$('npCov').style.background='linear-gradient(135deg,#3a6b8c,#243a52)';$('npTi').textContent=a.title;$('npAr').textContent=a.ar||'MVA 精选';$('np').classList.add('lit');},920);}

function play(){
  reset();
  $('phlabel').textContent='聆听 · 识别中';
  $('avatar').classList.add('awake');
  $('svAsr').classList.add('show');
  typeASR(SENT,2800);
  at(3100,()=>{$('phlabel').textContent='识别成功';$('asrCur').style.display='none';$('svAsr').classList.add('done');});
  at(3650,()=>$('svAsr').classList.add('gone'));
  at(4100,()=>{$('svAsr').style.display='none';$('svReply').textContent='好的，这就为你把座舱调到舒适模式';$('svReply').classList.add('show');stage.classList.add('voice-on');$('phlabel').textContent='复杂推理中';});  // 内容出现→地图卡推右
  // 推理胶囊
  const TS=4500;at(TS,()=>showCapsule(THINK));
  THINK.forEach((s,i)=>at(TS+i*800,()=>{setCap(THINK,i);$('phlabel').textContent=`推理 ${i+1}/${THINK.length}`;}));
  const EX=TS+THINK.length*800;             // 执行开始
  at(EX,()=>capStatus('正在为你调节…'));
  // 依次执行 6 项（节奏稍慢）
  const gap=1500;
  ACTS.forEach((a,i)=>at(EX+200+i*gap,()=>{
    $('phlabel').textContent=`执行 ${i+1}/6 · ${a.title}`;
    $('thinkNow').textContent='正在调节 · '+a.title;$('thinkNow').classList.remove('roll');void $('thinkNow').offsetWidth;$('thinkNow').classList.add('roll');
    addAct(a);                              // 语音区逐条生长出这项操作
    if(a.amb)ripple();                      // 氛围灯：同时荡起暖色涟漪
    if(a.music)lightMusic(a);               // 音乐：同时一束光点亮底部播放器
  }));
  const END=EX+200+ACTS.length*gap;
  at(END,()=>{capStatus('已为你调节 6 项 · 舒适就绪');
    $('svReply').textContent='舒适模式已就绪，好好休息一会儿吧';$('phlabel').textContent='完成 · 舒适模式';});
}
$('ask').onclick=play;
$('thinkPill').onclick=()=>$('think').classList.toggle('expanded');
setTimeout(play,600);
</script>

<script>
(function(){
  var orb=document.getElementById('mvaOrb');if(!orb)return;
  var stage=document.querySelector('.stage');
  var watch=[document.querySelector('.voice-zone'),document.querySelector('.statusbar')].filter(Boolean);
  var busy=true,settleT=null;
  function en(on){orb.classList.toggle('busy',!on);}
  function settle(){busy=false;en(true);}
  function bump(){busy=true;en(false);clearTimeout(settleT);settleT=setTimeout(settle,1200);}
  try{var obs=new MutationObserver(bump);watch.forEach(function(n){obs.observe(n,{childList:true,subtree:true,characterData:true,attributes:true,attributeFilter:['class','style']});});}catch(e){}
  bump();
  orb.onclick=function(){if(busy)return;stage.classList.toggle('zone-hidden');};
})();
</script>
</body>
</html>
