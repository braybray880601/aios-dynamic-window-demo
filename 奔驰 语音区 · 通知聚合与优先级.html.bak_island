<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>奔驰 · 语音区 · 通知聚合与优先级</title>
<!--
  feed 流承载三类消息:车辆(IC)故障/保养 · AI 推荐 · 系统通知(安装成功等)。
  规则:① 按重要程度排序(车辆故障最高 > 保养 > 推荐 > 系统最低)
       ② 适当聚合 —— 不重要的折叠成「· N 条」分组;车辆(IC)也可整体进聚合态,不必全摊开
       ③ 清晰标明 —— 每条带类别标签;车辆故障置顶红色高亮
  交互:单指向左滑动收起 feed;收起后若有重要通知,左边缘保留持续提示(红色脉冲),点一下展开。
  三种视图:优先级展开 / 车辆聚合 / 三类全聚合。文案原创,无版权正文。
-->
<style>
  :root{--card:rgba(20,26,38,.7);--card-bd:rgba(255,255,255,.1);--ink:#eef1f4;--soft:rgba(238,241,244,.62);--faint:rgba(238,241,244,.4);--gold:#ffcf6a;--green:#34d06a;--vz-w:430px}
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{height:100%;background:#05070b;overflow:hidden;font-family:"PingFang SC","Microsoft YaHei",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;-webkit-font-smoothing:antialiased;color:var(--ink)}
  .viewport{position:fixed;inset:0;display:flex;align-items:center;justify-content:center}
  .stage{position:relative;width:1300px;height:812px;overflow:hidden;transform-origin:center center;border-radius:18px;box-shadow:0 40px 120px rgba(0,0,0,.65);background:radial-gradient(135% 115% at 50% 8%,#141c2a 0%,#0e1420 46%,#080b12 100%)}
  .mapbg{position:absolute;inset:0;z-index:0}.mapbg svg{position:absolute;inset:0;width:100%;height:100%}
  .mapbg-scrim{position:absolute;inset:0;background:radial-gradient(125% 105% at 50% 40%,rgba(8,11,18,.5),rgba(6,9,15,.76))}

  .statusbar{position:absolute;top:0;left:0;right:0;height:50px;display:flex;align-items:center;justify-content:space-between;padding:0 24px;z-index:55}
  .sb-left{display:flex;align-items:center;gap:13px;flex:1;min-width:0;height:100%;padding-right:24px}
  .avatar{width:36px;height:36px;border-radius:50%;flex:none;position:relative;background-image:linear-gradient(135deg,#f3c9b0,#cf9d86);box-shadow:inset 0 0 0 1.5px rgba(255,255,255,.4);transition:box-shadow .5s}
  .avatar::before{content:"";position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);filter:blur(1px);opacity:0;transition:opacity .55s;animation:spin 5s linear infinite}
  .avatar::after{content:"";position:absolute;inset:7px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.6));box-shadow:0 0 14px rgba(255,255,255,.55);opacity:0;transition:opacity .55s}
  .avatar.awake{box-shadow:none;animation:breathe 3.2s ease-in-out infinite}.avatar.awake::before,.avatar.awake::after{opacity:1}
  @keyframes spin{to{transform:rotate(360deg)}}@keyframes breathe{0%,100%{transform:scale(1)}50%{transform:scale(1.07)}}
  .sb-voice{position:relative;display:flex;align-items:center;min-width:0;height:100%}
  .sv-reply{font-size:15.5px;font-weight:600;color:#fff;white-space:nowrap;opacity:0;transform:translateY(4px);transition:opacity .45s,transform .45s;text-shadow:0 1px 12px rgba(0,0,0,.5)}.sv-reply.show{opacity:1;transform:none}
  .sb-right{display:flex;align-items:center;gap:16px;color:#dfe3e8;flex:none}.sb-clock{font-size:19px;font-weight:500}.sb-5g{font-size:10px;font-weight:700;vertical-align:top}

  .map{position:absolute;top:64px;left:40px;width:300px;border-radius:20px;background:rgba(44,52,64,.5);backdrop-filter:blur(22px) saturate(1.2);-webkit-backdrop-filter:blur(22px) saturate(1.2);box-shadow:0 8px 30px rgba(0,0,0,.3),inset 0 0 0 1px rgba(255,255,255,.12);overflow:hidden;z-index:25;color:#fff;transition:transform .42s cubic-bezier(.2,.7,.2,1)}
  .stage.mapright .map{transform:translateX(calc(var(--vz-w) + 16px))}
  .map-top{display:flex;align-items:center;gap:9px;padding:14px 16px}.map-top .t{flex:1;font-size:16px;font-weight:500}
  .map-quick{display:flex;background:rgba(10,14,20,.4)}.map-quick div{flex:1;display:flex;align-items:center;justify-content:center;padding:12px 0;opacity:.85}.map-quick div+div{box-shadow:inset 1px 0 0 rgba(255,255,255,.08)}
  .weather{position:absolute;top:60px;right:36px;text-align:right;z-index:25}
  .weather .temp{font-size:60px;font-weight:200;line-height:.9;letter-spacing:-1px;color:#fff}.weather .temp sup{font-size:20px;font-weight:300;vertical-align:top;margin-left:2px}.weather .loc{font-size:15px;color:var(--soft);margin-top:6px}
  .cards{position:absolute;left:40px;right:40px;bottom:84px;display:flex;gap:16px;z-index:15}
  .card{flex:1;height:96px;border-radius:18px;background:rgba(24,30,40,.6);backdrop-filter:blur(20px) saturate(1.2);box-shadow:0 8px 26px rgba(0,0,0,.25),inset 0 0 0 1px rgba(255,255,255,.1);display:flex;align-items:center;gap:13px;padding:0 18px;color:#eef1f4}
  .card .ic{width:42px;height:42px;border-radius:11px;flex:none;display:flex;align-items:center;justify-content:center;font-size:20px;background:rgba(255,255,255,.08)}
  .card .ic.pink{background:linear-gradient(135deg,#ff7a9c,#ff5277)}.card .big{font-size:18px;font-weight:600}.card .sub{font-size:12px;color:var(--soft);margin-top:3px}.card .lnk{color:#7fa8ff;font-weight:600}
  .card .col2{display:flex;gap:18px;width:100%}.tyre{display:flex;flex-direction:column;gap:4px;font-size:12px;color:var(--soft);width:100%}.tyre .r{display:flex;justify-content:space-between}.tyre .tcar{align-self:center;width:26px;height:14px;border-radius:5px;background:rgba(255,255,255,.16);margin:1px 0}

  /* ── 语音区:通知 feed(可单指左滑收起)── */
  .voice-zone{position:absolute;left:40px;top:60px;z-index:50;width:var(--vz-w);display:flex;flex-direction:column;touch-action:pan-y;cursor:grab}
  .voice-zone:active{cursor:grabbing}
  .feed-hd{display:flex;align-items:center;gap:8px;padding:6px 4px 11px;font-size:12.5px;font-weight:700;color:var(--soft);letter-spacing:.04em}
  .feed-hd .dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);animation:livedot 1.6s ease-in-out infinite}
  @keyframes livedot{0%,100%{opacity:.5}50%{opacity:1}}
  .feed-hd .sp{margin-left:auto;font-weight:600;color:var(--faint)}
  .feed-hd .grab{margin-left:8px;color:var(--faint);font-weight:600}
  .track{display:flex;flex-direction:column;gap:11px}

  /* 个体通知卡(优先级展开态用) */
  .ncard{position:relative;background:var(--card);backdrop-filter:blur(18px) saturate(1.2);-webkit-backdrop-filter:blur(18px) saturate(1.2);border-radius:15px;box-shadow:inset 0 0 0 1px var(--card-bd);padding:12px 14px 12px 17px;display:flex;align-items:center;gap:12px;overflow:hidden;transition:box-shadow .35s}
  .ncard .nstripe{position:absolute;left:0;top:0;bottom:0;width:4px}
  .pfault .nstripe{background:#ff5a5a}.pmaint .nstripe{background:#ffab5b}.prec .nstripe{background:#ffcf6a}
  .ncard .nic{width:42px;height:42px;border-radius:11px;flex:none;display:flex;align-items:center;justify-content:center;font-size:21px;background:rgba(255,255,255,.07)}
  .pfault .nic{background:rgba(255,90,90,.16)}.pmaint .nic{background:rgba(255,171,91,.16)}
  .ncard .nmain{flex:1;min-width:0}
  .ncard .nrow1{display:flex;align-items:center;gap:7px;margin-bottom:3px}
  .ncard .ntag{font-size:9.5px;font-weight:800;padding:1px 7px;border-radius:6px;letter-spacing:.02em}
  .pfault .ntag{color:#ff8f8f;background:rgba(255,90,90,.18)}.pmaint .ntag{color:#ffc188;background:rgba(255,171,91,.18)}.prec .ntag{color:#ffd98a;background:rgba(255,207,106,.15)}
  .ncard .nimp{font-size:9px;font-weight:800;color:#2a0a0a;background:#ff6a6a;padding:1px 6px;border-radius:6px}
  .ncard .nt{font-size:14.5px;font-weight:700;color:var(--ink);line-height:1.25}
  .pfault .nt{font-size:15.5px}
  .ncard .ns{font-size:11.5px;color:var(--soft);margin-top:2px;line-height:1.35}
  .ncard .nact{flex:none;border:0;cursor:pointer;font-family:inherit;font-weight:700;font-size:12px;padding:8px 13px;border-radius:10px;color:#0b0a14;background:#ffcf6a;align-self:center}
  .pfault .nact{background:#ff6a6a;color:#fff}.pmaint .nact{background:#ffab5b;color:#241404}
  .ncard .ngo{flex:none;color:var(--faint);font-size:15px}
  .ncard.pfault{box-shadow:inset 0 0 0 1.4px rgba(255,90,90,.5),0 10px 26px rgba(255,60,60,.16);background:rgba(38,22,26,.68)}
  .ncard.pfault.attn{animation:faultpulse 1.5s ease-in-out 2}
  @keyframes faultpulse{0%,100%{box-shadow:inset 0 0 0 1.4px rgba(255,90,90,.5),0 10px 26px rgba(255,60,60,.16)}50%{box-shadow:inset 0 0 0 2px rgba(255,135,135,.85),0 12px 34px rgba(255,60,60,.45)}}

  /* 聚合分组(系统 / 车辆 / 推荐通用) */
  .grp{border-radius:14px;background:rgba(255,255,255,.035);box-shadow:inset 0 0 0 1px rgba(255,255,255,.07);overflow:hidden;transition:box-shadow .35s}
  .grp.flash{box-shadow:inset 0 0 0 1.5px rgba(150,165,190,.55)}
  .grp.urgent{background:rgba(38,22,26,.5);box-shadow:inset 0 0 0 1.3px rgba(255,90,90,.42)}
  .g-head{display:flex;align-items:center;gap:9px;padding:11px 14px;cursor:pointer}
  .g-ic{font-size:15px}
  .g-lbl{font-size:13px;font-weight:700;color:rgba(238,241,244,.82)}
  .g-veh .g-lbl{color:#ffd0a0}.grp.urgent .g-lbl{color:#ff9a9a}
  .g-cnt{font-size:11px;font-weight:700;color:#b3bbc9;background:rgba(255,255,255,.08);padding:1px 8px;border-radius:9px;transition:transform .25s}
  .g-cnt.bump{transform:scale(1.18)}
  .g-note{font-size:10px;color:var(--faint)}
  .grp.urgent .g-note{color:#ff8a8a;font-weight:700}
  .g-chev{margin-left:auto;font-size:13px;color:var(--faint);transition:transform .3s}
  .grp.open .g-chev{transform:rotate(180deg)}
  .g-list{max-height:0;overflow:hidden;transition:max-height .42s cubic-bezier(.2,.8,.2,1)}
  .grp.open .g-list{max-height:320px}
  .g-item{display:flex;align-items:center;gap:9px;padding:9px 14px;font-size:12px;box-shadow:inset 0 1px 0 rgba(255,255,255,.05)}
  .g-dot{width:7px;height:7px;border-radius:50%;flex:none}
  .g-dot.fault{background:#ff5a5a;box-shadow:0 0 7px rgba(255,90,90,.8)}.g-dot.maint{background:#ffab5b}.g-dot.rec{background:#ffcf6a}.g-dot.sys{background:#8b95a6}
  .g-i{font-size:14px;opacity:.75;flex:none}
  .g-t{flex:1;min-width:0;color:rgba(238,241,244,.85);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .g-s{font-size:10.5px;color:var(--faint);flex:none}

  /* 收起后:左边缘持续提示 */
  /* 收起后:左边缘只留一道光条提示(无文字);重要=红色闪烁 */
  .edge-hint{position:absolute;left:0;top:60px;bottom:64px;width:30px;z-index:60;opacity:0;pointer-events:none;transition:opacity .42s}
  .edge-hint.show{opacity:1;pointer-events:auto;cursor:pointer}
  .edge-hint .eh-bar{position:absolute;left:0;top:38%;bottom:38%;width:5px;border-radius:0 4px 4px 0;background:rgba(150,165,190,.5);transform-origin:center}
  .edge-hint.sev-fault .eh-bar{background:#ff5a5a;box-shadow:0 0 13px 2px rgba(255,80,80,.7);animation:ehpulse 1.2s ease-in-out infinite}
  .edge-hint.sev-maint .eh-bar{background:#ffab5b;box-shadow:0 0 11px 2px rgba(255,171,91,.55);animation:ehpulse 1.9s ease-in-out infinite}
  @keyframes ehpulse{0%,100%{opacity:.4;transform:scaleY(.92)}50%{opacity:1;transform:scaleY(1)}}

  .dock{position:absolute;left:0;right:0;bottom:0;height:64px;z-index:30;display:flex;align-items:center;gap:18px;padding:0 22px;background:rgba(12,16,24,.6);backdrop-filter:blur(26px);box-shadow:inset 0 1px 0 rgba(255,255,255,.08)}
  .dock .home{width:32px;height:32px;border-radius:50%;box-shadow:inset 0 0 0 2px rgba(255,255,255,.5);flex:none}
  .dock .tt{font-size:13px;color:var(--soft)}.dock .sep{flex:1}.dock .ctrl{display:flex;align-items:center;gap:24px;color:rgba(238,241,244,.7);font-size:18px}

  .panel{position:fixed;top:18px;right:18px;width:256px;z-index:100;background:rgba(20,22,26,.9);backdrop-filter:blur(20px);border-radius:16px;padding:15px;color:#e8eaee;font-size:12.5px;box-shadow:0 20px 50px rgba(0,0,0,.5),inset 0 0 0 1px rgba(255,255,255,.08)}
  .panel .title{font-size:13.5px;font-weight:700;color:#fff;display:flex;align-items:center;gap:7px;margin-bottom:11px}.panel .title i{width:8px;height:8px;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#ff6b9b,#ffab5b,#5b8cff)}
  .panel button{width:100%;border:0;border-radius:11px;cursor:pointer;font-family:inherit;font-weight:600;font-size:13px;padding:10px;color:#fff;margin-top:8px;text-align:left;background:rgba(255,255,255,.08);transition:.15s}
  .panel button:hover{background:rgba(255,255,255,.16)}.panel button.main{background:linear-gradient(135deg,#3b78ff,#2f6bff)}
  .panel .seglbl{margin-top:11px;font-size:10.5px;color:var(--faint);letter-spacing:.06em}
  .panel .seg{display:flex;gap:6px;margin-top:5px}
  .panel .seg button{margin-top:0;flex:1;text-align:center;padding:8px 3px;font-size:11px;background:rgba(255,255,255,.06)}
  .panel .seg button.on{background:linear-gradient(135deg,#3b78ff,#2f6bff)}
  .panel .phase{margin-top:11px;font-size:11px;color:#8b9098;border-top:1px solid rgba(255,255,255,.08);padding-top:9px}.panel .phase b{color:#ffce8a}
  .panel{opacity:.3;transform:scale(.86);transform-origin:top right;transition:opacity .3s ease,transform .3s ease}
  .panel:hover{opacity:1;transform:scale(1)}

  /* 全局：底栏 MVA 光球（语音区收起时的最小化态 · 点击唤起；区域展开时淡出）*/
  .mva-orb{width:38px;height:38px;border-radius:50%;flex:none;border:0;padding:0;cursor:pointer;position:relative;background:radial-gradient(circle at 38% 34%,#2a3340,#11161f);transition:transform .15s,opacity .35s}
  .mva-orb::before{content:"";position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);filter:blur(.6px);animation:mvaspin 6s linear infinite}
  .mva-orb::after{content:"";position:absolute;inset:7px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.62));box-shadow:0 0 11px rgba(255,255,255,.5)}
  .mva-orb:hover{transform:scale(1.06)}.mva-orb:active{transform:scale(.93)}
  .stage.voice-on .mva-orb{opacity:.4}
  .mva-orb.busy{opacity:.26 !important;pointer-events:none;filter:saturate(.55)}
  .stage.zone-hidden .voice-zone{opacity:0 !important;transform:translateY(-10px) scale(.985) !important;pointer-events:none !important;transition:opacity .35s ease,transform .35s ease}
  .stage.zone-hidden .map{transform:none !important}
  @keyframes mvaspin{to{transform:rotate(360deg)}}
</style>
</head>
<body>
<div class="viewport">
  <div class="stage mapright" id="stage">
    <div class="mapbg">
      <svg viewBox="0 0 1300 812" preserveAspectRatio="xMidYMid slice">
        <defs><linearGradient id="bg" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#1c2533"/><stop offset="1" stop-color="#151b25"/></linearGradient></defs>
        <rect width="1300" height="812" fill="url(#bg)"/>
        <path d="M-20 612 C 120 588 210 640 250 720 C 270 766 250 812 250 812 L -20 812 Z" fill="#1d3144"/>
        <path d="M 1010 70 C 1110 60 1190 110 1180 200 C 1172 280 1080 300 1020 250 C 970 210 950 110 1010 70 Z" fill="#21362b"/>
        <g stroke="#222b39" stroke-width="15" fill="none" stroke-linecap="round"><path d="M-20 590 C 230 560 440 540 640 548 C 900 558 1080 520 1330 452"/><path d="M 300 -20 C 350 200 400 410 540 560 C 660 690 740 760 800 840"/></g>
        <g stroke="#4b5566" stroke-width="9" fill="none" stroke-linecap="round"><path d="M-20 590 C 230 560 440 540 640 548 C 900 558 1080 520 1330 452"/><path d="M 300 -20 C 350 200 400 410 540 560 C 660 690 740 760 800 840"/></g>
        <g fill="#9aa3b0" font-size="15"><text x="430" y="470">莫干山镇</text><text x="800" y="210">埭溪镇</text></g>
      </svg>
      <div class="mapbg-scrim"></div>
    </div>

    <div class="statusbar">
      <div class="sb-left">
        <div class="avatar" id="avatar"></div>
        <div class="sb-voice"><span class="sv-reply" id="svReply"></span></div>
      </div>
      <div class="sb-right"><span><sup class="sb-5g">5G</sup> ▮▮▮</span><span class="sb-clock">21:36</span></div>
    </div>

    <div class="map">
      <div class="map-top"><span>📍</span><span class="t">地图</span><svg width="18" height="18" viewBox="0 0 18 18"><circle cx="7.5" cy="7.5" r="5.5" fill="none" stroke="#fff" stroke-width="1.6"/><path d="M12 12l4 4" stroke="#fff" stroke-width="1.6" stroke-linecap="round"/></svg></div>
      <div class="map-quick"><div>⌂</div><div>☰</div><div>★</div><div>⚡</div></div>
    </div>
    <div class="weather"><div class="temp">14<sup>°C</sup></div><div class="loc">上海市　夜间晴</div></div>

    <!-- 收起后的左边缘提示 -->
    <div class="edge-hint" id="edgeHint" title="点这里展开通知"><div class="eh-bar"></div></div>

    <!-- 语音区:通知 feed -->
    <div class="voice-zone" id="vz">
      <div class="feed-hd"><span class="dot"></span>通知 · 按重要程度聚合排序<span class="sp">车辆优先</span><span class="grab">⟨ 左滑收起</span></div>
      <div class="track" id="track"></div>
    </div>

    <div class="dock"><button class="mva-orb" id="mvaOrb" title="MVA · 唤起语音区"></button>
      <div class="tt">🏠 桌面 · 通知中心</div><div class="sep"></div><div class="ctrl"><span>❄</span><span>🚘</span><span>360</span><span>📞</span><span>▦</span></div></div>
  </div>
</div>

<div class="panel">
  <div class="title"><i></i>通知聚合 × 优先级</div>
  <button class="main" id="bAll">▶ 完整演示</button>
  <div class="seglbl">视图</div>
  <div class="seg"><button id="mPri" class="on">优先级展开</button><button id="mVeh">车辆聚合</button><button id="mAll">三类全聚合</button></div>
  <button id="bCollapse">⟨ 左滑收起 feed(等效手势)</button>
  <button id="bFault">⚠️ 来条车辆故障(置顶)</button>
  <button id="bSys">🔔 来条系统通知(聚合)</button>
  <button id="bIdle">↺ 复位</button>
  <div class="phase">状态:<b id="phlabel">待机</b></div>
</div>

<script>
const stage=document.getElementById('stage');
let __sc=1;
function fit(){__sc=Math.min(innerWidth/1300,innerHeight/812)*0.985;stage.style.transform=`scale(${__sc})`;}
addEventListener('resize',fit);fit();
const $=id=>document.getElementById(id);

// 类别 → 优先级 + 标签 + 样式
const PRI={fault:0,maint:1,rec:2,sys:3};
const LBL={fault:'车辆 · 故障',maint:'车辆 · 保养',rec:'AI 推荐'};
const CLS={fault:'pfault',maint:'pmaint',rec:'prec'};

// 初始数据(可被 live 演示修改;复位时还原)
const D0={
  faults:[],
  maints:[{ic:'🔧',t:'机油寿命剩 8%',s:'建议本周预约保养 · 就近 3 家门店',act:'预约'}],
  recs:[{ic:'☕',t:'顺路 · Manner 咖啡(常去)',s:'前方 1.2km · 本周已来过 2 次'},{ic:'🚗',t:'现在回家约 38 分钟',s:'全程畅通 · 比平时快 6 分钟'}],
  sys:[{ic:'✅',t:'「Spotify」安装成功',s:'5 分钟前'},{ic:'🔗',t:'已连接 蓝牙耳机 WF-1000',s:'12 分钟前'}],
};
let FAULTS,MAINTS,RECS,SYS,mode='priority',collapsed=false;
function resetData(){FAULTS=D0.faults.map(c=>({...c}));MAINTS=D0.maints.map(c=>({...c}));RECS=D0.recs.map(c=>({...c}));SYS=D0.sys.map(c=>({...c}));}

function cardHTML(cat,n){
  return `<div class="ncard ${CLS[cat]}" data-cat="${cat}"><div class="nstripe"></div><div class="nic">${n.ic}</div>
    <div class="nmain"><div class="nrow1"><span class="ntag">${LBL[cat]}</span>${cat==='fault'?'<span class="nimp">重要</span>':''}</div>
    <div class="nt">${n.t}</div><div class="ns">${n.s}</div></div>
    ${n.act?`<button class="nact">${n.act}</button>`:'<div class="ngo">›</div>'}</div>`;
}
function grpRow(n){return `<div class="g-item"><span class="g-dot ${n.cat}"></span><span class="g-i">${n.ic}</span><span class="g-t">${n.t}</span><span class="g-s">${n.s||''}</span></div>`;}
function groupHTML(key,items,o){
  return `<div class="grp g-${key}${o.urgent?' urgent':''}" id="grp-${key}">
    <div class="g-head"><span class="g-ic">${o.icon}</span><span class="g-lbl">${o.label}</span>
      <span class="g-cnt" id="cnt-${key}">${items.length} 条</span>${o.note?`<span class="g-note">${o.note}</span>`:''}<span class="g-chev">⌄</span></div>
    <div class="g-list" id="list-${key}">${items.map(grpRow).join('')}</div></div>`;
}
const tagCat=(arr,c)=>arr.map(x=>({...x,cat:c}));

function render(){
  const t=$('track');
  const open=[...t.querySelectorAll('.grp.open')].map(g=>g.id);   // 记住展开的分组
  const sysItems=tagCat(SYS,'sys'),vehItems=[...tagCat(FAULTS,'fault'),...tagCat(MAINTS,'maint')];
  let h='';
  if(mode==='priority'){
    FAULTS.forEach(n=>h+=cardHTML('fault',n));
    MAINTS.forEach(n=>h+=cardHTML('maint',n));
    RECS.forEach(n=>h+=cardHTML('rec',n));
    h+=groupHTML('sys',sysItems,{icon:'🔔',label:'系统通知',note:'不重要 · 已聚合'});
  }else if(mode==='vehAgg'){
    h+=groupHTML('veh',vehItems,{icon:'🚗',label:'车辆通知',note:FAULTS.length?`含 ${FAULTS.length} 条故障 · 需处理`:'保养提醒',urgent:FAULTS.length>0});
    RECS.forEach(n=>h+=cardHTML('rec',n));
    h+=groupHTML('sys',sysItems,{icon:'🔔',label:'系统通知',note:'不重要 · 已聚合'});
  }else{ // allAgg:三类都进 feed,各自一个分组
    h+=groupHTML('veh',vehItems,{icon:'🚗',label:'车辆通知',note:FAULTS.length?`含 ${FAULTS.length} 条故障`:'',urgent:FAULTS.length>0});
    h+=groupHTML('rec',tagCat(RECS,'rec'),{icon:'✨',label:'为你推荐',note:''});
    h+=groupHTML('sys',sysItems,{icon:'🔔',label:'系统通知',note:'不重要'});
  }
  t.innerHTML=h;
  open.forEach(id=>{const g=document.getElementById(id);if(g)g.classList.add('open');});
  t.querySelectorAll('.grp').forEach(g=>g.querySelector('.g-head').onclick=()=>g.classList.toggle('open'));
}

const timers=[];const at=(ms,fn)=>timers.push(setTimeout(fn,ms));
function clearT(){timers.forEach(clearTimeout);timers.length=0;}
function reply(t){$('svReply').textContent=t;$('svReply').className='sv-reply show';}
function clearReply(){$('svReply').className='sv-reply';$('svReply').textContent='';}
function phase(t){$('phlabel').textContent=t;}
function syncModeBtns(){const m={priority:'mPri',vehAgg:'mVeh',allAgg:'mAll'};['mPri','mVeh','mAll'].forEach(id=>$(id).classList.toggle('on',m[mode]===id));}

function setMode(m){mode=m;render();syncModeBtns();phase('视图:'+({priority:'优先级展开',vehAgg:'车辆聚合 · IC 不全摊开',allAgg:'三类全聚合 · 都进 feed'}[m]));}

// ── 收起 / 展开 + 边缘提示 ──
const vzEl=$('vz');
let edgeFadeT=null;
function setEdgeClass(){
  const eh=$('edgeHint');
  if(FAULTS.length)eh.className='edge-hint show sev-fault';
  else if(MAINTS.length)eh.className='edge-hint show sev-maint';
  else eh.className='edge-hint show sev-none';
}
// 闪烁几秒后自动停下、淡出(不一直闪太吓人);边缘细条仍可点开
function flashEdge(){
  setEdgeClass();
  const bar=$('edgeHint').querySelector('.eh-bar');
  bar.style.transition='none';bar.style.opacity='';bar.style.boxShadow='';
  bar.style.animation='none';void bar.offsetWidth;bar.style.animation='';   // 重启闪烁
  if(edgeFadeT)clearTimeout(edgeFadeT);
  edgeFadeT=setTimeout(()=>{                                                 // ~3.6s 后停下并淡出
    bar.style.transition='opacity .9s ease,box-shadow .9s ease';
    bar.style.animation='none';bar.style.opacity='0';bar.style.boxShadow='none';
  },3600);
}
function clearEdge(){
  if(edgeFadeT){clearTimeout(edgeFadeT);edgeFadeT=null;}
  const bar=$('edgeHint').querySelector('.eh-bar');if(bar)bar.removeAttribute('style');
  $('edgeHint').className='edge-hint';
}
function collapseFeed(){
  if(collapsed)return;collapsed=true;
  vzEl.style.transition='transform .42s cubic-bezier(.4,.05,.3,1),opacity .42s';
  vzEl.style.transform='translateX(-118%)';vzEl.style.opacity='0';vzEl.style.pointerEvents='none';
  stage.classList.remove('mapright');     // 地图滑回左侧填充
  flashEdge();
  reply(FAULTS.length?'已收起 · 有重要通知,在左边缘提示你':'已收起 · 左边缘可展开');
  phase('feed 收起 · 边缘保留重要提示');
}
function restoreFeed(){
  if(!collapsed)return;collapsed=false;
  vzEl.style.transition='transform .42s cubic-bezier(.2,.7,.2,1),opacity .42s';
  vzEl.style.transform='';vzEl.style.opacity='';vzEl.style.pointerEvents='';
  stage.classList.add('mapright');
  clearEdge();
  phase('feed 已展开');clearReply();
}
$('edgeHint').onclick=restoreFeed;

// 单指左滑手势
let dx0=null,dragging=false;
vzEl.addEventListener('pointerdown',e=>{if(collapsed)return;dx0=e.clientX;dragging=false;});
vzEl.addEventListener('pointermove',e=>{
  if(dx0==null)return;const dx=(e.clientX-dx0)/__sc;
  if(!dragging&&Math.abs(dx)>8){dragging=true;vzEl.style.transition='none';try{vzEl.setPointerCapture(e.pointerId);}catch(_){}}
  if(dragging){const t=Math.min(0,dx);vzEl.style.transform=`translateX(${t}px)`;vzEl.style.opacity=String(Math.max(.15,1+t/360));}
});
function endDrag(e){
  if(dx0==null)return;const dx=(e.clientX-dx0)/__sc,wasDrag=dragging;dx0=null;dragging=false;vzEl.style.transition='';
  if(wasDrag){ if(dx<-70)collapseFeed(); else {vzEl.style.transform='';vzEl.style.opacity='';} }
}
vzEl.addEventListener('pointerup',endDrag);
vzEl.addEventListener('pointercancel',endDrag);

// ── live 演示 ──
function addSys(n){
  SYS.unshift(n);render();
  const c=$('cnt-sys');if(c){c.classList.add('bump');setTimeout(()=>c.classList.remove('bump'),260);}
  const g=$('grp-sys');if(g){g.classList.add('flash');setTimeout(()=>g.classList.remove('flash'),1100);}
  reply('一条系统通知,已折叠进「系统通知」,不打扰');phase('系统通知 → 聚合(最低优先级)');
  if(collapsed)flashEdge();
}
function addFault(n){
  mode='priority';FAULTS.unshift(n);render();syncModeBtns();
  const top=$('track').querySelector('.ncard');if(top){top.classList.add('attn');setTimeout(()=>top.classList.remove('attn'),3200);}
  $('avatar').classList.add('awake');
  reply('⚠️ 检测到'+n.t+',已置顶提醒');phase('车辆故障(IC)→ 置顶 · 最高优先级');
  if(collapsed)flashEdge();
}
function addMaint(n){mode='priority';MAINTS.push(n);render();syncModeBtns();reply('车辆保养提醒,已排在推荐之前');phase('车辆保养 → 高优先级');if(collapsed)flashEdge();}

function reset(){
  clearT();resetData();mode='priority';collapsed=false;
  vzEl.removeAttribute('style');stage.classList.add('mapright');clearEdge();
  $('avatar').classList.remove('awake');clearReply();render();syncModeBtns();phase('待机 · 已按重要程度聚合');
}

function playAll(){
  reset();
  at(1500,()=>addSys({ic:'⬇️',t:'「高德地图」更新完成 v12.3',s:'刚刚'}));          // 系统 → 聚合(不抢位)
  at(3300,()=>addFault({ic:'⚠️',t:'左前胎压偏低 2.1bar',s:'低于推荐 2.4bar · 建议尽快充气',act:'查看'}));  // 故障 → 置顶
  at(6300,()=>collapseFeed());                                                  // 单指左滑收起 → 红色边缘提示
  at(9400,()=>restoreFeed());
  at(11200,()=>setMode('vehAgg'));                                              // 车辆通知也聚合,不全摊开
  at(14200,()=>setMode('allAgg'));                                              // 三类都进 feed
  at(16600,()=>phase('演示结束 · 可左滑收起 / 切换三种视图'));
}
$('bAll').onclick=playAll;
$('mPri').onclick=()=>setMode('priority');
$('mVeh').onclick=()=>setMode('vehAgg');
$('mAll').onclick=()=>setMode('allAgg');
$('bCollapse').onclick=()=>collapsed?restoreFeed():collapseFeed();
$('bFault').onclick=()=>addFault({ic:'⚠️',t:'左前胎压偏低 2.1bar',s:'低于推荐 2.4bar · 建议尽快充气',act:'查看'});
$('bSys').onclick=()=>addSys({ic:'✅',t:'「CarPlay」连接成功',s:'刚刚'});
$('bIdle').onclick=reset;
setTimeout(playAll,700);
</script>

<script>
(function(){
  var orb=document.getElementById('mvaOrb');if(!orb)return;
  var stage=document.querySelector('.stage');
  var watch=[document.querySelector('.voice-zone'),document.querySelector('.statusbar')].filter(Boolean);
  var busy=true,settleT=null;
  function en(on){orb.classList.toggle('busy',!on);}
  function settle(){busy=false;en(true);}
  function bump(){busy=true;en(false);clearTimeout(settleT);settleT=setTimeout(settle,1200);}
  try{var obs=new MutationObserver(bump);watch.forEach(function(n){obs.observe(n,{childList:true,subtree:true,characterData:true,attributes:true,attributeFilter:['class','style']});});}catch(e){}
  bump();
  orb.onclick=function(){if(busy)return;stage.classList.toggle('zone-hidden');};
})();
</script>
</body>
</html>
