<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Mercedes-Benz · Voice Zone · Rainy Weather (Local · Full View)</title>
<!--
  场景：用户问天气 → 左上【语音区】里长出一块毛玻璃天气卡（地图卡被推右）
        → 卡内：先下雨（canvas 雨丝）→ 雨势转小、玻璃凝结水雾、水珠挂壁滑落拖清痕（变湿润）。
  雨只发生在语音区这块卡里（局部），整块车机界面保持完整可见、不放大。
-->
<style>
  :root{
    --sky-top:#d6ecf7; --sky-mid:#c4e3f3; --ground:#cdd1d6; --ground-low:#bfc3c8;
    --card-bg:rgba(255,255,255,.46); --card-bd:rgba(255,255,255,.55);
    --ink:#23262b; --ink-soft:rgba(35,38,43,.55); --ink-faint:rgba(35,38,43,.4);
    --blue:#2f6bff; --vz-w:392px;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{height:100%;background:#0e0f12;overflow:hidden;
    font-family:"PingFang SC","Microsoft YaHei",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
    -webkit-font-smoothing:antialiased;color:var(--ink)}
  .viewport{position:fixed;inset:0;display:flex;align-items:center;justify-content:center}
  .stage{position:relative;width:1300px;height:812px;overflow:hidden;transform-origin:center center;
    border-radius:18px;box-shadow:0 40px 120px rgba(0,0,0,.55);
    background:linear-gradient(180deg,var(--sky-top) 0%,var(--sky-mid) 26%,#cdd9dd 46%,var(--ground) 64%,var(--ground-low) 100%)}
  .hero{position:absolute;left:0;top:150px;width:1300px;height:430px;
    background:url("flyme-hero.jpg") center/cover no-repeat;
    -webkit-mask-image:linear-gradient(180deg,transparent 0,#000 16%,#000 80%,transparent 100%);
            mask-image:linear-gradient(180deg,transparent 0,#000 16%,#000 80%,transparent 100%)}

  /* chrome */
  .statusbar{position:absolute;top:0;left:0;right:0;height:50px;display:flex;align-items:center;justify-content:space-between;padding:0 24px;z-index:55}
  .sb-left{display:flex;align-items:center;gap:13px;flex:1;min-width:0;height:100%;padding-right:24px}
  .avatar{width:36px;height:36px;border-radius:50%;flex:none;position:relative;background-image:linear-gradient(135deg,#f3c9b0,#cf9d86);box-shadow:inset 0 0 0 1.5px rgba(255,255,255,.7);transition:box-shadow .5s}
  .avatar::before{content:"";position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);filter:blur(1px);opacity:0;transition:opacity .55s;animation:spin 5s linear infinite}
  .avatar::after{content:"";position:absolute;inset:7px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.6));box-shadow:0 0 14px rgba(255,255,255,.55);opacity:0;transition:opacity .55s}
  .avatar.awake{box-shadow:none;animation:breathe 3.2s ease-in-out infinite}
  .avatar.awake::before,.avatar.awake::after{opacity:1}
  .sb-voice{position:relative;display:flex;align-items:center;min-width:0;height:100%}
  .sv-asr{display:inline-flex;align-items:center;max-width:600px;overflow:hidden;white-space:nowrap;font-size:15.5px;font-weight:600;color:var(--ink);opacity:0;transition:opacity .35s,transform .4s,filter .4s}
  .sv-asr.show{opacity:1}.sv-asr.done{color:#3a9d54}.sv-asr.gone{opacity:0;transform:translateY(-7px);filter:blur(2px)}
  .sv-cur{display:inline-block;width:2px;height:16px;background:#3a9d54;margin-left:2px;animation:blink 1s step-end infinite}
  .sv-reply{font-size:15.5px;font-weight:600;color:#1c2228;white-space:nowrap;opacity:0;transform:translateY(4px);transition:opacity .45s,transform .45s;text-shadow:0 1px 10px rgba(255,255,255,.85)}
  .sv-reply.show{opacity:1;transform:none}
  .sb-right{display:flex;align-items:center;gap:16px;flex:none}
  @keyframes blink{50%{opacity:0}}
  .sb-clock{font-size:19px;font-weight:500;letter-spacing:.5px}.sb-5g{font-size:10px;font-weight:700;vertical-align:top;margin-right:1px}
  .map{position:absolute;top:64px;left:40px;width:300px;border-radius:20px;background:rgba(70,78,86,.34);
    backdrop-filter:blur(22px) saturate(1.2);-webkit-backdrop-filter:blur(22px) saturate(1.2);
    box-shadow:0 8px 30px rgba(40,50,60,.18),inset 0 0 0 1px rgba(255,255,255,.18);overflow:hidden;z-index:25;color:#fff;
    transition:transform .42s cubic-bezier(.2,.7,.2,1)}
  .stage.voice-on .map{transform:translateX(calc(var(--vz-w) + 16px))}
  .map-top{display:flex;align-items:center;gap:9px;padding:14px 16px}.map-top .t{flex:1;font-size:16px;font-weight:500}
  .map-quick{display:flex;background:rgba(20,24,28,.28)}
  .map-quick div{flex:1;display:flex;align-items:center;justify-content:center;padding:12px 0;opacity:.9}
  .map-quick div+div{box-shadow:inset 1px 0 0 rgba(255,255,255,.1)}
  .weather{position:absolute;top:60px;right:36px;text-align:right;z-index:25}
  .weather .temp{font-size:60px;font-weight:200;line-height:.9;letter-spacing:-1px}
  .weather .temp sup{font-size:20px;font-weight:300;vertical-align:top;margin-left:2px}
  .weather .loc{font-size:15px;color:var(--ink-soft);margin-top:6px}
  .cards{position:absolute;left:40px;right:40px;bottom:84px;display:flex;gap:16px;z-index:15}
  .card{flex:1;height:96px;border-radius:18px;background:var(--card-bg);backdrop-filter:blur(20px) saturate(1.3);-webkit-backdrop-filter:blur(20px) saturate(1.3);
    box-shadow:0 8px 26px rgba(40,50,60,.12),inset 0 0 0 1px var(--card-bd);display:flex;align-items:center;gap:13px;padding:0 18px}
  .card .ic{width:42px;height:42px;border-radius:11px;flex:none;display:flex;align-items:center;justify-content:center;font-size:20px;background:linear-gradient(135deg,#fff,#eef1f4);box-shadow:0 2px 6px rgba(0,0,0,.06)}
  .card .ic.pink{background:linear-gradient(135deg,#ff7a9c,#ff5277);color:#fff}
  .card .big{font-size:18px;font-weight:600}.card .sub{font-size:12px;color:var(--ink-soft);margin-top:3px}.card .lnk{color:var(--blue);font-weight:600}
  .card .col2{display:flex;gap:18px;width:100%}
  .tyre{display:flex;flex-direction:column;gap:4px;font-size:12px;color:var(--ink-soft);width:100%}
  .tyre .r{display:flex;justify-content:space-between}.tyre .car{align-self:center;width:26px;height:14px;border-radius:5px;background:rgba(35,38,43,.18);margin:1px 0}
  .dock{position:absolute;left:0;right:0;bottom:0;height:72px;z-index:30;display:flex;align-items:center;gap:18px;padding:0 22px;
    background:rgba(248,250,252,.5);backdrop-filter:blur(26px) saturate(1.3);-webkit-backdrop-filter:blur(26px) saturate(1.3);box-shadow:inset 0 1px 0 rgba(255,255,255,.6)}
  .dock .home{width:34px;height:34px;border-radius:50%;box-shadow:inset 0 0 0 2px rgba(35,38,43,.55);flex:none}
  .np{display:flex;align-items:center;gap:11px;width:230px}.np .cov{width:40px;height:40px;border-radius:9px;flex:none;background:linear-gradient(135deg,#ffb37a,#ff7eb0,#9b8cff)}
  .np .ti{font-size:14px;font-weight:600;line-height:1.25}.np .ar{font-size:11px;color:var(--ink-soft)}.np .pause{margin-left:auto;font-size:16px;color:var(--ink-soft)}
  .dock .sep{flex:1}.dock .ctrl{display:flex;align-items:center;gap:24px;color:rgba(35,38,43,.7)}
  .dock .ctrl .temp{display:flex;align-items:center;gap:9px;font-size:21px;font-weight:600;color:var(--ink)}
  .dock .ctrl .temp small{font-size:12px;color:var(--ink-soft)}.dock .ctrl .chev{font-size:13px;color:var(--ink-faint)}.dock .ctrl .it{font-size:19px;font-weight:600}

  /* ── 语音区（左上原小窗位）── */
  .voice-zone{position:absolute;left:40px;top:64px;z-index:36;width:var(--vz-w);display:flex;flex-direction:column;gap:12px;
    transition:width .35s cubic-bezier(.2,.7,.2,1)}
  .wreply{display:flex;align-items:center;gap:11px;opacity:0;transform:translateY(4px);transition:opacity .5s,transform .5s}
  .wreply.show{opacity:1;transform:none}
  .aicy{width:40px;height:40px;border-radius:50%;flex:none;position:relative;animation:breathe 3.4s ease-in-out infinite}
  .aicy::before{content:"";position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);filter:blur(1px);animation:spin 5s linear infinite}
  .aicy::after{content:"";position:absolute;inset:8px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.6));box-shadow:0 0 14px rgba(255,255,255,.55)}
  @keyframes spin{to{transform:rotate(360deg)}}@keyframes breathe{0%,100%{transform:scale(1)}50%{transform:scale(1.07)}}
  .wreply-t{font-size:15px;font-weight:500;color:#1c2228;line-height:1.45;text-shadow:0 1px 10px rgba(255,255,255,.85),0 1px 2px rgba(255,255,255,.9)}
  .listen{display:flex;align-items:center;gap:11px;opacity:0;transition:opacity .35s}.listen.show{opacity:1}
  .listen .bubble{background:rgba(255,255,255,.55);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);box-shadow:inset 0 0 0 1px rgba(255,255,255,.6);border-radius:16px;padding:13px 17px;font-size:15px;color:var(--ink)}
  .eq{display:inline-flex;gap:3px;align-items:flex-end;height:14px;margin-left:2px}
  .eq i{width:3px;background:var(--blue);border-radius:2px;animation:eq 1s ease-in-out infinite}
  .eq i:nth-child(2){animation-delay:.15s}.eq i:nth-child(3){animation-delay:.3s}.eq i:nth-child(4){animation-delay:.45s}
  @keyframes eq{0%,100%{height:4px}50%{height:14px}}

  /* ── 毛玻璃天气卡（雨/雾/水珠都在卡内）── */
  .wcard{position:relative;width:100%;border-radius:22px;overflow:hidden;max-height:0;opacity:0;transform:translateY(-6px);
    background:linear-gradient(165deg,rgba(46,62,84,.5),rgba(64,80,102,.4));
    backdrop-filter:blur(18px) saturate(1.15) brightness(1.02);-webkit-backdrop-filter:blur(18px) saturate(1.15) brightness(1.02);
    box-shadow:0 18px 50px rgba(20,30,45,.4),inset 0 1px 0 rgba(255,255,255,.4),inset 0 0 0 1px rgba(255,255,255,.14);
    transition:max-height .75s cubic-bezier(.2,.8,.2,1),opacity .55s,transform .55s,background .6s}
  .wcard.formed{max-height:340px;opacity:1;transform:none}
  .wcard.wet{background:linear-gradient(165deg,rgba(30,42,60,.66),rgba(44,58,80,.56));
    backdrop-filter:blur(24px) saturate(1.1) brightness(.86);-webkit-backdrop-filter:blur(24px) saturate(1.1) brightness(.86)}
  .wcard.sunny{background:linear-gradient(165deg,rgba(120,170,225,.42),rgba(180,205,235,.36))}
  .wcard canvas{position:absolute;inset:0;width:100%;height:100%;pointer-events:none}
  .wcard .rain{z-index:3}.wcard .spec{z-index:2}.wcard .fog{z-index:1}
  .wc-content{position:relative;z-index:4;padding:20px 22px 18px;color:#fff;opacity:0;transform:translateY(8px);transition:opacity .6s .15s,transform .6s .15s}
  .wc-content.show{opacity:1;transform:none}
  .wc-head{display:flex;align-items:center;justify-content:space-between}
  .wc-loc{font-size:15px;font-weight:600;letter-spacing:.02em;opacity:.95}
  .wc-cond{font-size:14px;font-weight:500;padding:4px 12px;border-radius:20px;background:rgba(255,255,255,.18);box-shadow:inset 0 0 0 1px rgba(255,255,255,.25)}
  .wc-temp{font-size:74px;font-weight:200;line-height:.95;margin:6px 0 2px;text-shadow:0 2px 24px rgba(0,0,0,.25)}
  .wc-temp sup{font-size:26px;font-weight:300;vertical-align:top}
  .wc-sub{font-size:13.5px;opacity:.82}
  .wc-hours{display:flex;justify-content:space-between;gap:6px;margin-top:16px;padding-top:14px;border-top:1px solid rgba(255,255,255,.16)}
  .hr{display:flex;flex-direction:column;align-items:center;gap:7px;flex:1}
  .hr .h{font-size:12px;opacity:.7}.hr .v{font-size:14px;font-weight:600}.hr svg{opacity:.92}
  .hr .pp{width:100%;height:3px;border-radius:2px;background:rgba(255,255,255,.18);overflow:hidden}
  .hr .pp i{display:block;height:100%;background:#8fc6ff;border-radius:2px}

  /* 面板 */
  .panel{position:fixed;top:18px;right:18px;width:248px;z-index:100;background:rgba(20,22,26,.88);
    backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-radius:16px;padding:15px;color:#e8eaee;font-size:12.5px;
    box-shadow:0 20px 50px rgba(0,0,0,.5),inset 0 0 0 1px rgba(255,255,255,.08)}
  .panel .title{font-size:13.5px;font-weight:700;color:#fff;display:flex;align-items:center;gap:7px;margin-bottom:13px}
  .panel .title i{width:8px;height:8px;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#ff6b9b,#ffab5b,#5b8cff)}
  .ask{width:100%;border:0;border-radius:12px;cursor:pointer;font-family:inherit;font-weight:600;font-size:13.5px;padding:13px;color:#fff;
    background:linear-gradient(135deg,#3b78ff,#2f6bff);box-shadow:0 6px 18px rgba(47,107,255,.45);transition:.15s;display:flex;align-items:center;justify-content:center;gap:8px}
  .ask:hover{filter:brightness(1.08)}.ask:active{transform:translateY(1px)}
  .panel h4{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:#9aa0a8;font-weight:700;margin:15px 0 7px}
  .seg{display:flex;gap:5px}
  .seg button{flex:1;padding:8px 4px;border:0;border-radius:9px;cursor:pointer;background:rgba(255,255,255,.08);color:#cfd3d9;font-size:12px;font-weight:600;transition:.15s;font-family:inherit}
  .seg button:hover{background:rgba(255,255,255,.15)}.seg button.on{background:var(--blue);color:#fff;box-shadow:0 2px 10px rgba(47,107,255,.5)}
  .row-tog{display:flex;align-items:center;justify-content:space-between;margin-top:10px}
  .sw{width:40px;height:23px;border-radius:12px;background:rgba(255,255,255,.16);position:relative;cursor:pointer;transition:.2s;flex:none}
  .sw::after{content:"";position:absolute;top:2.5px;left:2.5px;width:18px;height:18px;border-radius:50%;background:#fff;transition:.2s}
  .sw.on{background:var(--blue)}.sw.on::after{left:19px}
  .phase{margin-top:13px;font-size:11px;color:#8b9098;border-top:1px solid rgba(255,255,255,.08);padding-top:10px}.phase b{color:#ffce8a}
  /* 演示控制台：默认弱化半透明、略缩小，悬停恢复清晰（不抢演示效果） */
  .panel{opacity:.3;transform:scale(.86);transform-origin:top right;transition:opacity .3s ease,transform .3s ease}
  .panel:hover{opacity:1;transform:scale(1)}

  /* 全局：底栏 MVA 光球（语音区收起时的最小化态 · 点击唤起；区域展开时淡出）*/
  .mva-orb{width:38px;height:38px;border-radius:50%;flex:none;border:0;padding:0;cursor:pointer;position:relative;background:radial-gradient(circle at 38% 34%,#2a3340,#11161f);transition:transform .15s,opacity .35s}
  .mva-orb::before{content:"";position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);filter:blur(.6px);animation:mvaspin 6s linear infinite}
  .mva-orb::after{content:"";position:absolute;inset:7px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.62));box-shadow:0 0 11px rgba(255,255,255,.5)}
  .mva-orb:hover{transform:scale(1.06)}.mva-orb:active{transform:scale(.93)}
  .stage.voice-on .mva-orb{opacity:.4}
  .mva-orb.busy{opacity:.26 !important;pointer-events:none;filter:saturate(.55)}
  .stage.zone-hidden .voice-zone{opacity:0 !important;transform:translateY(-10px) scale(.985) !important;pointer-events:none !important;transition:opacity .35s ease,transform .35s ease}
  .stage.zone-hidden .map{transform:none !important}
  @keyframes mvaspin{to{transform:rotate(360deg)}}
</style>
</head>
<body>
<div class="viewport">
  <div class="stage" id="stage">
    <div class="hero"></div>

    <div class="statusbar">
      <div class="sb-left">
        <div class="avatar" id="avatar"></div>
        <div class="sb-voice">
          <span class="sv-asr" id="svAsr"><span id="asrText"></span><span class="sv-cur" id="asrCur"></span></span>
          <span class="sv-reply" id="wreplyt"></span>
        </div>
      </div>
      <div class="sb-right">
        <svg width="15" height="18" viewBox="0 0 15 18"><path d="M3 5l9 8-4.5 4V1L12 5 3 13" fill="none" stroke="#23262b" stroke-width="1.6" stroke-linejoin="round"/></svg>
        <span><sup class="sb-5g">5G</sup>
          <svg width="22" height="16" viewBox="0 0 22 16" style="vertical-align:middle">
            <rect x="0" y="11" width="3.4" height="5" rx="1" fill="#23262b"/><rect x="5.2" y="8" width="3.4" height="8" rx="1" fill="#23262b"/>
            <rect x="10.4" y="5" width="3.4" height="11" rx="1" fill="#23262b"/><rect x="15.6" y="2" width="3.4" height="14" rx="1" fill="#23262b"/></svg></span>
        <svg width="20" height="16" viewBox="0 0 20 16"><path d="M2 6h4l5-4v12l-5-4H2z" fill="#23262b"/><path d="M14 5c1.5 1.2 1.5 4.8 0 6M16.5 3c2.8 2 2.8 8 0 10" fill="none" stroke="#23262b" stroke-width="1.4" stroke-linecap="round"/></svg>
        <span class="sb-clock">13:12</span>
      </div>
    </div>

    <div class="map">
      <div class="map-top"><span>📍</span><span class="t">Map</span>
        <svg width="18" height="18" viewBox="0 0 18 18"><circle cx="7.5" cy="7.5" r="5.5" fill="none" stroke="#fff" stroke-width="1.6"/><path d="M12 12l4 4" stroke="#fff" stroke-width="1.6" stroke-linecap="round"/></svg></div>
      <div class="map-quick"><div>⌂</div><div>☰</div><div>★</div><div>⚡</div></div>
    </div>
    <div class="weather"><div class="temp">18<sup>°C</sup></div><div class="loc">Shanghai &nbsp; Sunny</div></div>

    <!-- ★ 语音区：雨只在这块卡里 ★ -->
    <div class="voice-zone" id="vz">
      <div class="wcard" id="wcard">
        <canvas class="spec" id="cspec"></canvas>
        <canvas class="rain" id="crain"></canvas>
        <div class="wc-content" id="wcontent">
          <div class="wc-head"><span class="wc-loc">Shanghai · Tomorrow</span><span class="wc-cond" id="wcond">Moderate Rain</span></div>
          <div class="wc-temp"><span id="wtemp">16</span><sup>°</sup></div>
          <div class="wc-sub" id="wsub">Feels like 14° · Rain 80% · E Wind Force 3</div>
          <div class="wc-hours" id="whours"></div>
        </div>
      </div>
    </div>

    <div class="dock">
      <button class="mva-orb" id="mvaOrb" title="MVA · Wake Voice Zone"></button>
      <div class="np"><div class="cov"></div><div><div class="ti">Infinite Passion</div><div class="ar">Suker Wong</div></div><div class="pause">❙❙</div></div>
      <div class="sep"></div>
      <div class="ctrl"><div class="it">❄</div><div class="temp"><span class="chev">‹</span>23.5<small>°</small><span class="chev">›</span></div>
        <div class="it">🚘</div><div class="it">⚡</div><div class="it">360</div><div class="it">📞</div><div class="it">▦</div></div>
    </div>
  </div>
</div>

<audio id="rainAudio" loop preload="auto">
  <source src="rain-loop.m4a" type="audio/mp4">
  <source src="rain-loop.ogg" type="audio/ogg">
</audio>

<div class="panel">
  <div class="title"><i></i>Voice Zone Rain · Local Scene</div>
  <button class="ask" id="ask">🎤 "Will it rain tomorrow?"</button>
  <h4>Weather</h4>
  <div class="seg" id="seg-wx"><button data-wx="rain" class="on">Rain</button><button data-wx="sun">Sunny</button></div>
  <h4>Rain Intensity</h4>
  <div class="seg" id="seg-i"><button data-i="0.6">Light Rain</button><button data-i="1" class="on">Moderate Rain</button><button data-i="1.5">Heavy Rain</button></div>
  <h4>Desktop Sync</h4>
  <div class="row-tog"><span>Voice Zone (push map)</span><div class="sw on" id="sw-show"></div></div>
  <div class="row-tog"><span>🔊 Rain Ambience (by intensity)</span><div class="sw on" id="sw-sound"></div></div>
  <div class="phase">Phase: <b id="phlabel">Standby</b> · Card height <b id="hlabel" style="color:#fff">-</b></div>
</div>

<script>
const stage=document.getElementById('stage');
function fit(){stage.style.transform=`scale(${Math.min(innerWidth/1300,innerHeight/812)*0.985})`;}
addEventListener('resize',fit);fit();
const $=id=>document.getElementById(id);

const HRS=[['Now',16,.8],['14',16,.85],['15',17,.6],['16',18,.35],['17',17,.5],['18',16,.7]];
const dropSVG='<svg width="16" height="16" viewBox="0 0 16 16"><path d="M8 2.5C8 2.5 4 7 4 9.6A4 4 0 0 0 12 9.6C12 7 8 2.5 8 2.5Z" fill="none" stroke="#bfe0ff" stroke-width="1.3"/></svg>';
document.getElementById('whours').innerHTML=HRS.map(([h,t,p])=>
  `<div class="hr"><span class="h">${h}</span>${dropSVG}<span class="v">${t}°</span><span class="pp"><i style="width:${Math.round(p*100)}%"></i></span></div>`).join('');

// 雨丝（卡内）
function makeRain(c){const x=c.getContext('2d');let W,H,d,drops=[];let I=0;
  function resize(){d=Math.min(devicePixelRatio||1,1.5);W=c.clientWidth;H=c.clientHeight;c.width=W*d;c.height=H*d;x.setTransform(d,0,0,d,0,0);}
  function frame(){x.clearRect(0,0,W,H);if(W<2)return;
    const n=Math.round(I*3.2);for(let i=0;i<n;i++)drops.push({x:Math.random()*W*1.12-W*.06,y:-18,len:7+Math.random()*12*I,sp:2.2+Math.random()*2.4,a:.07+Math.random()*.18,w:.6+Math.random()*.9});
    x.lineCap='round';
    for(const p of drops){x.strokeStyle=`rgba(206,224,238,${p.a})`;x.lineWidth=p.w;x.beginPath();x.moveTo(p.x,p.y);x.lineTo(p.x-1.5,p.y-p.len);x.stroke();p.y+=p.sp;p.x-=.28;}
    drops=drops.filter(p=>p.y<H+p.len);}
  return{resize,frame,set i(v){I=v},get i(){return I}};
}
// 真实折射水珠（采样真实桌面图）
const heroImg=new Image();let heroOK=false;heroImg.onload=()=>heroOK=true;heroImg.src='flyme-hero.jpg';
function makeWet(c){const s=c.getContext('2d');let W,H,d,statics=[],sliders=[],w=0;
  function resize(){d=Math.min(devicePixelRatio||1,1.6);W=c.clientWidth;H=c.clientHeight;c.width=W*d;c.height=H*d;s.setTransform(d,0,0,d,0,0);seed();}
  function seed(){statics=[];const n=Math.min(120,Math.max(0,Math.round(W*H/2900)));
    for(let i=0;i<n;i++){const b=Math.random();statics.push({x:Math.random()*W,y:Math.random()*H,r:1.4+Math.pow(b,2.1)*7.5,t:Math.random()*.6,fx:Math.random(),fy:Math.random()});}}
  function lens(o,a){const r=o.r;
    s.save();s.beginPath();s.arc(o.x,o.y,r*.9,0,7);s.clip();
    if(heroOK){const sw=heroImg.width*.085,sh=heroImg.height*.12;
      const ix=heroImg.width*(.16+o.fx*.62),iy=heroImg.height*(.24+o.fy*.5);
      s.globalAlpha=a;s.translate(o.x,o.y);s.scale(1,-1);            // 倒置（透镜折射）
      s.drawImage(heroImg,ix-sw/2,iy-sh/2,sw,sh,-r,-r,r*2,r*2);
      s.setTransform(d,0,0,d,0,0);s.globalAlpha=1;}
    else{s.fillStyle=`rgba(206,220,236,${.5*a})`;s.fillRect(o.x-r,o.y-r,r*2,r*2);}
    s.restore();}
  function drawDrop(o,a){const r=o.r,x=o.x,y=o.y;
    s.fillStyle=`rgba(8,14,24,${.24*a})`;s.beginPath();s.ellipse(x+r*.12,y+r*.5,r*.92,r*.82,0,0,7);s.fill();   // 投影
    lens(o,a);                                                                                                  // 折射镜体
    const g=s.createRadialGradient(x,y+r*.34,r*.05,x,y,r);                                                       // 体内明暗
    g.addColorStop(0,`rgba(255,255,255,${.12*a})`);g.addColorStop(.6,'rgba(255,255,255,0)');g.addColorStop(1,`rgba(5,11,20,${.24*a})`);
    s.fillStyle=g;s.beginPath();s.arc(x,y,r*.9,0,7);s.fill();
    s.lineWidth=Math.max(.7,r*.14);s.strokeStyle=`rgba(255,255,255,${.5*a})`;s.beginPath();s.arc(x,y,r*.82,Math.PI*1.04,Math.PI*2.12);s.stroke();  // 菲涅尔亮边（上缘）
    s.fillStyle=`rgba(255,255,255,${.92*a})`;s.beginPath();s.arc(x-r*.3,y-r*.34,Math.max(.6,r*.2),0,7);s.fill();}                                   // 镜面高光
  function frame(){s.clearRect(0,0,W,H);if(w<=.01)return;
    if(Math.random()<.009*w&&sliders.length<2)sliders.push({x:12+Math.random()*(W-24),y:Math.random()*H*.22,r:6.5+Math.random()*5,v:.1,fx:Math.random(),fy:Math.random()});
    for(const dd of sliders){dd.v=Math.min(dd.v+.009,.6+dd.r*.035);dd.y+=dd.v;
      if(Math.random()<.08&&statics.length<170)statics.push({x:dd.x+(Math.random()-.5)*dd.r*2.2,y:dd.y-dd.r,r:1+Math.random()*2,t:0,fx:dd.fx,fy:dd.fy});}  // 滑落留稀疏珠痕
    sliders=sliders.filter(dd=>dd.y<H+14);
    for(const st of statics){const a=st.t?Math.max(0,Math.min(1,(w-st.t)/.25)):w;if(a>.01)drawDrop(st,a);}      // 渐次凝结成形
    for(const dd of sliders)drawDrop(dd,w);}
  return{resize,frame,set w(v){w=v;},get w(){return w;}};
}

const rain=makeRain($('crain')), wet=makeWet($('cspec'));
const wcard=$('wcard');
new ResizeObserver(()=>{rain.resize();wet.resize();}).observe(wcard);

const ORDER=['listening','forming','raining','wetting','wet'];
const DUR={listening:1300,forming:1000,raining:2600,wetting:3600,wet:1e9};
const LABEL={listening:'Listening',forming:'Glass Forming',raining:'Raining',wetting:'Condensing',wet:'Wet · Resting'};
let pi=0,pt=0,last=0,rt=0,wt=0,rI=0,wW=0,intensity=1,mode='rain',playing=false,aGain=0;
const rainAudio=document.getElementById('rainAudio');let soundOn=true;   // 雨声(随可视雨势实时渐入渐出)
let audioReady=false;
// 浏览器自动播放策略:必须由真实用户手势解锁音频。首次任意点击即解锁,之后循环播放、由音量随雨势调制。
function unlockAudio(){if(!rainAudio||audioReady)return;const p=rainAudio.play();if(p&&p.then)p.then(()=>{audioReady=true;}).catch(()=>{});}
window.addEventListener('pointerdown',unlockAudio);

function enter(p){
  $('phlabel').textContent=LABEL[p];
  const C=$('wcontent');
  if(p==='listening'){$('avatar').classList.add('awake');$('svAsr').style.display='';$('svAsr').className='sv-asr show';$('asrText').textContent='Will it rain tomorrow?';$('asrCur').style.display='';$('wreplyt').classList.remove('show');$('wreplyt').textContent='';C.classList.remove('show');wcard.classList.remove('formed','wet');rt=0;wt=0;
    stage.classList.remove('voice-on');}                                  // 还没内容 → 地图先不推
  if(p==='forming'){$('svAsr').classList.add('done');$('asrCur').style.display='none';wcard.classList.add('formed');rt=0;wt=0;
    if($('sw-show').classList.contains('on'))stage.classList.add('voice-on');}  // 卡片成形(内容出现) → 这时才把地图推开
  if(p==='raining'){$('svAsr').style.display='none';C.classList.add('show');wcard.classList.remove('wet');$('wreplyt').textContent='Moderate rain expected in Shanghai tomorrow - bring an umbrella!';$('wreplyt').classList.add('show');rt=1;wt=0;}
  if(p==='wetting'){wcard.classList.add('wet');$('wreplyt').textContent='The glass is fogging up - rain is falling outside.';rt=0;wt=1;}   // 雨停，凝水成形
  if(p==='wet'){rt=0;wt=1;}
}
function play(){pi=0;pt=0;playing=true;wet.w=0;rain.i=0;rI=0;wW=0;aGain=0;last=performance.now();enter('listening');}

function loop(now){const dt=now-last;last=now;
  if(playing){pt+=dt;if(pt>=DUR[ORDER[pi]]&&pi<ORDER.length-1){pi++;pt=0;enter(ORDER[pi]);}}
  const tgtR=(mode==='sun')?0:rt*intensity, tgtW=(mode==='sun')?0:wt;
  rI+=(tgtR-rI)*.045; wW+=(tgtW-wW)*.018;
  rain.i=Math.max(0,rI); wet.w=Math.max(0,wW);
  // 雨声音量跟随可视雨势(rI) → 下雨自然渐入、雨停渐出，营造沉浸感
  // 雨声增益:比可视雨势更快跟到位,下雨时清晰可闻;雨停渐隐
  aGain+=(((mode==='sun')?0:rt*Math.min(1,intensity))-aGain)*0.12;
  if(rainAudio&&audioReady){
    rainAudio.volume=soundOn?Math.max(0,Math.min(1,aGain*0.72)):0;
    if(soundOn&&rainAudio.paused)rainAudio.play().catch(()=>{});
  }
  rain.frame(); wet.frame();
  $('hlabel').textContent=wcard.offsetHeight+'px';
  requestAnimationFrame(loop);
}
requestAnimationFrame(loop);

$('ask').onclick=()=>{unlockAudio();play();};
function bindSeg(id,fn){const b=$(id);b.onclick=e=>{const t=e.target.closest('button');if(!t)return;[...b.children].forEach(x=>x.classList.remove('on'));t.classList.add('on');fn(t);};}
bindSeg('seg-wx',t=>{mode=t.dataset.wx;wcard.classList.toggle('sunny',mode==='sun');if(mode==='sun')wcard.classList.remove('wet');
  if(mode==='sun'){$('wcond').textContent='Sunny';$('wtemp').textContent='24';$('wsub').textContent='Feels like 25° · Rain 5% · S Wind Force 2';$('wreplyt').textContent='Shanghai will be sunny tomorrow - UV index is high, use sun protection.';
    document.querySelectorAll('#whours .pp i').forEach((i,k)=>i.style.width=[10,8,6,5,4,6][k]+'%');}
  else{$('wcond').textContent='Moderate Rain';$('wtemp').textContent='16';$('wsub').textContent='Feels like 14° · Rain 80% · E Wind Force 3';
    document.querySelectorAll('#whours .pp i').forEach((i,k)=>i.style.width=Math.round(HRS[k][2]*100)+'%');}
});
bindSeg('seg-i',t=>{intensity=+t.dataset.i;});
$('sw-show').onclick=function(){this.classList.toggle('on');const on=this.classList.contains('on');stage.classList.toggle('voice-on',on);$('vz').style.display=on?'':'none';};
$('sw-sound').onclick=function(){unlockAudio();this.classList.toggle('on');soundOn=this.classList.contains('on');if(!soundOn&&rainAudio)rainAudio.pause();};

setTimeout(play,500);
</script>

<script>
(function(){
  var orb=document.getElementById('mvaOrb');if(!orb)return;
  var stage=document.querySelector('.stage');
  var watch=[document.querySelector('.voice-zone'),document.querySelector('.statusbar')].filter(Boolean);
  var busy=true,settleT=null;
  function en(on){orb.classList.toggle('busy',!on);}
  function settle(){busy=false;en(true);}
  function bump(){busy=true;en(false);clearTimeout(settleT);settleT=setTimeout(settle,1200);}
  try{var obs=new MutationObserver(bump);watch.forEach(function(n){obs.observe(n,{childList:true,subtree:true,characterData:true,attributes:true,attributeFilter:['class','style']});});}catch(e){}
  bump();
  orb.onclick=function(){if(busy)return;stage.classList.toggle('zone-hidden');};
})();
</script>
</body>
</html>
