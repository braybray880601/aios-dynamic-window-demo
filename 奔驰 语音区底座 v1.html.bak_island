<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>奔驰 · 无框语音区底座 v1</title>
<!--
  ── 设计假设 / reasoning（Junior pass）──────────────────────────────
  1. 比例：还原 奔驰 真实车机 = 15.4" 悬浮横屏 2560×1600（16:10）。
     逻辑画布用 1300×812，等比缩放铺满窗口、letterbox。
  2. 背景：直接用从官方桌面（领克08 · 3D车模/时光引擎主题）裁出的真实场景图
     flyme-hero.jpg（蓝天+车模+建筑+浅灰地面），上下边缘用 mask 融进 CSS 天空/地面渐变。
  3. chrome：状态栏 / 左上「地图」磨砂卡 / 右上大字号天气 / 底部 4 张磨砂信息卡 / 全宽 Dock —— 都按实拍复刻。
  4. ★核心改动★：原本的"语音小窗"被替换成一块
     —— 宽度固定（可在面板切几档）、高度随内容自适应、且【没有任何框线/卡片底】的区域。
     内容直接长在桌面背景上。这块就是你之后填语音交互场景的画布。
  5. 场景先不做（按你说的）。语音区里现在放的是【中性占位】+ 实时高度读数，
     仅用来证明它"无框、宽固定、高不固定"。右上面板可调高度/宽度/可读衬底/参考线。
  ────────────────────────────────────────────────────────────────
-->
<style>
  :root{
    --sky-top:#d6ecf7; --sky-mid:#c4e3f3;
    --ground:#cdd1d6; --ground-low:#bfc3c8;
    --card-bg:rgba(255,255,255,.46); --card-bd:rgba(255,255,255,.55);
    --ink:#23262b; --ink-soft:rgba(35,38,43,.55); --ink-faint:rgba(35,38,43,.4);
    --blue:#2f6bff; --warm:#ff8a3c;
    --vz-w:380px;            /* 语音区固定宽度，可切换 */
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{height:100%;background:#0e0f12;overflow:hidden;
    font-family:"PingFang SC","Microsoft YaHei",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
    -webkit-font-smoothing:antialiased;color:var(--ink)}
  .viewport{position:fixed;inset:0;display:flex;align-items:center;justify-content:center}

  /* ── 1300×812 逻辑画布，JS 等比缩放 ── */
  .stage{position:relative;width:1300px;height:812px;overflow:hidden;
    transform-origin:center center;border-radius:18px;
    box-shadow:0 40px 120px rgba(0,0,0,.55);
    background:linear-gradient(180deg,var(--sky-top) 0%,var(--sky-mid) 26%,
      #cdd9dd 46%,var(--ground) 64%,var(--ground-low) 100%)}

  .hero{position:absolute;left:0;top:150px;width:1300px;height:430px;
    background:url("flyme-hero.jpg") center/cover no-repeat;
    -webkit-mask-image:linear-gradient(180deg,transparent 0,#000 16%,#000 80%,transparent 100%);
            mask-image:linear-gradient(180deg,transparent 0,#000 16%,#000 80%,transparent 100%)}

  /* ── 状态栏 ── */
  .statusbar{position:absolute;top:0;left:0;right:0;height:46px;display:flex;
    align-items:center;justify-content:space-between;padding:0 24px;z-index:30}
  .avatar{width:34px;height:34px;border-radius:50%;background:#caa;
    background-image:linear-gradient(135deg,#f3c9b0,#cf9d86);
    box-shadow:inset 0 0 0 1.5px rgba(255,255,255,.7)}
  .sb-right{display:flex;align-items:center;gap:16px}
  .sb-right svg{display:block;opacity:.82}
  .sb-clock{font-size:19px;font-weight:500;letter-spacing:.5px}
  .sb-5g{font-size:10px;font-weight:700;vertical-align:top;margin-right:1px}

  /* ── 左上 地图卡 ── */
  .map{position:absolute;top:64px;left:40px;width:300px;border-radius:20px;
    background:rgba(70,78,86,.34);backdrop-filter:blur(22px) saturate(1.2);
    -webkit-backdrop-filter:blur(22px) saturate(1.2);
    box-shadow:0 8px 30px rgba(40,50,60,.18),inset 0 0 0 1px rgba(255,255,255,.18);
    overflow:hidden;z-index:25;color:#fff;
    transition:transform .4s cubic-bezier(.2,.7,.2,1)}
  /* ★ 语音区出现时，地图卡被向右推 ★ */
  .stage.voice-on .map{transform:translateX(calc(var(--vz-w) + 16px))}
  .map-top{display:flex;align-items:center;gap:9px;padding:14px 16px}
  .map-top .pin{font-size:15px}
  .map-top .t{flex:1;font-size:16px;font-weight:500}
  .map-top .mag{opacity:.85}
  .map-quick{display:flex;background:rgba(20,24,28,.28)}
  .map-quick div{flex:1;display:flex;align-items:center;justify-content:center;
    padding:12px 0;opacity:.9}
  .map-quick div+div{box-shadow:inset 1px 0 0 rgba(255,255,255,.1)}

  /* ── 右上 天气 ── */
  .weather{position:absolute;top:60px;right:36px;text-align:right;z-index:25}
  .weather .temp{font-size:60px;font-weight:200;line-height:.9;letter-spacing:-1px}
  .weather .temp sup{font-size:20px;font-weight:300;vertical-align:top;margin-left:2px}
  .weather .loc{font-size:15px;color:var(--ink-soft);margin-top:6px}

  /* ── 底部信息卡（首页常态）── */
  .cards{position:absolute;left:40px;right:40px;bottom:84px;display:flex;gap:16px;
    z-index:15;transition:opacity .4s,transform .4s}
  .card{flex:1;height:96px;border-radius:18px;background:var(--card-bg);
    backdrop-filter:blur(20px) saturate(1.3);-webkit-backdrop-filter:blur(20px) saturate(1.3);
    box-shadow:0 8px 26px rgba(40,50,60,.12),inset 0 0 0 1px var(--card-bd);
    display:flex;align-items:center;gap:13px;padding:0 18px}
  .card .ic{width:42px;height:42px;border-radius:11px;flex:none;display:flex;
    align-items:center;justify-content:center;font-size:20px;
    background:linear-gradient(135deg,#fff,#eef1f4);box-shadow:0 2px 6px rgba(0,0,0,.06)}
  .card .ic.blue{background:linear-gradient(135deg,#3b78ff,#2f6bff);color:#fff}
  .card .ic.pink{background:linear-gradient(135deg,#ff7a9c,#ff5277);color:#fff}
  .card .big{font-size:18px;font-weight:600}
  .card .sub{font-size:12px;color:var(--ink-soft);margin-top:3px}
  .card .lnk{color:var(--blue);font-weight:600}
  .card .col2{display:flex;gap:18px}
  .tyre{display:flex;flex-direction:column;gap:4px;font-size:12px;color:var(--ink-soft);
    width:100%}
  .tyre .r{display:flex;justify-content:space-between}
  .tyre .car{align-self:center;width:26px;height:14px;border-radius:5px;
    background:rgba(35,38,43,.18);margin:1px 0}

  /* ── Dock ── */
  .dock{position:absolute;left:0;right:0;bottom:0;height:72px;z-index:40;
    display:flex;align-items:center;gap:18px;padding:0 22px;
    background:rgba(248,250,252,.5);backdrop-filter:blur(26px) saturate(1.3);
    -webkit-backdrop-filter:blur(26px) saturate(1.3);
    box-shadow:inset 0 1px 0 rgba(255,255,255,.6)}
  .dock .home{width:34px;height:34px;border-radius:50%;
    box-shadow:inset 0 0 0 2px rgba(35,38,43,.55);flex:none}
  .np{display:flex;align-items:center;gap:11px;width:230px}
  .np .cov{width:40px;height:40px;border-radius:9px;flex:none;
    background:linear-gradient(135deg,#ffb37a,#ff7eb0,#9b8cff)}
  .np .ti{font-size:14px;font-weight:600;line-height:1.25}
  .np .ar{font-size:11px;color:var(--ink-soft)}
  .np .pause{margin-left:auto;font-size:16px;color:var(--ink-soft)}
  .dock .sep{flex:1}
  .dock .ctrl{display:flex;align-items:center;gap:24px;color:rgba(35,38,43,.7)}
  .dock .ctrl .temp{display:flex;align-items:center;gap:9px;font-size:21px;font-weight:600;color:var(--ink)}
  .dock .ctrl .temp small{font-size:12px;color:var(--ink-soft)}
  .dock .ctrl .chev{font-size:13px;color:var(--ink-faint)}
  .dock .ctrl .it{font-size:12px;font-weight:600;display:flex;flex-direction:column;align-items:center;gap:2px}
  .dock .ctrl .it span:first-child{font-size:19px}

  /* ════════════ ★ 无框语音区 ★ ════════════
     固定宽度(--vz-w) · 高度随内容自适应 · 无 border / 无卡片底 */
  /* ★ 语音区：固定在左上（原小窗位）· 顶部锚定 · 向下随内容生长 · 无框 ★ */
  .voice-zone{position:absolute;left:40px;top:64px;z-index:36;
    width:var(--vz-w);
    display:flex;flex-direction:column;justify-content:flex-start;gap:12px;
    /* 故意不写 background / border / box-shadow —— 这是"无框"的关键 */
    transition:width .35s cubic-bezier(.2,.7,.2,1)}
  .voice-zone.hidden{display:none}

  /* 可读衬底：都是无硬边的柔性渐变，不是框 */
  .voice-zone::before{content:"";position:absolute;left:-26px;right:-26px;
    top:-22px;bottom:-22px;z-index:-1;pointer-events:none;
    border-radius:30px;filter:blur(30px);opacity:0;transition:opacity .4s}
  .stage.scrim-soft .voice-zone::before{opacity:.9;
    background:radial-gradient(70% 70% at 50% 36%,rgba(255,255,255,.72),rgba(255,255,255,0) 74%)}
  .stage.scrim-warm .voice-zone::before{opacity:.95;
    background:radial-gradient(72% 72% at 50% 34%,rgba(255,176,92,.62),rgba(255,138,60,.16) 56%,rgba(255,138,60,0) 76%)}
  /* 聚焦暗化：盖住整屏的柔性暗场，只突出语音区（也无框）*/
  .focus-dim{position:absolute;inset:0;z-index:34;pointer-events:none;opacity:0;
    transition:opacity .4s;background:radial-gradient(80% 90% at 50% 86%,rgba(10,14,20,0) 30%,rgba(10,14,20,.42) 100%)}
  .stage.scrim-dim .focus-dim{opacity:1}

  /* 参考线：仅设计期用，证明"区域边界" —— 默认关闭 */
  .voice-zone.guide::after{content:"固定宽 · 自适应高 · 无框";
    position:absolute;inset:-10px;border:1.5px dashed rgba(47,107,255,.7);border-radius:14px;
    color:var(--blue);font-size:11px;padding:3px 8px;white-space:nowrap;
    display:flex;align-items:flex-start;justify-content:flex-end;pointer-events:none}

  /* MVA 光球（品牌元素，非 slop）*/
  .aicy{width:46px;height:46px;border-radius:50%;flex:none;position:relative}
  .aicy::before{content:"";position:absolute;inset:0;border-radius:50%;
    background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);
    filter:blur(1px);animation:spin 5s linear infinite}
  .aicy::after{content:"";position:absolute;inset:9px;border-radius:50%;
    background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.6));
    box-shadow:0 0 16px rgba(255,255,255,.6)}
  .aicy.lg{width:60px;height:60px}
  @keyframes spin{to{transform:rotate(360deg)}}
  @keyframes breathe{0%,100%{transform:scale(1);opacity:.95}50%{transform:scale(1.08);opacity:1}}
  .aicy{animation:breathe 3.4s ease-in-out infinite}

  /* 中性占位内容（非场景，仅演示高度自适应）*/
  .vz-cap{font-size:13px;color:var(--ink-soft);text-shadow:0 1px 6px rgba(255,255,255,.7);
    display:flex;align-items:center;gap:8px}
  .vz-cap b{color:var(--blue);font-weight:700}
  .ph{border:1.5px dashed rgba(35,38,43,.28);border-radius:14px;
    background:rgba(255,255,255,.28);color:var(--ink-soft);font-size:13px;
    display:flex;align-items:center;justify-content:center;text-align:center;padding:0 16px}
  .row{display:flex;align-items:center;gap:14px}
  .bubble{position:relative;background:rgba(255,255,255,.58);
    backdrop-filter:blur(20px) saturate(1.3);-webkit-backdrop-filter:blur(20px) saturate(1.3);
    box-shadow:0 6px 22px rgba(40,50,60,.12),inset 0 0 0 1px rgba(255,255,255,.6);
    border-radius:16px;padding:15px 18px;font-size:15px;color:var(--ink);line-height:1.5}
  .ph-tag{position:absolute;top:8px;right:10px;font-size:10px;font-style:normal;
    letter-spacing:.05em;color:#fff;background:rgba(47,107,255,.85);
    padding:2px 7px;border-radius:7px}

  /* ── 控制面板（固定在窗口角，不随画布缩放）── */
  .panel{position:fixed;top:18px;right:18px;width:236px;z-index:100;
    background:rgba(22,24,28,.86);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
    border-radius:16px;padding:14px 15px;color:#e8eaee;font-size:12.5px;
    box-shadow:0 20px 50px rgba(0,0,0,.5),inset 0 0 0 1px rgba(255,255,255,.08)}
  .panel h4{font-size:11px;letter-spacing:.12em;text-transform:uppercase;
    color:#9aa0a8;font-weight:700;margin:14px 0 7px}
  .panel h4:first-child{margin-top:2px}
  .panel .title{font-size:13.5px;font-weight:700;color:#fff;display:flex;align-items:center;gap:7px}
  .panel .title i{width:8px;height:8px;border-radius:50%;
    background:conic-gradient(from 0deg,#5b8cff,#ff6b9b,#ffab5b,#5b8cff)}
  .seg{display:flex;gap:5px;flex-wrap:wrap}
  .seg button{flex:1;min-width:42px;padding:7px 4px;border:0;border-radius:9px;cursor:pointer;
    background:rgba(255,255,255,.08);color:#cfd3d9;font-size:12px;font-weight:600;
    transition:.15s;font-family:inherit}
  .seg button:hover{background:rgba(255,255,255,.15)}
  .seg button.on{background:var(--blue);color:#fff;box-shadow:0 2px 10px rgba(47,107,255,.5)}
  .row-tog{display:flex;align-items:center;justify-content:space-between;margin-top:9px}
  .sw{width:40px;height:23px;border-radius:12px;background:rgba(255,255,255,.16);
    position:relative;cursor:pointer;transition:.2s;flex:none}
  .sw::after{content:"";position:absolute;top:2.5px;left:2.5px;width:18px;height:18px;
    border-radius:50%;background:#fff;transition:.2s}
  .sw.on{background:var(--blue)}.sw.on::after{left:19px}
  .hint{font-size:11px;color:#8b9098;line-height:1.5;margin-top:12px;
    border-top:1px solid rgba(255,255,255,.08);padding-top:10px}
  .hint code{color:#ffce8a;background:rgba(255,255,255,.06);padding:1px 5px;border-radius:5px}
  /* 演示控制台：默认弱化半透明、略缩小，悬停恢复清晰（不抢演示效果） */
  .panel{opacity:.3;transform:scale(.86);transform-origin:top right;transition:opacity .3s ease,transform .3s ease}
  .panel:hover{opacity:1;transform:scale(1)}

  /* 全局：底栏 MVA 光球（语音区收起时的最小化态 · 点击唤起；区域展开时淡出）*/
  .mva-orb{width:38px;height:38px;border-radius:50%;flex:none;border:0;padding:0;cursor:pointer;position:relative;background:radial-gradient(circle at 38% 34%,#2a3340,#11161f);transition:transform .15s,opacity .35s}
  .mva-orb::before{content:"";position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);filter:blur(.6px);animation:mvaspin 6s linear infinite}
  .mva-orb::after{content:"";position:absolute;inset:7px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.62));box-shadow:0 0 11px rgba(255,255,255,.5)}
  .mva-orb:hover{transform:scale(1.06)}.mva-orb:active{transform:scale(.93)}
  .stage.voice-on .mva-orb{opacity:.4}
  .mva-orb.busy{opacity:.26 !important;pointer-events:none;filter:saturate(.55)}
  .stage.zone-hidden .voice-zone{opacity:0 !important;transform:translateY(-10px) scale(.985) !important;pointer-events:none !important;transition:opacity .35s ease,transform .35s ease}
  .stage.zone-hidden .map{transform:none !important}
  @keyframes mvaspin{to{transform:rotate(360deg)}}
</style>
</head>
<body>
<div class="viewport">
  <div class="stage" id="stage">
    <div class="hero"></div>
    <div class="focus-dim"></div>

    <!-- 状态栏 -->
    <div class="statusbar">
      <div class="avatar"></div>
      <div class="sb-right">
        <svg width="15" height="18" viewBox="0 0 15 18"><path d="M3 5l9 8-4.5 4V1L12 5 3 13" fill="none" stroke="#23262b" stroke-width="1.6" stroke-linejoin="round"/></svg>
        <span><sup class="sb-5g">5G</sup>
          <svg width="22" height="16" viewBox="0 0 22 16" style="vertical-align:middle">
            <rect x="0" y="11" width="3.4" height="5" rx="1" fill="#23262b"/>
            <rect x="5.2" y="8" width="3.4" height="8" rx="1" fill="#23262b"/>
            <rect x="10.4" y="5" width="3.4" height="11" rx="1" fill="#23262b"/>
            <rect x="15.6" y="2" width="3.4" height="14" rx="1" fill="#23262b"/>
          </svg></span>
        <svg width="20" height="16" viewBox="0 0 20 16"><path d="M2 6h4l5-4v12l-5-4H2z" fill="#23262b"/><path d="M14 5c1.5 1.2 1.5 4.8 0 6M16.5 3c2.8 2 2.8 8 0 10" fill="none" stroke="#23262b" stroke-width="1.4" stroke-linecap="round"/></svg>
        <span class="sb-clock">13:12</span>
      </div>
    </div>

    <!-- 左上 地图卡 -->
    <div class="map">
      <div class="map-top">
        <span class="pin">📍</span><span class="t">地图</span>
        <svg class="mag" width="18" height="18" viewBox="0 0 18 18"><circle cx="7.5" cy="7.5" r="5.5" fill="none" stroke="#fff" stroke-width="1.6"/><path d="M12 12l4 4" stroke="#fff" stroke-width="1.6" stroke-linecap="round"/></svg>
      </div>
      <div class="map-quick">
        <div>⌂</div><div>☰</div><div>★</div><div>⚡</div>
      </div>
    </div>

    <!-- 右上 天气 -->
    <div class="weather">
      <div class="temp">18<sup>°C</sup></div>
      <div class="loc">上海市　晴</div>
    </div>

    <!-- 底部信息卡（首页常态）-->

    <!-- ★ 无框语音区 ★ -->
    <div class="voice-zone" id="vz">
      <!-- 内容由 JS 注入（中性占位，演示高度自适应）-->
    </div>

    <!-- Dock -->
    <div class="dock">
      <button class="mva-orb" id="mvaOrb" title="MVA · 唤起语音区"></button>
      <div class="np">
        <div class="cov"></div>
        <div><div class="ti">Infinite Passion</div><div class="ar">Suker Wong</div></div>
        <div class="pause">❙❙</div>
      </div>
      <div class="sep"></div>
      <div class="ctrl">
        <div class="it"><span>❄</span></div>
        <div class="temp"><span class="chev">‹</span>23.5<small>°</small><span class="chev">›</span></div>
        <div class="it"><span>🚘</span></div>
        <div class="it"><span>⚡</span></div>
        <div class="it"><span>360</span></div>
        <div class="it"><span>📞</span></div>
        <div class="it"><span>▦</span></div>
      </div>
    </div>
  </div>
</div>

<!-- 控制面板 -->
<div class="panel">
  <div class="title"><i></i>无框语音区 · 底座 v1</div>

  <h4>语音区</h4>
  <div class="row-tog"><span>显示语音区</span><div class="sw on" id="sw-show"></div></div>

  <h4>内容高度（演示高度自适应）</h4>
  <div class="seg" id="seg-h">
    <button data-h="0">空</button><button data-h="1" class="on">短</button>
    <button data-h="2">中</button><button data-h="3">高</button>
  </div>

  <h4>区域宽度（固定·切几档）</h4>
  <div class="seg" id="seg-w">
    <button data-w="320">320</button><button data-w="380" class="on">380</button><button data-w="440">440</button>
  </div>

  <h4>可读衬底（皆无硬边）</h4>
  <div class="seg" id="seg-s">
    <button data-s="none" class="on">无</button><button data-s="soft">柔光</button>
    <button data-s="warm">暖橙</button><button data-s="dim">聚焦</button>
  </div>

  <h4>设计辅助</h4>
  <div class="row-tog"><span>显示区域参考线</span><div class="sw" id="sw-guide"></div></div>

  <div class="hint">位于<b style="color:#fff">左上原小窗位</b>，出现时把<b style="color:#fff">地图卡向右推</b>。区域<b style="color:#ffce8a">没有 border / 卡片底</b>，宽度固定（<code>--vz-w</code>），高度随内容向下撑开。当前高 <b style="color:#fff" id="hread">–</b>。场景留空给你填。</div>
</div>

<script>
  // ── 等比缩放 1300×812 到窗口 ──
  const stage = document.getElementById('stage');
  function fit(){
    const s = Math.min(innerWidth/1300, innerHeight/812)*0.985;
    stage.style.transform = `scale(${s})`;
  }
  addEventListener('resize', fit); fit();

  // ── 语音区中性占位内容（演示高度自适应，非具体场景）──
  const vz = document.getElementById('vz');
  const cap = () => `<div class="vz-cap"><b>语音区</b> · 宽固定 · 高自适应 · 无框 —— 场景待填</div>`;
  const tag = '<em class="ph-tag">占位</em>';
  const levels = {
    0: `${cap()}<div class="ph" style="height:60px">空状态 · 区域存在但无内容（无框）</div>`,
    1: `${cap()}
        <div class="row"><div class="aicy"></div>
          <div class="bubble" style="flex:1">${tag}正在聆听…</div></div>`,
    2: `${cap()}
        <div class="row"><div class="aicy"></div>
          <div class="bubble" style="flex:1">${tag}识别文字 / 标题行</div></div>
        <div class="bubble">${tag}中等高度内容块 —— 例如识别结果 + 一组横向推荐卡，高度随之撑开。</div>`,
    3: `${cap()}
        <div class="row"><div class="aicy lg"></div>
          <div class="bubble" style="flex:1">${tag}识别文字 / 标题行</div></div>
        <div class="bubble">${tag}一段回复内容。</div>
        <div class="bubble" style="line-height:1.7">${tag}更大的块 —— 多轮对话堆叠 / 长列表 / 富媒体卡。<br>区域高度持续向下自适应，顶边锚定不动、无任何边框。</div>`,
  };
  function setH(h){ vz.innerHTML = levels[h]; }

  // 实时高度读数
  const hread = document.getElementById('hread');
  new ResizeObserver(()=>{ hread.textContent = vz.offsetHeight + 'px'; }).observe(vz);

  // ── 面板交互 ──
  function bindSeg(id, fn){
    const box = document.getElementById(id);
    box.addEventListener('click', e=>{
      const b = e.target.closest('button'); if(!b) return;
      [...box.children].forEach(x=>x.classList.remove('on')); b.classList.add('on'); fn(b);
    });
  }
  bindSeg('seg-h', b=> setH(+b.dataset.h));
  bindSeg('seg-w', b=> stage.style.setProperty('--vz-w', b.dataset.w+'px'));
  bindSeg('seg-s', b=>{
    stage.classList.remove('scrim-soft','scrim-warm','scrim-dim');
    if(b.dataset.s==='soft') stage.classList.add('scrim-soft');
    if(b.dataset.s==='warm') stage.classList.add('scrim-warm');
    if(b.dataset.s==='dim')  stage.classList.add('scrim-dim');
  });
  function bindSw(id, fn){ const s=document.getElementById(id);
    s.addEventListener('click',()=>{ s.classList.toggle('on'); fn(s.classList.contains('on')); }); }
  bindSw('sw-show',  on=>{ vz.classList.toggle('hidden', !on); stage.classList.toggle('voice-on', on); });
  bindSw('sw-guide', on=> vz.classList.toggle('guide', on));

  stage.classList.add('voice-on'); // 默认语音区显示 → 地图卡右移
  setH(1); // 默认"短"
</script>

<script>
(function(){
  var orb=document.getElementById('mvaOrb');if(!orb)return;
  var stage=document.querySelector('.stage');
  var watch=[document.querySelector('.voice-zone'),document.querySelector('.statusbar')].filter(Boolean);
  var busy=true,settleT=null;
  function en(on){orb.classList.toggle('busy',!on);}
  function settle(){busy=false;en(true);}
  function bump(){busy=true;en(false);clearTimeout(settleT);settleT=setTimeout(settle,1200);}
  try{var obs=new MutationObserver(bump);watch.forEach(function(n){obs.observe(n,{childList:true,subtree:true,characterData:true,attributes:true,attributeFilter:['class','style']});});}catch(e){}
  bump();
  orb.onclick=function(){if(busy)return;stage.classList.toggle('zone-hidden');};
})();
</script>
</body>
</html>
