<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Mercedes-Benz · Voice Zone · World Cup Match (Adaptive Content)</title>
<!--
  场景：语音查询世界杯赛事 —— 展示语音区「内容丰富度自适应」
  同一块无框区域，按问题不同呈现 4 档：
   ① 比分（极简·精致小组件）② 单场详情（中）③ 赛程（丰富·撑高）④ 积分榜（撑满）
  数据：球队/分组/场馆/赛程为 2026 世界杯真实信息；比分与积分为示意值（赛事 6/11 开赛，已标注）。
-->
<style>
  :root{
    --card:rgba(22,28,38,.66);--card-2:rgba(30,37,48,.6);--card-bd:rgba(255,255,255,.1);
    --ink:#eef1f4;--ink-soft:rgba(238,241,244,.58);--ink-faint:rgba(238,241,244,.38);
    --blue:#3b78ff;--green:#34d06a;--live:#ff4d4f;--gold:#ffce5e;--vz-w:444px;
    --mex:#2fb55e;--rsa:#e0a82e;--kor:#e0454e;--cze:#3f7fe0;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{height:100%;background:#05070b;overflow:hidden;
    font-family:"PingFang SC","Microsoft YaHei",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
    -webkit-font-smoothing:antialiased;color:var(--ink)}
  .viewport{position:fixed;inset:0;display:flex;align-items:center;justify-content:center}
  .stage{position:relative;width:1300px;height:812px;overflow:hidden;transform-origin:center center;
    border-radius:18px;box-shadow:0 40px 120px rgba(0,0,0,.65);
    background:radial-gradient(135% 115% at 50% 8%,#141c2a 0%,#0e1420 46%,#080b12 100%)}
  /* 地图桌面底图（Flyme 地图桌面 · 夜间）*/
  .mapbg{position:absolute;inset:0;z-index:0}
  .mapbg svg{position:absolute;inset:0;width:100%;height:100%}
  .mapbg-scrim{position:absolute;inset:0;background:radial-gradient(125% 105% at 50% 38%,rgba(8,11,18,.32),rgba(6,9,15,.6))}

  /* chrome（深色）*/
  .statusbar{position:absolute;top:0;left:0;right:0;height:50px;display:flex;align-items:center;justify-content:space-between;padding:0 24px;z-index:55}
  .sb-left{display:flex;align-items:center;gap:13px;flex:1;min-width:0;height:100%;padding-right:24px}
  /* 头像 → 唤醒后形态转化为 MVA 光球 */
  .avatar{width:36px;height:36px;border-radius:50%;flex:none;position:relative;background-image:linear-gradient(135deg,#f3c9b0,#cf9d86);box-shadow:inset 0 0 0 1.5px rgba(255,255,255,.4);transition:box-shadow .5s}
  .avatar::before{content:"";position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);filter:blur(1px);opacity:0;transition:opacity .55s;animation:spin 5s linear infinite}
  .avatar::after{content:"";position:absolute;inset:7px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.6));box-shadow:0 0 14px rgba(255,255,255,.55);opacity:0;transition:opacity .55s}
  .avatar.awake{box-shadow:none;animation:breathe 3.2s ease-in-out infinite}
  .avatar.awake::before,.avatar.awake::after{opacity:1}
  .sb-voice{position:relative;display:flex;align-items:center;min-width:0;height:100%}
  .sv-asr{display:inline-flex;align-items:center;max-width:600px;overflow:hidden;white-space:nowrap;font-size:15.5px;font-weight:600;color:var(--ink);opacity:0;transition:opacity .35s,transform .4s,filter .4s}
  .sv-asr.show{opacity:1}.sv-asr.done{color:#62e08c}.sv-asr.gone{opacity:0;transform:translateY(-7px);filter:blur(2px)}
  .sv-cur{display:inline-block;width:2px;height:16px;background:#62e08c;margin-left:2px;animation:blink 1s step-end infinite}
  .sv-reply{font-size:15.5px;font-weight:600;color:#fff;white-space:nowrap;opacity:0;transform:translateY(4px);transition:opacity .45s,transform .45s;text-shadow:0 1px 10px rgba(0,0,0,.4)}
  .sv-reply.show{opacity:1;transform:none}
  .sb-right{display:flex;align-items:center;gap:16px;color:#dfe3e8;flex:none}
  .sb-clock{font-size:19px;font-weight:500;letter-spacing:.5px}.sb-5g{font-size:10px;font-weight:700;vertical-align:top;margin-right:1px}
  .map{position:absolute;top:64px;left:40px;width:300px;border-radius:20px;background:rgba(44,52,64,.5);
    backdrop-filter:blur(22px) saturate(1.2);-webkit-backdrop-filter:blur(22px) saturate(1.2);
    box-shadow:0 8px 30px rgba(0,0,0,.3),inset 0 0 0 1px rgba(255,255,255,.12);overflow:hidden;z-index:25;color:#fff;
    transition:transform .42s cubic-bezier(.2,.7,.2,1)}
  .stage.voice-on .map{transform:translateX(calc(var(--vz-w) + 16px))}
  .map-top{display:flex;align-items:center;gap:9px;padding:14px 16px}.map-top .t{flex:1;font-size:16px;font-weight:500}
  .map-quick{display:flex;background:rgba(10,14,20,.4)}
  .map-quick div{flex:1;display:flex;align-items:center;justify-content:center;padding:12px 0;opacity:.85}
  .map-quick div+div{box-shadow:inset 1px 0 0 rgba(255,255,255,.08)}
  .weather{position:absolute;top:60px;right:36px;text-align:right;z-index:25}
  .weather .temp{font-size:60px;font-weight:200;line-height:.9;letter-spacing:-1px;color:#fff}
  .weather .temp sup{font-size:20px;font-weight:300;vertical-align:top;margin-left:2px}
  .weather .loc{font-size:15px;color:var(--ink-soft);margin-top:6px}
  .dock{position:absolute;left:0;right:0;bottom:0;height:72px;z-index:30;display:flex;align-items:center;gap:18px;padding:0 22px;
    background:rgba(12,16,24,.6);backdrop-filter:blur(26px) saturate(1.2);-webkit-backdrop-filter:blur(26px) saturate(1.2);box-shadow:inset 0 1px 0 rgba(255,255,255,.08)}
  .dock .home{width:34px;height:34px;border-radius:50%;box-shadow:inset 0 0 0 2px rgba(255,255,255,.5);flex:none}
  .np{display:flex;align-items:center;gap:11px;width:230px}.np .cov{width:40px;height:40px;border-radius:9px;flex:none;background:linear-gradient(135deg,#ffb37a,#ff7eb0,#9b8cff)}
  .np .ti{font-size:14px;font-weight:600;line-height:1.25}.np .ar{font-size:11px;color:var(--ink-soft)}.np .pause{margin-left:auto;font-size:16px;color:var(--ink-soft)}
  .dock .sep{flex:1}.dock .ctrl{display:flex;align-items:center;gap:24px;color:rgba(238,241,244,.72)}
  .dock .ctrl .temp{display:flex;align-items:center;gap:9px;font-size:21px;font-weight:600;color:var(--ink)}
  .dock .ctrl .temp small{font-size:12px;color:var(--ink-soft)}.dock .ctrl .chev{font-size:13px;color:var(--ink-faint)}.dock .ctrl .it{font-size:19px}

  /* ── 语音区 ── */
  /* 内容顶沿与右侧地图卡上沿（top:64）平齐 */
  .voice-zone{position:absolute;left:40px;top:64px;z-index:50;width:var(--vz-w);display:flex;flex-direction:column;gap:14px}
  .asr{display:flex;align-items:center;gap:12px;opacity:0;transition:opacity .35s,transform .45s,filter .45s}
  .asr.show{opacity:1}.asr.done .asr-text{color:#62e08c;transition:color .35s}
  .asr.gone{opacity:0;transform:translateY(-8px);filter:blur(2px)}
  .aicy{width:42px;height:42px;border-radius:50%;flex:none;position:relative;animation:breathe 3.2s ease-in-out infinite}
  .aicy::before{content:"";position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);filter:blur(1px);animation:spin 5s linear infinite}
  .aicy::after{content:"";position:absolute;inset:8px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.6));box-shadow:0 0 14px rgba(255,255,255,.55)}
  @keyframes spin{to{transform:rotate(360deg)}}@keyframes breathe{0%,100%{transform:scale(1)}50%{transform:scale(1.07)}}
  .asr-box{flex:1;min-width:0;background:var(--card);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-radius:15px;box-shadow:inset 0 0 0 1px var(--card-bd);padding:13px 16px;overflow:hidden}
  .asr-scroll{overflow:hidden;white-space:nowrap;width:100%}.asr-text{font-size:15.5px;font-weight:500;color:var(--ink);white-space:nowrap}
  .asr-cursor{display:inline-block;width:2px;height:16px;background:#62e08c;margin-left:2px;vertical-align:-3px;animation:blink 1s step-end infinite}
  @keyframes blink{50%{opacity:0}}
  .reply{display:flex;align-items:flex-start;gap:12px;opacity:0;transform:translateY(6px);transition:opacity .5s,transform .5s}
  .reply.show{opacity:1;transform:none}
  .reply-t{font-size:16px;font-weight:600;color:#fff;line-height:1.45;padding-top:9px;text-shadow:0 1px 12px rgba(0,0,0,.5)}

  /* 内容容器（按丰富度自适应高度）*/
  .content{opacity:0;transform:translateY(10px);transition:opacity .45s,transform .45s}
  .content.show{opacity:1;transform:none}
  .card{background:var(--card);backdrop-filter:blur(24px) saturate(1.2);-webkit-backdrop-filter:blur(24px) saturate(1.2);
    border-radius:20px;box-shadow:0 14px 40px rgba(0,0,0,.4),inset 0 0 0 1px rgba(255,255,255,.1);overflow:hidden}
  .badge{font-size:10px;font-weight:700;letter-spacing:.05em;color:var(--gold);background:rgba(255,206,94,.16);padding:2px 7px;border-radius:6px;vertical-align:1px}
  .live{display:inline-flex;align-items:center;gap:5px;color:var(--live);font-weight:700;font-variant-numeric:tabular-nums}
  .live i{width:7px;height:7px;border-radius:50%;background:var(--live);animation:pulse 1.4s ease-in-out infinite}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.25}}

  /* 比分卡 */
  .sc-meta{display:flex;align-items:center;justify-content:space-between;font-size:12px;color:var(--ink-soft);
    padding:13px 18px 0}
  .sc-meta .l{display:flex;align-items:center;gap:8px}
  .sc-main{display:flex;align-items:center;padding:8px 20px 20px}
  .tm{flex:1;display:flex;flex-direction:column;align-items:center;gap:9px}
  .tm .flag{font-size:34px;line-height:1;filter:drop-shadow(0 2px 4px rgba(0,0,0,.4))}
  .tm .nm{font-size:15px;font-weight:600}
  .tm.acc{position:relative}
  .sco{display:flex;flex-direction:column;align-items:center;gap:6px;padding:0 6px;min-width:120px}
  .sco .num{font-size:48px;font-weight:300;letter-spacing:1px;font-variant-numeric:tabular-nums;line-height:1}
  .sco .num em{font-style:normal;color:var(--ink-faint);margin:0 6px;font-size:34px;vertical-align:3px}
  .tm-bar{height:3px;width:42px;border-radius:2px;margin-top:2px}

  /* 进球人 + 数据 */
  .scorers{display:flex;border-top:1px solid rgba(255,255,255,.08);font-size:12.5px;color:var(--ink-soft)}
  .scorers>div{flex:1;padding:12px 18px;display:flex;flex-direction:column;gap:5px}
  .scorers .sr{text-align:right;align-items:flex-end;border-left:1px solid rgba(255,255,255,.08)}
  .scorers b{color:var(--ink);font-weight:600}
  .stats{padding:14px 18px 18px;border-top:1px solid rgba(255,255,255,.08);display:flex;flex-direction:column;gap:13px}
  .st .row{display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px}
  .st .row .lab{color:var(--ink-soft)}.st .row b{font-weight:700}
  .st .bar{height:6px;border-radius:3px;display:flex;overflow:hidden;background:rgba(255,255,255,.08)}
  .st .bar .a{background:var(--mex)}.st .bar .b{background:var(--rsa)}

  /* 赛程 */
  .sch{padding:6px 0 8px}
  .day{display:flex;align-items:center;gap:9px;padding:13px 18px 7px}
  .day .dd{font-size:14px;font-weight:700}.day .ds{font-size:11px;color:var(--ink-soft);background:rgba(255,255,255,.08);padding:2px 8px;border-radius:6px}
  .m{padding:9px 18px;display:grid;grid-template-columns:54px 1fr;gap:4px 12px;align-items:center}
  .m+.m{border-top:1px solid rgba(255,255,255,.05)}
  .m .t{grid-row:1/3;font-size:17px;font-weight:700;color:#fff;font-variant-numeric:tabular-nums}
  .m .teams{display:flex;align-items:center;gap:8px;font-size:15px;font-weight:600}
  .m .teams .vs{color:var(--ink-faint);font-size:12px;font-weight:600;margin:0 2px}
  .m .teams .f{font-size:18px}
  .m .v{font-size:11.5px;color:var(--ink-soft)}

  /* 积分榜 */
  .tbl{padding:6px 0 10px}
  .tcap{display:flex;align-items:center;justify-content:space-between;padding:13px 18px 8px;font-size:13px;font-weight:700}
  .tcap .badge{font-weight:700}
  .th,.tr{display:grid;grid-template-columns:30px 1fr 30px 26px 26px 26px 38px 40px;align-items:center;
    padding:0 16px;font-variant-numeric:tabular-nums}
  .th{font-size:11px;color:var(--ink-faint);height:28px}
  .th span,.tr span{text-align:center}.th .c-tm,.tr .c-tm{text-align:left}
  .tr{height:46px;font-size:14px;position:relative}
  .tr+.tr{border-top:1px solid rgba(255,255,255,.05)}
  .tr .c-tm{display:flex;align-items:center;gap:9px;font-weight:600}.tr .c-tm .f{font-size:18px}
  .tr .c-pts{font-weight:800;color:#fff}
  .tr.q::before{content:"";position:absolute;left:0;top:8px;bottom:8px;width:3px;border-radius:2px;background:var(--green)}
  .tr .pos{display:inline-flex;width:20px;height:20px;border-radius:6px;align-items:center;justify-content:center;font-size:12px;font-weight:700;background:rgba(255,255,255,.08)}
  .tr.q .pos{background:rgba(52,208,106,.2);color:#7ff0a8}
  .tlegend{display:flex;align-items:center;gap:7px;padding:11px 18px 4px;font-size:11.5px;color:var(--ink-soft)}
  .tlegend i{width:8px;height:8px;border-radius:2px;background:var(--green)}

  /* 射手榜（带真实球员头像）*/
  .lb{padding:6px 0 10px}
  .lb .cap{display:flex;align-items:center;justify-content:space-between;padding:13px 18px 8px;font-size:13px;font-weight:700}
  .lb .th,.lb .r{display:grid;grid-template-columns:26px 48px 1fr 50px 50px;align-items:center;padding:0 16px}
  .lb .th{font-size:11px;color:var(--ink-faint);height:26px}
  .lb .th span{text-align:center}.lb .th .c-pl{text-align:left}
  .lb .r{height:56px;position:relative}.lb .r+.r{border-top:1px solid rgba(255,255,255,.05)}
  .lb .pos{text-align:center;font-weight:700;font-size:13px;color:var(--ink-soft)}
  .lb .r.top .pos{color:var(--gold)}
  .lb .av{width:42px;height:42px;border-radius:50%;object-fit:cover;object-position:50% 16%;justify-self:center;
    box-shadow:0 2px 8px rgba(0,0,0,.45),inset 0 0 0 1px rgba(255,255,255,.18);background:#1a2230}
  .lb .r.top .av{box-shadow:0 0 0 2px var(--gold),0 2px 8px rgba(0,0,0,.45)}
  .lb .pl{display:flex;flex-direction:column;gap:2px;min-width:0;padding-left:4px}
  .lb .pl .nm{font-size:15px;font-weight:600;display:flex;align-items:center;gap:5px}
  .lb .pl .tt{font-size:11.5px;color:var(--ink-soft)}
  .lb .g,.lb .a{text-align:center;font-variant-numeric:tabular-nums}
  .lb .g{font-size:19px;font-weight:800;color:#fff}.lb .a{font-size:15px;font-weight:600;color:var(--ink-soft)}
  .lb .lg{padding:9px 18px 2px;font-size:11.5px;color:var(--ink-soft)}

  /* 面板 */
  .panel{position:fixed;top:18px;right:18px;width:244px;z-index:100;background:rgba(20,22,26,.9);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
    border-radius:16px;padding:15px;color:#e8eaee;font-size:12.5px;box-shadow:0 20px 50px rgba(0,0,0,.5),inset 0 0 0 1px rgba(255,255,255,.08)}
  .panel .title{font-size:13.5px;font-weight:700;color:#fff;display:flex;align-items:center;gap:7px;margin-bottom:12px}
  .panel .title i{width:8px;height:8px;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#ff6b9b,#ffab5b,#5b8cff)}
  .panel h4{font-size:11px;letter-spacing:.1em;color:#9aa0a8;font-weight:700;margin:6px 0 8px}
  .vbtns{display:flex;flex-direction:column;gap:7px}
  .vbtn{display:flex;align-items:center;gap:10px;border:0;border-radius:11px;cursor:pointer;font-family:inherit;text-align:left;
    background:rgba(255,255,255,.07);color:#dfe3e8;padding:11px 13px;transition:.15s}
  .vbtn:hover{background:rgba(255,255,255,.13)}
  .vbtn.on{background:var(--blue);color:#fff;box-shadow:0 4px 14px rgba(47,107,255,.45)}
  .vbtn .k{font-size:13.5px;font-weight:700}.vbtn .d{font-size:11px;opacity:.7;margin-top:1px}
  .vbtn .n{margin-left:auto;font-size:10px;opacity:.6}
  .panel .phase{margin-top:12px;font-size:11px;color:#8b9098;border-top:1px solid rgba(255,255,255,.08);padding-top:10px}.panel .phase b{color:#ffce8a}
  /* 演示控制台：默认弱化半透明、略缩小，悬停恢复清晰（不抢演示效果） */
  .panel{opacity:.3;transform:scale(.86);transform-origin:top right;transition:opacity .3s ease,transform .3s ease}
  .panel:hover{opacity:1;transform:scale(1)}

  /* 全局：底栏 MVA 光球（语音区收起时的最小化态 · 点击唤起；区域展开时淡出）*/
  .mva-orb{width:38px;height:38px;border-radius:50%;flex:none;border:0;padding:0;cursor:pointer;position:relative;background:radial-gradient(circle at 38% 34%,#2a3340,#11161f);transition:transform .15s,opacity .35s}
  .mva-orb::before{content:"";position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);filter:blur(.6px);animation:mvaspin 6s linear infinite}
  .mva-orb::after{content:"";position:absolute;inset:7px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.62));box-shadow:0 0 11px rgba(255,255,255,.5)}
  .mva-orb:hover{transform:scale(1.06)}.mva-orb:active{transform:scale(.93)}
  .stage.voice-on .mva-orb{opacity:.4}
  .mva-orb.busy{opacity:.26 !important;pointer-events:none;filter:saturate(.55)}
  .stage.zone-hidden .voice-zone{opacity:0 !important;transform:translateY(-10px) scale(.985) !important;pointer-events:none !important;transition:opacity .35s ease,transform .35s ease}
  .stage.zone-hidden .map{transform:none !important}
  @keyframes mvaspin{to{transform:rotate(360deg)}}
</style>
</head>
<body>
<div class="viewport">
  <div class="stage" id="stage">
    <div class="mapbg">
      <svg viewBox="0 0 1300 812" preserveAspectRatio="xMidYMid slice">
        <defs><linearGradient id="bg" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#1c2533"/><stop offset="1" stop-color="#151b25"/></linearGradient></defs>
        <rect width="1300" height="812" fill="url(#bg)"/>
        <path d="M-20 612 C 120 588 210 640 250 720 C 270 766 250 812 250 812 L -20 812 Z" fill="#1d3144"/>
        <path d="M 470 -20 C 520 90 470 160 540 250 C 600 330 560 420 640 470" fill="none" stroke="#1d3144" stroke-width="26" stroke-linecap="round" opacity=".9"/>
        <path d="M 1010 70 C 1110 60 1190 110 1180 200 C 1172 280 1080 300 1020 250 C 970 210 950 110 1010 70 Z" fill="#21362b"/>
        <g stroke="#222b39" stroke-width="15" fill="none" stroke-linecap="round"><path d="M-20 590 C 230 560 440 540 640 548 C 900 558 1080 520 1330 452"/><path d="M 300 -20 C 350 200 400 410 540 560 C 660 690 740 760 800 840"/><path d="M 1330 150 C 1150 210 1050 330 1010 470 C 980 640 1010 760 1030 840"/><path d="M-20 230 C 220 250 430 250 640 300 C 900 360 1040 340 1330 300"/></g>
        <g stroke="#4b5566" stroke-width="9" fill="none" stroke-linecap="round"><path d="M-20 590 C 230 560 440 540 640 548 C 900 558 1080 520 1330 452"/><path d="M 300 -20 C 350 200 400 410 540 560 C 660 690 740 760 800 840"/><path d="M 1330 150 C 1150 210 1050 330 1010 470 C 980 640 1010 760 1030 840"/><path d="M-20 230 C 220 250 430 250 640 300 C 900 360 1040 340 1330 300"/></g>
        <g stroke="#3c4552" stroke-width="4.8" fill="none" stroke-linecap="round"><path d="M 360 90 C 420 230 480 360 560 470"/><path d="M 700 300 C 760 380 820 430 920 450"/><path d="M 640 548 C 700 620 740 700 720 812"/><path d="M 1010 470 C 900 500 800 520 700 560"/><path d="M 200 400 C 320 420 440 440 540 470"/><path d="M 880 110 C 900 200 920 300 945 360"/></g>
        <g stroke="#3a4350" stroke-width="3.4" fill="none" stroke-linecap="round"><path d="M 380 560 C 520 600 680 636 840 658 C 1000 680 1150 694 1330 686"/><path d="M 520 470 C 540 600 552 700 560 812"/><path d="M 760 560 C 778 660 792 740 800 812"/><path d="M 900 520 C 944 620 972 712 982 812"/><path d="M 240 650 C 440 660 640 682 860 704"/><path d="M 1090 540 C 1118 640 1136 740 1150 812"/><path d="M 640 548 C 600 656 566 742 542 812"/><path d="M 700 300 C 640 360 580 392 520 470"/><path d="M 980 470 C 1060 510 1140 540 1330 560"/></g>
        <text x="560" y="360" fill="#5d7e98" font-size="14" font-style="italic" transform="rotate(58 560 360)">Dongming Creek</text>
        <g fill="#9aa3b0" font-size="15"><text x="430" y="470">Moganshan Town</text><text x="800" y="210">Daixi Town</text><text x="1110" y="150">Donglin Town</text></g>
        <g fill="#7c8694" font-size="13"><text x="250" y="320">Pudong South Rd</text><text x="640" y="630">Century Ave</text><text x="1040" y="560">Riverside East Rd</text></g>
        <g font-size="12" font-weight="700" text-anchor="middle"><rect x="688" y="392" width="42" height="20" rx="5" fill="#b8443a"/><text x="709" y="406" fill="#fff">G104</text><rect x="500" y="500" width="42" height="20" rx="5" fill="#2f9e8d"/><text x="521" y="514" fill="#fff">S43</text></g>
      </svg>
      <div class="mapbg-scrim"></div>
    </div>
    <div class="statusbar">
      <div class="sb-left">
        <div class="avatar" id="avatar"></div>
        <div class="sb-voice">
          <span class="sv-asr" id="svAsr"><span id="asrText"></span><span class="sv-cur" id="asrCur"></span></span>
          <span class="sv-reply" id="replyT"></span>
        </div>
      </div>
      <div class="sb-right">
        <svg width="15" height="18" viewBox="0 0 15 18"><path d="M3 5l9 8-4.5 4V1L12 5 3 13" fill="none" stroke="#dfe3e8" stroke-width="1.6" stroke-linejoin="round"/></svg>
        <span><sup class="sb-5g">5G</sup>
          <svg width="22" height="16" viewBox="0 0 22 16" style="vertical-align:middle">
            <rect x="0" y="11" width="3.4" height="5" rx="1" fill="#dfe3e8"/><rect x="5.2" y="8" width="3.4" height="8" rx="1" fill="#dfe3e8"/>
            <rect x="10.4" y="5" width="3.4" height="11" rx="1" fill="#dfe3e8"/><rect x="15.6" y="2" width="3.4" height="14" rx="1" fill="#dfe3e8"/></svg></span>
        <span class="sb-clock">13:12</span>
      </div>
    </div>
    <div class="map">
      <div class="map-top"><span>📍</span><span class="t">Navigation</span>
        <svg width="18" height="18" viewBox="0 0 18 18"><circle cx="7.5" cy="7.5" r="5.5" fill="none" stroke="#fff" stroke-width="1.6"/><path d="M12 12l4 4" stroke="#fff" stroke-width="1.6" stroke-linecap="round"/></svg></div>
      <div class="map-quick"><div>⌂</div><div>☰</div><div>★</div><div>⚡</div></div>
    </div>
    <div class="weather"><div class="temp">18<sup>°C</sup></div><div class="loc">Shanghai · Sunny</div></div>

    <div class="voice-zone" id="vz">
      <div class="content" id="content"></div>
    </div>

    <div class="dock">
      <button class="mva-orb" id="mvaOrb" title="MVA · Open Voice Zone"></button>
      <div class="np"><div class="cov"></div><div><div class="ti">Infinite Passion</div><div class="ar">Suker Wong</div></div><div class="pause">❙❙</div></div>
      <div class="sep"></div>
      <div class="ctrl"><div class="it">❄</div><div class="temp"><span class="chev">‹</span>23.5<small>°</small><span class="chev">›</span></div>
        <div class="it">🚘</div><div class="it">⚡</div><div class="it">360</div><div class="it">📞</div><div class="it">▦</div></div>
    </div>
  </div>
</div>

<div class="panel">
  <div class="title"><i></i>World Cup · Adaptive Content</div>
  <h4>Ask different questions → different richness</h4>
  <div class="vbtns" id="vbtns">
    <button class="vbtn on" data-v="score"><div><div class="k">Score</div><div class="d">Minimal · compact widget</div></div><span class="n">Minimal</span></button>
    <button class="vbtn" data-v="detail"><div><div class="k">Match Detail</div><div class="d">Score + goals + stats</div></div><span class="n">Medium</span></button>
    <button class="vbtn" data-v="scorers"><div><div class="k">Top Scorers</div><div class="d">Goals, assists + player photos</div></div><span class="n">Rich</span></button>
    <button class="vbtn" data-v="schedule"><div><div class="k">Schedule</div><div class="d">Group A · 6 matches · real fixtures</div></div><span class="n">Rich</span></button>
    <button class="vbtn" data-v="table"><div><div class="k">Standings</div><div class="d">Group table · full height</div></div><span class="n">Max</span></button>
  </div>
  <div class="phase">Phase: <b id="phlabel">Standby</b></div>
</div>

<script>
const stage=document.getElementById('stage');
function fit(){stage.style.transform=`scale(${Math.min(innerWidth/1300,innerHeight/812)*0.985})`;}
addEventListener('resize',fit);fit();
const $=id=>document.getElementById(id);

const T={MEX:{n:'Mexico',f:'🇲🇽'},RSA:{n:'South Africa',f:'🇿🇦'},KOR:{n:'South Korea',f:'🇰🇷'},CZE:{n:'Czech Republic',f:'🇨🇿'}};
const tm=(k,r)=>`<span class="f">${T[k].f}</span>${r?'':''}${T[k].n}`;

// ── 各档内容（真实赛程；比分/积分为示意）──
function scoreCard(){return `<div class="card">
  <div class="sc-meta"><span class="l">World Cup · Group A Opener</span><span class="live"><i></i>67'</span></div>
  <div class="sc-main">
    <div class="tm"><div class="flag">🇲🇽</div><div class="nm">Mexico</div><div class="tm-bar" style="background:var(--mex)"></div></div>
    <div class="sco"><div class="num">1<em>:</em>0</div></div>
    <div class="tm"><div class="flag">🇿🇦</div><div class="nm">South Africa</div><div class="tm-bar" style="background:var(--rsa)"></div></div>
  </div></div>
  <div style="text-align:center;font-size:11px;color:var(--ink-faint);margin-top:8px">Illustrative score · Opener kicks off 6/11</div>`;}

function detailCard(){return `<div class="card">
  <div class="sc-meta"><span class="l">World Cup · Group A Opener <span class="badge">Illustrative</span></span><span class="live"><i></i>67'</span></div>
  <div class="sc-main">
    <div class="tm"><div class="flag">🇲🇽</div><div class="nm">Mexico</div></div>
    <div class="sco"><div class="num">1<em>:</em>0</div></div>
    <div class="tm"><div class="flag">🇿🇦</div><div class="nm">South Africa</div></div>
  </div>
  <div class="scorers">
    <div class="sl">Goal<br><b>⚽ Jimenez 23′</b></div>
    <div class="sr">Goal<br><b>—</b></div>
  </div>
  <div class="stats">
    ${stat('Possession',58,42,'%')}${stat('Shots',9,5)}${stat('On Target',4,2)}${stat('Corners',5,3)}
  </div></div>`;}
function stat(lab,a,b,suf){const t=a+b;return `<div class="st"><div class="row"><b>${a}${suf||''}</b><span class="lab">${lab}</span><b>${b}${suf||''}</b></div>
  <div class="bar"><div class="a" style="width:${a/t*100}%"></div><div class="b" style="width:${b/t*100}%"></div></div></div>`;}

const SCH=[
  {d:'Jun 11',s:'Opening Day',ms:[
    {t:'13:00',a:'MEX',b:'RSA',v:'Azteca Stadium · Mexico City'},
    {t:'20:00',a:'KOR',b:'CZE',v:'Akron Stadium · Zapopan'}]},
  {d:'Jun 18',s:'Matchday 2',ms:[
    {t:'12:00',a:'CZE',b:'RSA',v:'Mercedes-Benz Stadium · Atlanta'},
    {t:'19:00',a:'MEX',b:'KOR',v:'Akron Stadium · Zapopan'}]},
  {d:'Jun 24',s:'Final Matchday',ms:[
    {t:'19:00',a:'CZE',b:'MEX',v:'Azteca Stadium · Mexico City'},
    {t:'19:00',a:'RSA',b:'KOR',v:'BBVA Stadium · Guadalupe'}]},
];
function scheduleCard(){let h='<div class="card sch">';
  for(const day of SCH){h+=`<div class="day"><span class="dd">${day.d}</span><span class="ds">${day.s}</span></div>`;
    for(const m of day.ms){h+=`<div class="m"><span class="t">${m.t}</span>
      <div class="teams"><span class="f">${T[m.a].f}</span>${T[m.a].n}<span class="vs">VS</span>${T[m.b].n}<span class="f">${T[m.b].f}</span></div>
      <span class="v" style="grid-column:2">${m.v} · Local time</span></div>`;}}
  return h+'</div>';}

const TBL=[
  {k:'MEX',pld:2,w:2,d:0,l:0,gd:'+3',pts:6,q:1},
  {k:'KOR',pld:2,w:1,d:1,l:0,gd:'+2',pts:4,q:1},
  {k:'CZE',pld:2,w:0,d:1,l:1,gd:'−1',pts:1,q:0},
  {k:'RSA',pld:2,w:0,d:0,l:2,gd:'−4',pts:0,q:0},
];
function tableCard(){let h=`<div class="card tbl">
  <div class="tcap"><span>Group A Standings <span class="badge">Illustrative</span></span><span style="font-size:11px;color:var(--ink-soft);font-weight:600">After Matchday 2</span></div>
  <div class="th"><span class="c-pos">#</span><span class="c-tm">Team</span><span>P</span><span>W</span><span>D</span><span>L</span><span>GD</span><span class="c-pts">Pts</span></div>`;
  TBL.forEach((r,i)=>{h+=`<div class="tr${r.q?' q':''}"><span class="c-pos"><span class="pos">${i+1}</span></span>
    <span class="c-tm"><span class="f">${T[r.k].f}</span>${T[r.k].n}</span>
    <span>${r.pld}</span><span>${r.w}</span><span>${r.d}</span><span>${r.l}</span><span>${r.gd}</span><span class="c-pts">${r.pts}</span></div>`;});
  return h+`<div class="tlegend"><i></i>Top 2 advance automatically · 3rd competes for best third place</div></div>`;}

// 射手榜（真实球员头像 from Wikimedia；进球/助攻为示意）
const SCORERS=[
  {s:'mbappe',n:'Mbappé',team:'France',f:'🇫🇷',g:5,a:2},
  {s:'messi',n:'Messi',team:'Argentina',f:'🇦🇷',g:4,a:3},
  {s:'kane',n:'Kane',team:'England',f:'🏴󠁧󠁢󠁥󠁮󠁧󠁿',g:4,a:1},
  {s:'vinicius',n:'Vinícius Jr.',team:'Brazil',f:'🇧🇷',g:3,a:4},
  {s:'ronaldo',n:'C. Ronaldo',team:'Portugal',f:'🇵🇹',g:3,a:1},
];
function scorersCard(){let h=`<div class="card lb">
  <div class="cap"><span>World Cup Top Scorers <span class="badge">Illustrative</span></span><span style="font-size:11px;color:var(--ink-soft);font-weight:600">Goals · Assists</span></div>
  <div class="th"><span class="pos">#</span><span></span><span class="c-pl">Player</span><span>Goals</span><span>Ast</span></div>`;
  SCORERS.forEach((p,i)=>{h+=`<div class="r${i===0?' top':''}">
    <span class="pos">${i+1}</span>
    <img class="av" src="players/${p.s}.jpg" alt="${p.n}" loading="eager">
    <span class="pl"><span class="nm">${p.n}${i===0?' 👟':''}</span><span class="tt">${p.f} ${p.team}</span></span>
    <span class="g">${p.g}</span><span class="a">${p.a}</span></div>`;});
  return h+`<div class="lg">👟 Current Golden Boot · assists used as tiebreaker</div></div>`;}

const VAR={
  score:{asr:"What's the score in the Mexico match?",reply:'Mexico lead South Africa 1–0.',build:scoreCard},
  scorers:{asr:'Who has scored the most goals at the World Cup?',reply:'Mbappé leads with 5 goals, Messi close behind with 4.',build:scorersCard},
  detail:{asr:'What is happening in the Mexico match right now?',reply:'Mexico lead 1–0, with an edge in possession and shots.',build:detailCard},
  schedule:{asr:"What is Group A's schedule at the World Cup?",reply:'Group A has 6 matches — here is the full schedule.',build:scheduleCard},
  table:{asr:'What are the current Group A standings at the World Cup?',reply:'Group A standings — Mexico top after two straight wins.',build:tableCard},
};

const timers=[];const at=(ms,fn)=>timers.push(setTimeout(fn,ms));
function reset(){timers.forEach(clearTimeout);timers.length=0;
  $('avatar').classList.remove('awake');
  $('svAsr').className='sv-asr';$('svAsr').style.display='';$('asrText').textContent='';$('svAsr').scrollLeft=0;$('asrCur').style.display='';
  $('replyT').className='sv-reply';$('replyT').textContent='';
  $('content').className='content';$('content').innerHTML='';
  stage.classList.remove('voice-on');}
function typeASR(text,dur,done){const el=$('asrText'),sc=$('svAsr');let i=0;const step=Math.min(28,dur/text.length);
  (function tick(){el.textContent=text.slice(0,i);sc.scrollLeft=sc.scrollWidth;
    if(i++<=text.length)timers.push(setTimeout(tick,step));else done&&done();})();}
function play(key){
  const V=VAR[key];reset();
  [...$('vbtns').children].forEach(b=>b.classList.toggle('on',b.dataset.v===key));
  $('phlabel').textContent='Listening · Recognizing';
  $('avatar').classList.add('awake');   // 头像→MVA 光球（识别阶段先不推地图）
  $('svAsr').classList.add('show');
  typeASR(V.asr,Math.max(1600,V.asr.length*48));
  const t1=V.asr.length*48+400;
  at(t1,()=>{$('phlabel').textContent='Recognized';$('asrCur').style.display='none';$('svAsr').classList.add('done');});
  at(t1+650,()=>$('svAsr').classList.add('gone'));
  at(t1+1150,()=>{$('svAsr').style.display='none';$('replyT').textContent=V.reply;$('replyT').classList.add('show');stage.classList.add('voice-on');$('phlabel').textContent='Showing result';});  // 回复出现、内容即将生长时，再把地图推开
  at(t1+1750,()=>{$('content').innerHTML=V.build();requestAnimationFrame(()=>$('content').classList.add('show'));
    $('phlabel').textContent='Done · Switch buttons above to see different richness levels';});
}
$('vbtns').addEventListener('click',e=>{const b=e.target.closest('.vbtn');if(b)play(b.dataset.v);});
setTimeout(()=>play('schedule'),600);
</script>

<script>
(function(){
  var orb=document.getElementById('mvaOrb');if(!orb)return;
  var stage=document.querySelector('.stage');
  var watch=[document.querySelector('.voice-zone'),document.querySelector('.statusbar')].filter(Boolean);
  var busy=true,settleT=null;
  function en(on){orb.classList.toggle('busy',!on);}
  function settle(){busy=false;en(true);}
  function bump(){busy=true;en(false);clearTimeout(settleT);settleT=setTimeout(settle,1200);}
  try{var obs=new MutationObserver(bump);watch.forEach(function(n){obs.observe(n,{childList:true,subtree:true,characterData:true,attributes:true,attributeFilter:['class','style']});});}catch(e){}
  bump();
  orb.onclick=function(){if(busy)return;stage.classList.toggle('zone-hidden');};
})();
</script>
</body>
</html>
