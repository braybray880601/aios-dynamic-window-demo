<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Mercedes-Benz · Voice Zone · Movie Picks</title>
<!--
  电影推荐场景（装进固定宽度、动态生长的语音区）。
  用户：「推荐几个最近好看的电影」
  → 顶栏识别/回复；地图卡推右让位
  → 思考胶囊呈现「思考 + 搜索」过程（理解需求 → 检索 → 筛选 → 排序）
  → 内容区用真实电影海报 + 简介 + 导演/主演/上映时间，展示 3 个推荐结果
  数据经 WebSearch 核实（2026-06）；海报取自 Wikipedia 真实文件；简介为原创转述。
-->
<style>
  :root{--card:rgba(20,26,38,.7);--card-bd:rgba(255,255,255,.1);--ink:#eef1f4;--soft:rgba(238,241,244,.62);--faint:rgba(238,241,244,.4);--gold:#ffcf6a;--green:#34d06a;--blue:#3b78ff;--vz-w:430px}
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{height:100%;background:#05070b;overflow:hidden;font-family:"PingFang SC","Microsoft YaHei",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;-webkit-font-smoothing:antialiased;color:var(--ink)}
  .viewport{position:fixed;inset:0;display:flex;align-items:center;justify-content:center}
  .stage{position:relative;width:1300px;height:812px;overflow:hidden;transform-origin:center center;border-radius:18px;box-shadow:0 40px 120px rgba(0,0,0,.65);background:radial-gradient(135% 115% at 50% 8%,#141c2a 0%,#0e1420 46%,#080b12 100%)}
  .mapbg{position:absolute;inset:0;z-index:0}.mapbg svg{position:absolute;inset:0;width:100%;height:100%}
  .mapbg-scrim{position:absolute;inset:0;background:radial-gradient(125% 105% at 50% 40%,rgba(8,11,18,.5),rgba(6,9,15,.76))}

  .statusbar{position:absolute;top:0;left:0;right:0;height:50px;display:flex;align-items:center;justify-content:space-between;padding:0 24px;z-index:55}
  .sb-left{display:flex;align-items:center;gap:13px;flex:1;min-width:0;height:100%;padding-right:24px}
  .avatar{width:36px;height:36px;border-radius:50%;flex:none;position:relative;background-image:linear-gradient(135deg,#f3c9b0,#cf9d86);box-shadow:inset 0 0 0 1.5px rgba(255,255,255,.4);transition:box-shadow .5s}
  .avatar::before{content:"";position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);filter:blur(1px);opacity:0;transition:opacity .55s;animation:spin 5s linear infinite}
  .avatar::after{content:"";position:absolute;inset:7px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.6));box-shadow:0 0 14px rgba(255,255,255,.55);opacity:0;transition:opacity .55s}
  .avatar.awake{box-shadow:none;animation:breathe 3.2s ease-in-out infinite}.avatar.awake::before,.avatar.awake::after{opacity:1}
  @keyframes spin{to{transform:rotate(360deg)}}@keyframes breathe{0%,100%{transform:scale(1)}50%{transform:scale(1.07)}}
  .sb-voice{position:relative;display:flex;align-items:center;min-width:0;height:100%}
  .sv-asr{display:inline-flex;align-items:center;max-width:640px;overflow:hidden;white-space:nowrap;font-size:15.5px;font-weight:600;color:var(--ink);opacity:0;transition:opacity .35s,transform .4s,filter .4s}
  .sv-asr.show{opacity:1}.sv-asr.done{color:#62e08c}.sv-asr.gone{opacity:0;transform:translateY(-7px);filter:blur(2px)}
  .sv-cur{display:inline-block;width:2px;height:16px;background:#62e08c;margin-left:2px;animation:blink 1s step-end infinite}@keyframes blink{50%{opacity:0}}
  .sv-reply{font-size:15.5px;font-weight:600;color:#fff;white-space:nowrap;opacity:0;transform:translateY(4px);transition:opacity .45s,transform .45s;text-shadow:0 1px 12px rgba(0,0,0,.5)}.sv-reply.show{opacity:1;transform:none}
  .sb-right{display:flex;align-items:center;gap:16px;color:#dfe3e8;flex:none}.sb-clock{font-size:19px;font-weight:500}.sb-5g{font-size:10px;font-weight:700;vertical-align:top}

  .map{position:absolute;top:64px;left:40px;width:300px;border-radius:20px;background:rgba(44,52,64,.5);backdrop-filter:blur(22px) saturate(1.2);-webkit-backdrop-filter:blur(22px) saturate(1.2);box-shadow:0 8px 30px rgba(0,0,0,.3),inset 0 0 0 1px rgba(255,255,255,.12);overflow:hidden;z-index:25;color:#fff;transition:transform .42s cubic-bezier(.2,.7,.2,1)}
  .stage.voice-on .map{transform:translateX(calc(var(--vz-w) + 16px))}
  .map-top{display:flex;align-items:center;gap:9px;padding:14px 16px}.map-top .t{flex:1;font-size:16px;font-weight:500}
  .map-quick{display:flex;background:rgba(10,14,20,.4)}.map-quick div{flex:1;display:flex;align-items:center;justify-content:center;padding:12px 0;opacity:.85}.map-quick div+div{box-shadow:inset 1px 0 0 rgba(255,255,255,.08)}
  .weather{position:absolute;top:60px;right:36px;text-align:right;z-index:25}
  .weather .temp{font-size:60px;font-weight:200;line-height:.9;letter-spacing:-1px;color:#fff}.weather .temp sup{font-size:20px;font-weight:300;vertical-align:top;margin-left:2px}.weather .loc{font-size:15px;color:var(--soft);margin-top:6px}
  .cards{position:absolute;left:40px;right:40px;bottom:84px;display:flex;gap:16px;z-index:15}
  .card{flex:1;height:96px;border-radius:18px;background:rgba(24,30,40,.6);backdrop-filter:blur(20px) saturate(1.2);box-shadow:0 8px 26px rgba(0,0,0,.25),inset 0 0 0 1px rgba(255,255,255,.1);display:flex;align-items:center;gap:13px;padding:0 18px;color:#eef1f4}
  .card .ic{width:42px;height:42px;border-radius:11px;flex:none;display:flex;align-items:center;justify-content:center;font-size:20px;background:rgba(255,255,255,.08)}
  .card .ic.pink{background:linear-gradient(135deg,#ff7a9c,#ff5277)}.card .big{font-size:18px;font-weight:600}.card .sub{font-size:12px;color:var(--soft);margin-top:3px}.card .lnk{color:#7fa8ff;font-weight:600}
  .card .col2{display:flex;gap:18px;width:100%}.tyre{display:flex;flex-direction:column;gap:4px;font-size:12px;color:var(--soft);width:100%}.tyre .r{display:flex;justify-content:space-between}.tyre .tcar{align-self:center;width:26px;height:14px;border-radius:5px;background:rgba(255,255,255,.16);margin:1px 0}

  /* ── 语音区：固定宽、动态长高 ── */
  .voice-zone{position:absolute;left:40px;top:64px;z-index:50;width:var(--vz-w);display:flex;flex-direction:column;gap:11px}

  /* 思考胶囊 */
  .think{display:none}
  .think.show{display:block;animation:grow .4s ease}
  @keyframes grow{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:none}}
  .think-pill{display:flex;align-items:center;gap:9px;cursor:pointer;background:var(--card);backdrop-filter:blur(22px);border-radius:14px;box-shadow:inset 0 0 0 1px var(--card-bd);padding:10px 14px;user-select:none}
  .think-pill .spark{color:#b9a4ff;font-size:14px;animation:pulse 1.4s ease-in-out infinite}
  .think.done .think-pill .spark{color:var(--gold);animation:none}
  @keyframes pulse{0%,100%{opacity:.5;transform:scale(.9)}50%{opacity:1;transform:scale(1.15)}}
  .think-pill .pt{font-size:13.5px;font-weight:600;color:var(--soft);flex:1}
  .think.done .think-pill .pt{color:var(--ink)}
  .think-pill .chev{font-size:11px;color:var(--faint);transition:transform .3s}
  .think.open .think-pill .chev{transform:rotate(180deg)}
  .think-panel{max-height:0;overflow:hidden;transition:max-height .4s ease}
  .think.open .think-panel{max-height:260px}
  .tsteps{margin:9px 2px 2px;padding-left:6px;border-left:1.5px solid rgba(150,130,255,.3);display:flex;flex-direction:column;gap:10px}
  .tstep{opacity:0;transform:translateX(-6px);transition:opacity .35s,transform .35s;display:flex;gap:9px;align-items:flex-start;padding-left:8px}
  .tstep.in{opacity:1;transform:none}
  .tstep .ti{font-size:13px;line-height:1.2;flex:none;width:18px;text-align:center}
  .tstep .tt{font-size:13px;font-weight:600;color:var(--ink)}
  .tstep .ts{font-size:11.5px;color:var(--soft);margin-top:1px}
  .tstep.cur .tt::after{content:"…";color:var(--soft)}

  /* ── 结果区：英雄卡 + 备选条 ── */
  .result{display:none;flex-direction:column;gap:11px}
  .result.in{display:flex}

  /* 英雄卡 */
  .hero{opacity:0;transform:translateY(10px);transition:opacity .45s cubic-bezier(.2,.7,.2,1),transform .45s cubic-bezier(.2,.7,.2,1);display:flex;gap:15px;background:var(--card);backdrop-filter:blur(20px) saturate(1.2);-webkit-backdrop-filter:blur(20px) saturate(1.2);border-radius:18px;box-shadow:0 14px 34px rgba(0,0,0,.4),inset 0 0 0 1px var(--card-bd);padding:15px;position:relative;overflow:hidden}
  .result.in .hero{opacity:1;transform:none}
  .hero .hposter{width:118px;height:172px;flex:none;border-radius:12px;object-fit:cover;background:#222b39;box-shadow:0 6px 20px rgba(0,0,0,.5);transition:opacity .3s}
  .hinfo{flex:1;min-width:0;display:flex;flex-direction:column;padding-top:2px}
  .hwhy{font-size:11.5px;font-weight:700;color:var(--gold);letter-spacing:.02em;display:flex;align-items:center;gap:6px}
  .hwhy .spk{font-size:12px;filter:drop-shadow(0 0 6px rgba(255,207,106,.5))}
  .htitle{font-size:24px;font-weight:800;letter-spacing:.01em;color:var(--ink);margin-top:9px;line-height:1.15;transition:opacity .3s}
  .hchips{display:flex;gap:7px;margin-top:11px;flex-wrap:wrap}
  .chip{font-size:11px;font-weight:700;padding:4px 9px;border-radius:8px;background:rgba(255,255,255,.08);color:rgba(238,241,244,.86);box-shadow:inset 0 0 0 1px rgba(255,255,255,.07)}
  .chip.gold{color:var(--gold);background:rgba(255,207,106,.14);box-shadow:inset 0 0 0 1px rgba(255,207,106,.22)}
  .hplay{margin-top:auto;display:inline-flex;align-items:center;justify-content:center;gap:8px;border:0;cursor:pointer;font-family:inherit;font-weight:800;font-size:15px;padding:12px 16px;border-radius:13px;color:#0b1018;background:linear-gradient(135deg,#ffd980,#ffc24d);box-shadow:0 8px 20px rgba(255,194,77,.34);transition:.15s;letter-spacing:.02em}
  .hplay:hover{filter:brightness(1.06)}.hplay:active{transform:translateY(1px)}

  /* 备选海报条 */
  .alts{opacity:0;transform:translateY(8px);transition:opacity .45s,transform .45s;display:flex;align-items:center;gap:10px}
  .result.in .alts{opacity:1;transform:none}
  .alts .albl{font-size:11px;font-weight:700;color:var(--faint);flex:none;letter-spacing:.04em}
  .altrow{display:flex;gap:9px;flex:1;min-width:0}
  .alt{position:relative;width:54px;height:79px;border-radius:9px;overflow:hidden;cursor:pointer;flex:none;box-shadow:0 4px 12px rgba(0,0,0,.4),inset 0 0 0 1px rgba(255,255,255,.08);transition:transform .2s,box-shadow .2s,opacity .2s}
  .alt img{width:100%;height:100%;object-fit:cover;display:block}
  .alt::after{content:attr(data-t);position:absolute;left:0;right:0;bottom:0;padding:9px 5px 4px;font-size:9px;font-weight:700;color:#fff;background:linear-gradient(transparent,rgba(0,0,0,.82));opacity:0;transition:opacity .2s;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .alt:hover{transform:translateY(-3px);box-shadow:0 8px 18px rgba(0,0,0,.5),inset 0 0 0 1px rgba(255,207,106,.5)}
  .alt:hover::after{opacity:1}

  /* ── 正在播放 表面 ── */
  /* 全屏播放页：接管整个 stage */
  .nowplay{display:none;position:absolute;inset:0;z-index:90;overflow:hidden;background:#06080d}
  .nowplay.show{display:block;animation:npin .45s ease}
  @keyframes npin{from{opacity:0}to{opacity:1}}
  .np-bg{position:absolute;inset:0;background-size:cover;background-position:center;filter:blur(3px) brightness(.42);transform:scale(1.1)}
  .np-scrim{position:absolute;inset:0;background:linear-gradient(180deg,rgba(6,8,13,.45) 0%,rgba(6,8,13,.5) 48%,rgba(6,8,13,.92) 100%)}
  .np-body{position:relative;z-index:2;height:100%;display:flex;flex-direction:column;padding:30px 44px 36px}
  .np-top{display:flex;align-items:center;gap:12px}
  .np-live{font-size:13px;font-weight:800;color:#06080d;background:var(--green);padding:5px 13px;border-radius:8px;letter-spacing:.05em}
  .np-open{font-size:14px;font-weight:700;color:#9fe9b6}
  .np-back{margin-left:auto;font-size:14px;font-weight:700;color:#dfe6ef;background:rgba(255,255,255,.12);padding:9px 17px;border-radius:11px;cursor:pointer;border:0;font-family:inherit;transition:.15s}
  .np-back:hover{background:rgba(255,255,255,.2);color:#fff}
  .np-center{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:24px}
  .np-pbtn{width:94px;height:94px;flex:none;border-radius:50%;background:rgba(255,255,255,.95);display:flex;align-items:center;justify-content:center;font-size:34px;color:#06080d;box-shadow:0 12px 44px rgba(0,0,0,.55);cursor:pointer;transition:transform .15s}
  .np-pbtn:hover{transform:scale(1.07)}
  .np-meta{text-align:center;min-width:0;max-width:80%}
  .np-ttl{font-size:42px;font-weight:800;color:#fff;line-height:1.08;text-shadow:0 3px 20px rgba(0,0,0,.6)}
  .np-sub{font-size:15.5px;color:rgba(255,255,255,.8);margin-top:11px}
  .np-prog{display:flex;align-items:center;gap:14px;font-size:13px;color:rgba(255,255,255,.85);font-variant-numeric:tabular-nums}
  .np-bar{flex:1;height:5px;border-radius:3px;background:rgba(255,255,255,.24);overflow:hidden}
  .np-fill{height:100%;width:8%;border-radius:3px;background:linear-gradient(90deg,#ffd980,#ffc24d);transition:width 1s linear}

  .dock{position:absolute;left:0;right:0;bottom:0;height:64px;z-index:30;display:flex;align-items:center;gap:18px;padding:0 22px;background:rgba(12,16,24,.6);backdrop-filter:blur(26px);box-shadow:inset 0 1px 0 rgba(255,255,255,.08)}
  .dock .home{width:32px;height:32px;border-radius:50%;box-shadow:inset 0 0 0 2px rgba(255,255,255,.5);flex:none}
  .dock .tt{font-size:13px;color:var(--soft)}.dock .sep{flex:1}.dock .ctrl{display:flex;align-items:center;gap:24px;color:rgba(238,241,244,.7);font-size:18px}

  .panel{position:fixed;top:18px;right:18px;width:236px;z-index:100;background:rgba(20,22,26,.9);backdrop-filter:blur(20px);border-radius:16px;padding:15px;color:#e8eaee;font-size:12.5px;box-shadow:0 20px 50px rgba(0,0,0,.5),inset 0 0 0 1px rgba(255,255,255,.08)}
  .panel .title{font-size:13.5px;font-weight:700;color:#fff;display:flex;align-items:center;gap:7px;margin-bottom:12px}.panel .title i{width:8px;height:8px;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#ff6b9b,#ffab5b,#5b8cff)}
  .ask{width:100%;border:0;border-radius:12px;cursor:pointer;font-family:inherit;font-weight:600;font-size:13.5px;padding:13px;color:#fff;background:linear-gradient(135deg,#3b78ff,#2f6bff);box-shadow:0 6px 18px rgba(47,107,255,.45);transition:.15s}
  .ask:hover{filter:brightness(1.08)}.panel .phase{margin-top:12px;font-size:11px;color:#8b9098;border-top:1px solid rgba(255,255,255,.08);padding-top:10px}.panel .phase b{color:#ffce8a}
  /* 演示控制台：默认弱化半透明、略缩小，悬停恢复清晰（不抢演示效果） */
  .panel{opacity:.3;transform:scale(.86);transform-origin:top right;transition:opacity .3s ease,transform .3s ease}
  .panel:hover{opacity:1;transform:scale(1)}

  /* 全局：底栏 MVA 光球（语音区收起时的最小化态 · 点击唤起；区域展开时淡出）*/
  .mva-orb{width:38px;height:38px;border-radius:50%;flex:none;border:0;padding:0;cursor:pointer;position:relative;background:radial-gradient(circle at 38% 34%,#2a3340,#11161f);transition:transform .15s,opacity .35s}
  .mva-orb::before{content:"";position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,#5b8cff,#9b6bff,#ff6b9b,#ffab5b,#5bd6ff,#5b8cff);filter:blur(.6px);animation:mvaspin 6s linear infinite}
  .mva-orb::after{content:"";position:absolute;inset:7px;border-radius:50%;background:radial-gradient(circle at 38% 34%,#fff,rgba(255,255,255,.62));box-shadow:0 0 11px rgba(255,255,255,.5)}
  .mva-orb:hover{transform:scale(1.06)}.mva-orb:active{transform:scale(.93)}
  .stage.voice-on .mva-orb{opacity:.4}
  .mva-orb.busy{opacity:.26 !important;pointer-events:none;filter:saturate(.55)}
  .stage.zone-hidden .voice-zone{opacity:0 !important;transform:translateY(-10px) scale(.985) !important;pointer-events:none !important;transition:opacity .35s ease,transform .35s ease}
  .stage.zone-hidden .map{transform:none !important}
  @keyframes mvaspin{to{transform:rotate(360deg)}}
</style>
</head>
<body>
<div class="viewport">
  <div class="stage" id="stage">
    <div class="mapbg">
      <svg viewBox="0 0 1300 812" preserveAspectRatio="xMidYMid slice">
        <defs><linearGradient id="bg" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#1c2533"/><stop offset="1" stop-color="#151b25"/></linearGradient></defs>
        <rect width="1300" height="812" fill="url(#bg)"/>
        <path d="M-20 612 C 120 588 210 640 250 720 C 270 766 250 812 250 812 L -20 812 Z" fill="#1d3144"/>
        <path d="M 1010 70 C 1110 60 1190 110 1180 200 C 1172 280 1080 300 1020 250 C 970 210 950 110 1010 70 Z" fill="#21362b"/>
        <g stroke="#222b39" stroke-width="15" fill="none" stroke-linecap="round"><path d="M-20 590 C 230 560 440 540 640 548 C 900 558 1080 520 1330 452"/><path d="M 300 -20 C 350 200 400 410 540 560 C 660 690 740 760 800 840"/><path d="M 1330 150 C 1150 210 1050 330 1010 470 C 980 640 1010 760 1030 840"/></g>
        <g stroke="#4b5566" stroke-width="9" fill="none" stroke-linecap="round"><path d="M-20 590 C 230 560 440 540 640 548 C 900 558 1080 520 1330 452"/><path d="M 300 -20 C 350 200 400 410 540 560 C 660 690 740 760 800 840"/><path d="M 1330 150 C 1150 210 1050 330 1010 470 C 980 640 1010 760 1030 840"/></g>
        <g fill="#9aa3b0" font-size="15"><text x="430" y="470">Moganshan</text><text x="800" y="210">Daixi</text><text x="1110" y="150">Donglin</text></g>
      </svg>
      <div class="mapbg-scrim"></div>
    </div>

    <div class="statusbar">
      <div class="sb-left">
        <div class="avatar" id="avatar"></div>
        <div class="sb-voice"><span class="sv-asr" id="svAsr"><span id="asrText"></span><span class="sv-cur" id="asrCur"></span></span><span class="sv-reply" id="svReply"></span></div>
      </div>
      <div class="sb-right"><span><sup class="sb-5g">5G</sup> ▮▮▮</span><span class="sb-clock">21:36</span></div>
    </div>

    <div class="map">
      <div class="map-top"><span>📍</span><span class="t">Navigation</span><svg width="18" height="18" viewBox="0 0 18 18"><circle cx="7.5" cy="7.5" r="5.5" fill="none" stroke="#fff" stroke-width="1.6"/><path d="M12 12l4 4" stroke="#fff" stroke-width="1.6" stroke-linecap="round"/></svg></div>
      <div class="map-quick"><div>⌂</div><div>☰</div><div>★</div><div>⚡</div></div>
    </div>
    <div class="weather"><div class="temp">14<sup>°C</sup></div><div class="loc">Shanghai&nbsp;&nbsp;Clear Night</div></div>

    <!-- 语音区：思考胶囊 + 电影卡 -->
    <div class="voice-zone" id="vz">
      <div class="think" id="think">
        <div class="think-pill" id="thinkPill"><span class="spark">✦</span><span class="pt" id="pillText">Picking movies for you...</span><span class="chev">▾</span></div>
        <div class="think-panel"><div class="tsteps" id="tsteps"></div></div>
      </div>
      <!-- 结果：英雄推荐卡 + 备选条 -->
      <div class="result" id="result">
        <div class="hero" id="hero">
          <img class="hposter" id="hposter" src="" alt="Poster"/>
          <div class="hinfo">
            <div class="hwhy"><span class="spk">✦</span><span id="hwhy">MVA For you · Top Rated</span></div>
            <div class="htitle" id="htitle">Title</div>
            <div class="hchips" id="hchips"></div>
            <button class="hplay" id="hplay">▶ Watch Now</button>
          </div>
        </div>
        <div class="alts">
          <span class="albl">You might like</span>
          <div class="altrow" id="altrow"></div>
        </div>
      </div>

    </div>

    <!-- 全屏播放页（点击「立即观看」后接管整屏）-->
    <div class="nowplay" id="nowplay">
      <div class="np-bg" id="npBg"></div>
      <div class="np-scrim"></div>
      <div class="np-body">
        <div class="np-top">
          <span class="np-live">● Now Playing</span>
          <span class="np-open">MVA has opened Theater Mode for you</span>
          <button class="np-back" id="npBack">‹ Back to List</button>
        </div>
        <div class="np-center">
          <div class="np-pbtn">▶</div>
          <div class="np-meta">
            <div class="np-ttl" id="npTtl">Title</div>
            <div class="np-sub" id="npSub">Starting playback · Ultra HD</div>
          </div>
        </div>
        <div class="np-prog"><span id="npCur">00:00</span><div class="np-bar"><div class="np-fill" id="npFill"></div></div><span id="npDur">02:36</span></div>
      </div>
    </div>

    <div class="dock"><button class="mva-orb" id="mvaOrb" title="MVA · Open Voice Zone"></button><div class="tt">🎬 Movie Picks</div><div class="sep"></div><div class="ctrl"><span>❄</span><span>🚘</span><span>360</span><span>📞</span><span>▦</span></div></div>
  </div>
</div>

<div class="panel">
  <div class="title"><i></i>Movie Picks · Voice Zone</div>
  <button class="ask" id="ask">🎤 "Recommend some good movies to watch tonight"</button>
  <button class="ask" id="btnAlt" style="margin-top:8px;background:linear-gradient(135deg,#3a4150,#2b313d);box-shadow:0 6px 18px rgba(0,0,0,.35)">🔄 Switch Pick</button>
  <button class="ask" id="btnWatch" style="margin-top:8px;background:linear-gradient(135deg,#ffd980,#ffc24d);color:#0b1018;box-shadow:0 6px 18px rgba(255,194,77,.32)">▶ Watch This</button>
  <button class="ask" id="btnReset" style="margin-top:8px;background:linear-gradient(135deg,#3a4150,#2b313d);box-shadow:0 6px 18px rgba(0,0,0,.35)">↺ Reset</button>
  <div class="phase">Phase: <b id="phlabel">Standby</b></div>
</div>

<script>
const stage=document.getElementById('stage');
function fit(){stage.style.transform=`scale(${Math.min(innerWidth/1300,innerHeight/812)*0.985})`;}
addEventListener('resize',fit);fit();
const $=id=>document.getElementById(id);

const STEPS=[
  {ic:'🧭',t:'Understanding request',s:'Recent releases · Top-rated first'},
  {ic:'🔍',t:'Searching recent high-score films',s:'Maoyan · Douban · Mtime'},
  {ic:'⚖️',t:'Filtering by rating & variety',s:'Score ≥ 8.5 · Cross-genre'},
  {ic:'🎯',t:'Ranking by your viewing preferences',s:'Sci-fi / Drama fan'},
];
// 数据经 WebSearch 核实（2026-06）；简介为原创转述
// 第二部为主推（评分最高 9.2），首屏即作为英雄卡
const FILMS=[
  {poster:'movies/ama.png',title:'Letters to Grandma',score:'9.2',why:'Top Rated',genre:'Family / Romance',runtime:'112 min',dur:'01:52'},
  {poster:'movies/phm.jpg',title:'Project Hail Mary',score:'8.7',why:'Hot Today',genre:'Sci-Fi',runtime:'156 min',dur:'02:36'},
  {poster:'movies/nanjing.png',title:'Nanjing Studio',score:'8.8',why:'Best of the Year',genre:'History / Drama',runtime:'128 min',dur:'02:08'},
];

$('tsteps').innerHTML=STEPS.map((s,i)=>`<div class="tstep" id="ts${i}"><span class="ti">${s.ic}</span><div><div class="tt">${s.t}</div><div class="ts">${s.s}</div></div></div>`).join('');

// 当前英雄索引
let heroIdx=0;
// 渲染英雄卡
function renderHero(i){
  heroIdx=i;const f=FILMS[i];
  $('hposter').src=f.poster;$('hposter').alt=f.title+' Poster';
  $('hwhy').textContent=`MVA For you · ${f.why} ${f.score}`;
  $('htitle').textContent=f.title;
  $('hchips').innerHTML=`<span class="chip gold">★ ${f.score}</span><span class="chip">${f.genre}</span><span class="chip">${f.runtime}</span>`;
}
// 渲染备选条（除当前英雄外的两部）
function renderAlts(){
  $('altrow').innerHTML=FILMS.map((f,i)=>i===heroIdx?'':
    `<div class="alt" data-i="${i}" data-t="${f.title}"><img src="${f.poster}" alt="${f.title} Poster"/></div>`).join('');
  $('altrow').querySelectorAll('.alt').forEach(el=>el.onclick=()=>swapHero(+el.dataset.i));
}
// 点击备选 → 换入英雄位
function swapHero(i){
  if(i===heroIdx)return;
  $('hposter').style.opacity='0';$('htitle').style.opacity='0';
  setTimeout(()=>{renderHero(i);renderAlts();$('hposter').style.opacity='1';$('htitle').style.opacity='1';},180);
}
renderHero(0);renderAlts();

const timers=[];const at=(ms,fn)=>timers.push(setTimeout(fn,ms));
let progT=null;
function stopPlayback(){
  $('nowplay').classList.remove('show');
  if(progT){clearInterval(progT);progT=null;}
  $('npFill').style.width='8%';$('npCur').textContent='00:00';
}
function reset(){
  timers.forEach(clearTimeout);timers.length=0;
  stopPlayback();
  $('avatar').classList.remove('awake');stage.classList.remove('voice-on');
  $('svAsr').className='sv-asr';$('svAsr').style.display='';$('asrText').textContent='';$('svAsr').scrollLeft=0;$('asrCur').style.display='';
  $('svReply').className='sv-reply';$('svReply').textContent='';
  $('think').className='think';$('pillText').textContent='Picking movies for you...';
  STEPS.forEach((s,i)=>{const e=$('ts'+i);e.className='tstep';});
  $('result').classList.remove('in');
  renderHero(0);renderAlts();
  $('hposter').style.opacity='1';$('htitle').style.opacity='1';
}
function typeASR(text,dur){const el=$('asrText'),sc=$('svAsr');let i=0;const step=Math.min(28,dur/text.length);
  (function tick(){el.textContent=text.slice(0,i);sc.scrollLeft=sc.scrollWidth;if(i++<=text.length)timers.push(setTimeout(tick,step));})();}

function play(){
  reset();
  $('phlabel').textContent='Listening · Recognizing';
  $('avatar').classList.add('awake');$('svAsr').classList.add('show');
  typeASR('Recommend some good movies to watch tonight',2200);
  at(2500,()=>{$('asrCur').style.display='none';$('svAsr').classList.add('done');});
  at(3000,()=>$('svAsr').classList.add('gone'));
  at(3400,()=>{$('svAsr').style.display='none';$('svReply').textContent='Sure, let me check the latest top-rated films 🎬';$('svReply').classList.add('show');$('phlabel').textContent='Thinking · Searching';
    stage.classList.add('voice-on');/* 思考胶囊也是语音区内容：先把地图推开再出胶囊，避免叠放遮挡 */});
  // 思考胶囊（展开）+ 步骤逐条出现
  at(3800,()=>{$('think').classList.add('show','open');});
  const base=4100,gap=900;
  STEPS.forEach((s,i)=>{
    at(base+i*gap,()=>{$('ts'+i).classList.add('in','cur');$('pillText').textContent=s.t+'...';});
    at(base+i*gap+gap-150,()=>$('ts'+i).classList.remove('cur'));
  });
  const tdone=base+STEPS.length*gap+200;
  // 胶囊收起 + 完成态
  at(tdone,()=>{$('think').classList.remove('open');$('think').classList.add('done');$('pillText').textContent='Reviewed ~120 films · Top pick selected for you';});
  at(tdone+250,()=>{$('svReply').textContent='This one fits you best — want to watch it now?';$('phlabel').textContent='Showing results';});
  // 英雄卡 + 备选条 生长
  at(tdone+550,()=>{renderHero(0);renderAlts();$('result').classList.add('in');});
  at(tdone+1100,()=>$('phlabel').textContent='Done · ▶ Watch Now / Switch Pick');
}

// 立即观看 → 正在播放表面
function watch(){
  const f=FILMS[heroIdx];
  $('npBg').style.backgroundImage=`url("${f.poster}")`;
  $('npTtl').textContent=f.title;
  $('npSub').textContent=`${f.genre} · ${f.runtime} · Ultra HD`;
  $('npDur').textContent=f.dur;
  $('result').classList.remove('in');
  $('nowplay').classList.add('show');
  $('svReply').textContent=`Opening "${f.title}" — pull over to start watching 🍿`;$('svReply').classList.add('show');
  $('phlabel').textContent='Now Playing';
  // 模拟进度
  $('npFill').style.width='8%';$('npCur').textContent='00:00';
  let sec=0;if(progT)clearInterval(progT);
  progT=setInterval(()=>{sec+=1;const m=String(Math.floor(sec/60)).padStart(2,'0'),s=String(sec%60).padStart(2,'0');
    $('npCur').textContent=`${m}:${s}`;$('npFill').style.width=Math.min(8+sec*4,100)+'%';
    if(sec>=22){clearInterval(progT);progT=null;}},1000);
}
// 返回片单
function backToList(){
  stopPlayback();
  $('result').classList.add('in');
  $('svReply').textContent='Paused. Switch to something else anytime.';
  $('phlabel').textContent='Done · ▶ Watch Now / Switch Pick';
}
$('hplay').onclick=watch;
$('npBack').onclick=backToList;

$('thinkPill').onclick=()=>$('think').classList.toggle('open');

// 演示控制台
$('ask').onclick=play;
$('btnAlt').onclick=()=>{ // 切换到下一个备选
  if(!$('result').classList.contains('in'))return;
  swapHero((heroIdx+1)%FILMS.length);
};
$('btnWatch').onclick=()=>{ // 直接看这部
  if($('result').classList.contains('in'))watch();
};
$('btnReset').onclick=reset;
setTimeout(play,600);
</script>

<script>
(function(){
  var orb=document.getElementById('mvaOrb');if(!orb)return;
  var stage=document.querySelector('.stage');
  var watch=[document.querySelector('.voice-zone'),document.querySelector('.statusbar')].filter(Boolean);
  var busy=true,settleT=null;
  function en(on){orb.classList.toggle('busy',!on);}
  function settle(){busy=false;en(true);}
  function bump(){busy=true;en(false);clearTimeout(settleT);settleT=setTimeout(settle,1200);}
  try{var obs=new MutationObserver(bump);watch.forEach(function(n){obs.observe(n,{childList:true,subtree:true,characterData:true,attributes:true,attributeFilter:['class','style']});});}catch(e){}
  bump();
  orb.onclick=function(){if(busy)return;stage.classList.toggle('zone-hidden');};
})();
</script>
</body>
</html>
